@page "/setup"
@rendermode InteractiveServer
@using HomeschoolManager.Application.Common
@using HomeschoolManager.Application.Requirements
@using HomeschoolManager.Application.Setup
@using HomeschoolManager.Domain.Access
@using HomeschoolManager.Web.Services
@inject SetupService SetupService
@inject RequirementService RequirementService
@inject SessionState Session

<PageTitle>Setup</PageTitle>

<h1>Setup</h1>

@if (!Session.IsParentAdmin)
{
    <div class="alert alert-warning">Sign in as parent/admin to manage setup.</div>
}
else
{
    <section class="status-panel">
        <h2>Current setup</h2>
        @if (summary is null)
        {
            <p>Loading setup status...</p>
        }
        else
        {
            <ul>
                <li>Household: @Display(summary.HasHousehold, summary.HouseholdName)</li>
                <li>School profile: @Display(summary.HasSchoolProfile, summary.SchoolName)</li>
                <li>Children: @(summary.StudentCount == 0 ? "Not set" : $"{summary.StudentCount} configured")</li>
                <li>School year: @Display(summary.HasSchoolYear, summary.SchoolYearName)</li>
            </ul>
        }
    </section>

    <section class="form-section">
        <h2>Household</h2>
        <label class="form-label" for="household-name">Household name <span class="required-marker">*</span></label>
        <input id="household-name" class="form-control" @bind="household.HouseholdName" />
        @ValidationFor("household.HouseholdName")
        <label class="form-label" for="parent-name">Parent/guardian name <span class="required-marker">*</span></label>
        <input id="parent-name" class="form-control" @bind="household.ParentGuardianName" />
        @ValidationFor("household.ParentGuardianName")
        <button class="btn btn-primary mt-2" @onclick="SaveHousehold">Save household</button>
    </section>

    <section class="form-section">
        <h2>School profile</h2>
        <label class="form-label" for="school-name">School name <span class="required-marker">*</span></label>
        <input id="school-name" class="form-control" @bind="school.SchoolName" />
        @ValidationFor("school.SchoolName")
        <label class="form-label" for="administrator-name">Administrator parent name <span class="required-marker">*</span></label>
        <input id="administrator-name" class="form-control" @bind="school.AdministratorParentName" />
        @ValidationFor("school.AdministratorParentName")
        <label class="form-label" for="jurisdiction">Jurisdiction <span class="required-marker">*</span></label>
        <input id="jurisdiction" class="form-control" @bind="school.Jurisdiction" />
        @ValidationFor("school.Jurisdiction")
        <label class="form-label" for="start-date">Homeschool start date <span class="required-marker">*</span></label>
        <input id="start-date" class="form-control" type="date" @bind="school.HomeschoolStartDate" />
        @ValidationFor("school.HomeschoolStartDate")
        <label class="form-label" for="basis">Operating basis <span class="required-marker">*</span></label>
        <input id="basis" class="form-control" @bind="school.OperatingBasis" />
        @ValidationFor("school.OperatingBasis")
        <label class="form-label" for="signature">Diploma signature name <span class="required-marker">*</span></label>
        <input id="signature" class="form-control" @bind="school.DiplomaSignatureName" />
        @ValidationFor("school.DiplomaSignatureName")
        <label class="form-label" for="city">Diploma issue city <span class="required-marker">*</span></label>
        <input id="city" class="form-control" @bind="school.DiplomaIssueCity" />
        @ValidationFor("school.DiplomaIssueCity")
        <label class="form-label" for="state">Diploma issue state <span class="required-marker">*</span></label>
        <input id="state" class="form-control" @bind="school.DiplomaIssueState" />
        @ValidationFor("school.DiplomaIssueState")
        <button class="btn btn-primary mt-2" @onclick="SaveSchool">Save school profile</button>
    </section>

    <section class="form-section">
        <h2>Children</h2>
        @if (students.Count == 0)
        {
            <p>No children have been added yet.</p>
        }
        else
        {
            <ul class="itemized-editor-list stacked-editor-list">
                @foreach (var configuredStudent in students)
                {
                    <li>
                        <div class="itemized-editor-content">
                            <strong>@configuredStudent.DisplayName</strong>
                            <small>Grade @configuredStudent.GradeLevel</small>
                            <small>Student path: /student/@configuredStudent.Id</small>
                        </div>
                    </li>
                }
            </ul>
        }
        <h3 class="mt-3">Add child</h3>
        <label class="form-label" for="first-name">First name <span class="required-marker">*</span></label>
        <input id="first-name" class="form-control" @bind="student.FirstName" />
        @ValidationFor("student.FirstName")
        <label class="form-label" for="last-name">Last name <span class="required-marker">*</span></label>
        <input id="last-name" class="form-control" @bind="student.LastName" />
        @ValidationFor("student.LastName")
        <label class="form-label" for="grade-level">Grade level <span class="required-marker">*</span></label>
        <input id="grade-level" class="form-control" type="number" min="0" max="12" @bind="student.GradeLevel" />
        @ValidationFor("student.GradeLevel")
        <button class="btn btn-primary mt-2" @onclick="SaveStudent">Save student</button>
    </section>

    <section class="form-section">
        <h2>School year</h2>
        <label class="form-label" for="year-name">School year name <span class="required-marker">*</span></label>
        <input id="year-name" class="form-control" @bind="year.Name" />
        @ValidationFor("year.Name")
        <label class="form-label" for="start-year">Start year <span class="required-marker">*</span></label>
        <input id="start-year" class="form-control" type="number" @bind="year.StartYear" />
        @ValidationFor("year.StartYear")
        <label class="form-label" for="end-year">End year <span class="required-marker">*</span></label>
        <input id="end-year" class="form-control" type="number" @bind="year.EndYear" />
        @ValidationFor("year.EndYear")
        <label class="form-label" for="term1-start">Semester 1 start <span class="required-marker">*</span></label>
        <input id="term1-start" class="form-control" type="date" @bind="year.FirstTermStart" />
        @ValidationFor("year.FirstTermStart")
        <label class="form-label" for="term1-end">Semester 1 end <span class="required-marker">*</span></label>
        <input id="term1-end" class="form-control" type="date" @bind="year.FirstTermEnd" />
        @ValidationFor("year.FirstTermEnd")
        <label class="form-label" for="term2-start">Semester 2 start <span class="required-marker">*</span></label>
        <input id="term2-start" class="form-control" type="date" @bind="year.SecondTermStart" />
        @ValidationFor("year.SecondTermStart")
        <label class="form-label" for="term2-end">Semester 2 end <span class="required-marker">*</span></label>
        <input id="term2-end" class="form-control" type="date" @bind="year.SecondTermEnd" />
        @ValidationFor("year.SecondTermEnd")
        <button class="btn btn-primary mt-2" @onclick="SaveSchoolYear">Save school year</button>
    </section>

    <section class="form-section">
        <h2>Michigan requirement seed</h2>
        <p>Seed Michigan as the first jurisdiction profile. This supports selected subject-area coverage tracking and does not certify legal compliance.</p>
        <button class="btn btn-primary" @onclick="SeedMichigan">Seed Michigan requirements</button>
    </section>
}

@if (messages.Count > 0)
{
    <section class="message-list" aria-live="polite">
        @foreach (var message in messages)
        {
            <div class="@message.CssClass">@message.Text</div>
        }
    </section>
}

@code {
    private SetupSummary? summary;
    private readonly List<PageMessage> messages = [];
    private readonly Dictionary<string, string> fieldErrors = [];
    private IReadOnlyList<StudentSetupItem> students = [];
    private HouseholdModel household = new();
    private SchoolModel school = new();
    private StudentModel student = new();
    private SchoolYearModel year = new();

    protected override async Task OnInitializedAsync()
    {
        await RefreshSummary();
    }

    private async Task SaveHousehold()
    {
        if (!ValidateHousehold())
        {
            return;
        }

        await Run(() => SetupService.CreateHouseholdAsync(ParentUser(), new CreateHouseholdCommand(household.HouseholdName, household.ParentGuardianName)));
    }

    private async Task SaveSchool()
    {
        if (!ValidateSchool())
        {
            return;
        }

        await Run(() => SetupService.ConfigureSchoolProfileAsync(
            ParentUser(),
            new ConfigureSchoolProfileCommand(
                school.SchoolName,
                school.AdministratorParentName,
                school.Jurisdiction,
                school.HomeschoolStartDate,
                school.OperatingBasis,
                school.DiplomaSignatureName,
                school.DiplomaIssueCity,
                school.DiplomaIssueState)));
    }

    private async Task SaveStudent()
    {
        if (!ValidateStudent())
        {
            return;
        }

        if (await Run(() => SetupService.CreateStudentAsync(ParentUser(), new CreateStudentCommand(student.FirstName, student.LastName, student.GradeLevel))))
        {
            student = new StudentModel();
        }
    }

    private async Task SaveSchoolYear()
    {
        if (!ValidateSchoolYear())
        {
            return;
        }

        await Run(() => SetupService.ConfigureSchoolYearAsync(
            ParentUser(),
            new ConfigureSchoolYearCommand(
                year.Name,
                year.StartYear,
                year.EndYear,
                year.FirstTermStart,
                year.FirstTermEnd,
                year.SecondTermStart,
                year.SecondTermEnd)));
    }

    private async Task SeedMichigan()
    {
        await Run(() => RequirementService.SeedMichiganAsync(ParentUser()));
    }

    private async Task<bool> Run(Func<Task<OperationResult>> action)
    {
        messages.Clear();
        fieldErrors.Clear();
        var result = await action();
        if (result.Succeeded)
        {
            messages.Add(new PageMessage("Saved.", "alert alert-success"));
            await RefreshSummary();
            return true;
        }

        messages.AddRange(result.Errors.Select(error => new PageMessage(error, "alert alert-danger")));
        return false;
    }

    private async Task RefreshSummary()
    {
        summary = await SetupService.GetSummaryAsync();
        var detail = await SetupService.GetDetailAsync();
        students = detail.Students ?? [];
        household = new HouseholdModel
        {
            HouseholdName = detail.HouseholdName,
            ParentGuardianName = detail.ParentGuardianName
        };
        school = new SchoolModel
        {
            SchoolName = detail.SchoolName,
            AdministratorParentName = detail.AdministratorParentName,
            Jurisdiction = detail.Jurisdiction,
            HomeschoolStartDate = detail.HomeschoolStartDate,
            OperatingBasis = detail.OperatingBasis,
            DiplomaSignatureName = detail.DiplomaSignatureName,
            DiplomaIssueCity = detail.DiplomaIssueCity,
            DiplomaIssueState = detail.DiplomaIssueState
        };
        student = new StudentModel();
        year = new SchoolYearModel
        {
            Name = detail.SchoolYearName,
            StartYear = detail.StartYear,
            EndYear = detail.EndYear,
            FirstTermStart = detail.FirstTermStart,
            FirstTermEnd = detail.FirstTermEnd,
            SecondTermStart = detail.SecondTermStart,
            SecondTermEnd = detail.SecondTermEnd
        };
    }

    private UserContext ParentUser()
    {
        return Session.CurrentUser ?? UserContext.Student("Anonymous");
    }

    private static string Display(bool exists, string value)
    {
        return exists ? value : "Not set";
    }

    private MarkupString ValidationFor(string key)
    {
        return fieldErrors.TryGetValue(key, out var message)
            ? new MarkupString($"<div class=\"validation-message\">{System.Net.WebUtility.HtmlEncode(message)}</div>")
            : new MarkupString("");
    }

    private bool ValidateHousehold()
    {
        BeginValidation();
        RequireField("household.HouseholdName", household.HouseholdName, "Household name is required.");
        RequireField("household.ParentGuardianName", household.ParentGuardianName, "Parent/guardian name is required.");
        return EndValidation();
    }

    private bool ValidateSchool()
    {
        BeginValidation();
        RequireField("school.SchoolName", school.SchoolName, "School name is required.");
        RequireField("school.AdministratorParentName", school.AdministratorParentName, "Administrator parent name is required.");
        RequireField("school.Jurisdiction", school.Jurisdiction, "Jurisdiction is required.");
        RequireDate("school.HomeschoolStartDate", school.HomeschoolStartDate, "Homeschool start date is required.");
        RequireField("school.OperatingBasis", school.OperatingBasis, "Operating basis is required.");
        RequireField("school.DiplomaSignatureName", school.DiplomaSignatureName, "Diploma signature name is required.");
        RequireField("school.DiplomaIssueCity", school.DiplomaIssueCity, "Diploma issue city is required.");
        RequireField("school.DiplomaIssueState", school.DiplomaIssueState, "Diploma issue state is required.");
        return EndValidation();
    }

    private bool ValidateStudent()
    {
        BeginValidation();
        RequireField("student.FirstName", student.FirstName, "First name is required.");
        RequireField("student.LastName", student.LastName, "Last name is required.");
        if (student.GradeLevel is < 0 or > 12)
        {
            fieldErrors["student.GradeLevel"] = "Grade level must be between 0 and 12.";
        }

        return EndValidation();
    }

    private bool ValidateSchoolYear()
    {
        BeginValidation();
        RequireField("year.Name", year.Name, "School year name is required.");
        RequireYear("year.StartYear", year.StartYear, "Start year is required.");
        RequireYear("year.EndYear", year.EndYear, "End year is required.");
        RequireDate("year.FirstTermStart", year.FirstTermStart, "Semester 1 start is required.");
        RequireDate("year.FirstTermEnd", year.FirstTermEnd, "Semester 1 end is required.");
        RequireDate("year.SecondTermStart", year.SecondTermStart, "Semester 2 start is required.");
        RequireDate("year.SecondTermEnd", year.SecondTermEnd, "Semester 2 end is required.");
        if (year.EndYear < year.StartYear)
        {
            fieldErrors["year.EndYear"] = "End year cannot be before start year.";
        }

        if (year.FirstTermEnd < year.FirstTermStart)
        {
            fieldErrors["year.FirstTermEnd"] = "Semester 1 end cannot be before its start.";
        }

        if (year.SecondTermEnd < year.SecondTermStart)
        {
            fieldErrors["year.SecondTermEnd"] = "Semester 2 end cannot be before its start.";
        }

        return EndValidation();
    }

    private void BeginValidation()
    {
        messages.Clear();
        fieldErrors.Clear();
    }

    private bool EndValidation()
    {
        if (fieldErrors.Count == 0)
        {
            return true;
        }

        messages.Add(new PageMessage("Please complete the required fields.", "alert alert-danger"));
        return false;
    }

    private void RequireField(string key, string value, string message)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            fieldErrors[key] = message;
        }
    }

    private void RequireDate(string key, DateOnly value, string message)
    {
        if (value == default)
        {
            fieldErrors[key] = message;
        }
    }

    private void RequireYear(string key, int value, string message)
    {
        if (value < 1900)
        {
            fieldErrors[key] = message;
        }
    }

    private sealed record PageMessage(string Text, string CssClass);

    private sealed class HouseholdModel
    {
        public string HouseholdName { get; set; } = "Family Household";
        public string ParentGuardianName { get; set; } = "";
    }

    private sealed class SchoolModel
    {
        public string SchoolName { get; set; } = "Family Homeschool";
        public string AdministratorParentName { get; set; } = "";
        public string Jurisdiction { get; set; } = "Michigan";
        public DateOnly HomeschoolStartDate { get; set; } = new(2026, 8, 24);
        public string OperatingBasis { get; set; } = "Michigan Exemption 3(f)";
        public string DiplomaSignatureName { get; set; } = "";
        public string DiplomaIssueCity { get; set; } = "";
        public string DiplomaIssueState { get; set; } = "Michigan";
    }

    private sealed class StudentModel
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
        public int GradeLevel { get; set; } = 12;
    }

    private sealed class SchoolYearModel
    {
        public string Name { get; set; } = "2026-2027";
        public int StartYear { get; set; } = 2026;
        public int EndYear { get; set; } = 2027;
        public DateOnly FirstTermStart { get; set; } = new(2026, 8, 24);
        public DateOnly FirstTermEnd { get; set; } = new(2026, 12, 18);
        public DateOnly SecondTermStart { get; set; } = new(2027, 1, 11);
        public DateOnly SecondTermEnd { get; set; } = new(2027, 5, 28);
    }
}

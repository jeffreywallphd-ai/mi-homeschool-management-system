@page "/transcript"
@rendermode InteractiveServer
@using HomeschoolManager.Application.Common
@using HomeschoolManager.Application.Records
@using HomeschoolManager.Web.Services
@inject TranscriptService Transcripts
@inject SessionState Session
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Transcript</PageTitle>

@if (!canView)
{
    <h1>Transcript</h1>
    <div class="alert alert-warning">Sign in as parent/admin to review transcripts.</div>
}
else if (transcript is null)
{
    <div class="page-header-bar">
        <div>
            <span class="hm-icon-tile" aria-hidden="true">
                <img class="hm-icon-lg" src="icons/hm/svg/currentcolor/report-table.svg" alt="" />
            </span>
            <h1>Transcript</h1>
            <p>Prepare a family-issued transcript from recorded course and credit records.</p>
        </div>
        <a class="btn btn-outline-primary" href="/">Back to dashboard</a>
    </div>

    @foreach (var message in messages)
    {
        <div class="alert alert-warning">@message</div>
    }
}
else
{
    <div class="page-header-bar">
        <div>
            <span class="hm-icon-tile" aria-hidden="true">
                <img class="hm-icon-lg" src="icons/hm/svg/currentcolor/report-table.svg" alt="" />
            </span>
            <h1>Transcript</h1>
            <p>Review the academic record, course descriptions, and source notes before export.</p>
        </div>
        <div class="transcript-download-actions">
            <button class="btn btn-outline-primary" type="button" @onclick="DownloadTranscriptPdfAsync">Download PDF</button>
            <button class="btn btn-primary" type="button" @onclick="DownloadTranscriptAsync">Download packet</button>
        </div>
    </div>

    <div class="gradebook-selector-bar hm-card transcript-selector-bar">
        <div>
            <label class="form-label" for="transcript-student">Student</label>
            <select id="transcript-student" class="form-select" value="@selectedStudentId" @onchange="OnStudentChangedAsync">
                @foreach (var student in transcript.Students)
                {
                    <option value="@student.StudentId">@student.Name</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label" for="transcript-span">Transcript span</label>
            <select id="transcript-span" class="form-select" value="@selectedSpan" @onchange="OnSpanChangedAsync">
                <option value="@TranscriptSpan.HighSchool">High school</option>
                <option value="@TranscriptSpan.MiddleSchool">Middle school</option>
                <option value="@TranscriptSpan.AllCourses">All recorded courses</option>
            </select>
        </div>
    </div>

    @foreach (var message in messages)
    {
        <div class="alert @(lastActionSucceeded ? "alert-success" : "alert-warning")">@message</div>
    }

    <section class="dashboard-metrics transcript-metrics" aria-label="Transcript summary">
        <article class="hm-card dashboard-metric-card">
            <img class="hm-icon" src="icons/hm/svg/purple/report-table.svg" alt="" aria-hidden="true" />
            <span>Courses</span>
            <strong>@transcript.Summary.CourseCount</strong>
        </article>
        <article class="hm-card dashboard-metric-card">
            <img class="hm-icon" src="icons/hm/svg/purple/status-check-circle.svg" alt="" aria-hidden="true" />
            <span>Completed</span>
            <strong>@transcript.Summary.CompletedCourseCount</strong>
        </article>
        <article class="hm-card dashboard-metric-card">
            <img class="hm-icon" src="icons/hm/svg/purple/metric-credit-award.svg" alt="" aria-hidden="true" />
            <span>Earned credits</span>
            <strong>@Credit(transcript.Summary.EarnedCredits)</strong>
        </article>
        <article class="hm-card dashboard-metric-card">
            <img class="hm-icon" src="icons/hm/svg/purple/status-alert-triangle.svg" alt="" aria-hidden="true" />
            <span>Record notes</span>
            <strong>@transcript.Warnings.Count</strong>
        </article>
    </section>

    <div class="dashboard-grid transcript-workbench">
        <main class="dashboard-main">
            <section class="hm-card dashboard-card transcript-preview-card">
                <div class="transcript-document">
                    <header class="transcript-document-header">
                        <p>Family-issued homeschool academic record</p>
                        <h2>@transcript.SpanLabel</h2>
                    </header>

                    @if (!string.IsNullOrWhiteSpace(transcript.CoverageNote))
                    {
                        <section class="transcript-coverage-note">
                            <strong>Transcript coverage</strong>
                            <p>@transcript.CoverageNote</p>
                        </section>
                    }

                    <dl class="transcript-identity-grid">
                        <div>
                            <dt>Student</dt>
                            <dd>@transcript.StudentName</dd>
                        </div>
                        <div>
                            <dt>School</dt>
                            <dd>@transcript.SchoolName</dd>
                        </div>
                        <div>
                            <dt>Grade span</dt>
                            <dd>@transcript.TypicalGradeRange</dd>
                        </div>
                        <div>
                            <dt>Administrator</dt>
                            <dd>@Blank(transcript.AdministratorParentName)</dd>
                        </div>
                    </dl>

                    <dl class="transcript-summary-grid">
                        <div>
                            <dt>Courses</dt>
                            <dd>@transcript.Summary.CourseCount</dd>
                        </div>
                        <div>
                            <dt>Planned credits</dt>
                            <dd>@Credit(transcript.Summary.PlannedCredits)</dd>
                        </div>
                        <div>
                            <dt>Earned credits</dt>
                            <dd>@Credit(transcript.Summary.EarnedCredits)</dd>
                        </div>
                        <div>
                            <dt>GPA</dt>
                            <dd>@transcript.Summary.GpaDisplay</dd>
                        </div>
                    </dl>

                    @foreach (var year in transcript.Years)
                    {
                        <section class="transcript-year-block">
                            <div class="section-heading-row">
                                <h3>@year.SchoolYearName</h3>
                                <span class="student-grade-pill">@year.GradeLabel</span>
                            </div>
                            <div class="transcript-table-wrap">
                                <table class="transcript-table">
                                    <thead>
                                        <tr>
                                            <th>Course</th>
                                            <th>Subject</th>
                                            <th>Term</th>
                                            <th>Credit</th>
                                            <th>Earned</th>
                                            <th>Final grade</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var course in year.Courses)
                                        {
                                            <tr>
                                                <td>@course.CourseTitle</td>
                                                <td>@course.SubjectArea</td>
                                                <td>@course.TermLabel</td>
                                                <td class="transcript-number">@Credit(course.PlannedCreditValue)</td>
                                                <td class="transcript-number">@(course.EarnedCreditValue.HasValue ? Credit(course.EarnedCreditValue.Value) : "Not recorded")</td>
                                                <td>@course.FinalGrade</td>
                                                <td>@course.Status</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </section>
                    }

                    @if (transcript.Warnings.Count > 0)
                    {
                        <section class="transcript-record-notes">
                            <h3>Record Notes</h3>
                            <ul>
                                @foreach (var warning in transcript.Warnings)
                                {
                                    <li>@warning</li>
                                }
                            </ul>
                        </section>
                    }

                    <section class="transcript-signature-row">
                        <div>Parent/Admin Signature</div>
                        <div>Date</div>
                    </section>
                </div>

                <div class="transcript-description-appendix">
                    <div class="section-heading-row">
                        <div>
                            <h2>Course Descriptions</h2>
                            <p class="form-text">Included as supporting material for colleges, transfer review, work records, and the family archive.</p>
                        </div>
                        <span class="student-grade-pill">@transcript.CourseDescriptions.Count courses</span>
                    </div>

                    <div class="transcript-description-list">
                        @foreach (var course in transcript.CourseDescriptions)
                        {
                            <article class="portfolio-item-card transcript-description-card">
                                <h3>@course.CourseTitle</h3>
                                <small>@course.SubjectArea</small>
                                <p>@Blank(course.Description)</p>
                                <dl class="student-detail-facts">
                                    <div>
                                        <dt>Major topics</dt>
                                        <dd>@Blank(course.MajorTopics)</dd>
                                    </div>
                                    <div>
                                        <dt>Resources</dt>
                                        <dd>@Blank(course.TextsAndResources)</dd>
                                    </div>
                                    <div>
                                        <dt>Assessment</dt>
                                        <dd>@Blank(course.AssessmentMethods)</dd>
                                    </div>
                                </dl>
                                @if (course.Modules.Count > 0)
                                {
                                    <ul class="student-readable-list">
                                        @foreach (var module in course.Modules)
                                        {
                                            <li>
                                                <strong>@module.SequenceOrder. @module.Title</strong>
                                                <small>@module.Assignments.Count assignment@(module.Assignments.Count == 1 ? "" : "s")</small>
                                            </li>
                                        }
                                    </ul>
                                }
                            </article>
                        }
                    </div>
                </div>
            </section>
        </main>

        <aside class="dashboard-support">
            <section class="hm-card dashboard-card transcript-editor-card">
                <div class="section-heading-row">
                    <div>
                        <h2>Course Records</h2>
                        <p class="form-text">Parent-recorded values appear on the transcript; blank values stay visibly unrecorded.</p>
                    </div>
                </div>

                <div class="transcript-course-editor-list">
                    @foreach (var course in transcript.Years.SelectMany(year => year.Courses))
                    {
                        var edit = EditFor(course);
                        <details class="transcript-course-editor" open="@(!course.EarnedCreditValue.HasValue && course.FinalGrade == "Not recorded")">
                            <summary>
                                <span>@course.CourseTitle</span>
                                <span class="student-grade-pill">@course.Status</span>
                            </summary>
                            <div class="inline-entry-form">
                                <div class="two-column-form-grid">
                                    <div>
                                        <label class="form-label" for="@($"grade-{course.CourseId}")">Final grade</label>
                                        <input id="@($"grade-{course.CourseId}")" class="form-control" @bind="edit.FinalGrade" />
                                    </div>
                                    <div>
                                        <label class="form-label" for="@($"credit-{course.CourseId}")">Earned credit</label>
                                        <input id="@($"credit-{course.CourseId}")" class="form-control" @bind="edit.EarnedCreditValue" />
                                    </div>
                                    <div>
                                        <label class="form-label" for="@($"complete-{course.CourseId}")">Completion date</label>
                                        <input id="@($"complete-{course.CourseId}")" class="form-control" placeholder="YYYY-MM-DD" @bind="edit.CompletionDate" />
                                    </div>
                                </div>
                                <label class="form-label" for="@($"basis-{course.CourseId}")">Credit basis</label>
                                <textarea id="@($"basis-{course.CourseId}")" class="form-control" rows="3" @bind="edit.CreditBasis"></textarea>
                                <label class="form-label" for="@($"notes-{course.CourseId}")">Parent notes</label>
                                <textarea id="@($"notes-{course.CourseId}")" class="form-control" rows="3" @bind="edit.ParentNotes"></textarea>
                                <div class="checkbox-row">
                                    <input id="@($"include-{course.CourseId}")" class="form-check-input" type="checkbox" @bind="edit.IncludeInTranscript" />
                                    <label class="form-check-label" for="@($"include-{course.CourseId}")">Include this course on the transcript</label>
                                </div>
                                <button class="btn btn-outline-primary" type="button" @onclick="() => SaveCourseRecordAsync(course.CourseId)">Save course record</button>
                            </div>
                        </details>
                    }
                </div>
            </section>
        </aside>
    </div>
}

@code {
    private bool canView;
    private TranscriptPreview? transcript;
    private string selectedStudentId = "";
    private TranscriptSpan selectedSpan = TranscriptSpan.HighSchool;
    private readonly List<string> messages = [];
    private readonly Dictionary<Guid, TranscriptCourseEditModel> edits = [];
    private bool lastActionSucceeded;

    protected override async Task OnInitializedAsync()
    {
        canView = Session.IsParentAdmin;
        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", replace: true);
            return;
        }

        if (canView)
        {
            await LoadAsync();
        }
    }

    private async Task LoadAsync(Guid? studentId = null)
    {
        if (Session.CurrentUser is null)
        {
            return;
        }

        var result = await Transcripts.GetTranscriptAsync(Session.CurrentUser, studentId, selectedSpan);
        messages.Clear();
        if (result.Succeeded && result.Value is not null)
        {
            transcript = result.Value;
            selectedStudentId = transcript.StudentId.ToString();
            SyncEdits();
        }
        else
        {
            transcript = null;
            messages.AddRange(result.Errors);
        }
    }

    private async Task OnStudentChangedAsync(ChangeEventArgs args)
    {
        selectedStudentId = args.Value?.ToString() ?? "";
        await LoadAsync(Guid.TryParse(selectedStudentId, out var studentId) ? studentId : null);
    }

    private async Task OnSpanChangedAsync(ChangeEventArgs args)
    {
        if (Enum.TryParse<TranscriptSpan>(args.Value?.ToString(), out var span))
        {
            selectedSpan = span;
        }

        await LoadAsync(Guid.TryParse(selectedStudentId, out var studentId) ? studentId : null);
    }

    private async Task SaveCourseRecordAsync(Guid courseId)
    {
        if (transcript is null || Session.CurrentUser is null || !edits.TryGetValue(courseId, out var edit))
        {
            return;
        }

        messages.Clear();
        lastActionSucceeded = false;
        var validCredit = TryParseCredit(edit.EarnedCreditValue, out var credit, out var creditError);
        var validDate = TryParseDate(edit.CompletionDate, out var completionDate, out var dateError);
        if (!validCredit || !validDate)
        {
            messages.Add(creditError ?? dateError ?? "Review the course record values and try again.");
            return;
        }

        var result = await Transcripts.SaveCourseRecordAsync(Session.CurrentUser, new SaveTranscriptCourseRecordCommand(
            transcript.StudentId,
            courseId,
            edit.FinalGrade,
            credit,
            completionDate,
            edit.CreditBasis,
            edit.ParentNotes,
            edit.IncludeInTranscript));
        if (result.Succeeded)
        {
            lastActionSucceeded = true;
            messages.Add("Course transcript record saved.");
            await LoadAsync(transcript.StudentId);
        }
        else
        {
            messages.AddRange(result.Errors);
        }
    }

    private async Task DownloadTranscriptAsync()
    {
        if (transcript is null || Session.CurrentUser is null)
        {
            return;
        }

        messages.Clear();
        lastActionSucceeded = false;
        var result = await Transcripts.CreateTranscriptPacketAsync(
            Session.CurrentUser,
            new CreateTranscriptExportCommand(transcript.StudentId, selectedSpan));
        if (!result.Succeeded || result.Value is null)
        {
            messages.AddRange(result.Errors);
            return;
        }

        await JS.InvokeVoidAsync(
            "homeschoolFiles.downloadBase64",
            result.Value.FileName,
            result.Value.ContentType,
            Convert.ToBase64String(result.Value.Content));
        lastActionSucceeded = true;
        messages.Add($"Downloaded {result.Value.FileName}.");
    }

    private async Task DownloadTranscriptPdfAsync()
    {
        if (transcript is null || Session.CurrentUser is null)
        {
            return;
        }

        messages.Clear();
        lastActionSucceeded = false;
        var result = await Transcripts.CreateTranscriptPdfPacketAsync(
            Session.CurrentUser,
            new CreateTranscriptExportCommand(transcript.StudentId, selectedSpan));
        if (!result.Succeeded || result.Value is null)
        {
            messages.AddRange(result.Errors);
            return;
        }

        await JS.InvokeVoidAsync(
            "homeschoolFiles.downloadBase64",
            result.Value.FileName,
            result.Value.ContentType,
            Convert.ToBase64String(result.Value.Content));
        lastActionSucceeded = true;
        messages.Add($"Downloaded {result.Value.FileName}.");
    }

    private void SyncEdits()
    {
        if (transcript is null)
        {
            edits.Clear();
            return;
        }

        foreach (var course in transcript.Years.SelectMany(year => year.Courses))
        {
            edits[course.CourseId] = TranscriptCourseEditModel.From(course);
        }
    }

    private TranscriptCourseEditModel EditFor(TranscriptCourseRow course)
    {
        if (!edits.TryGetValue(course.CourseId, out var edit))
        {
            edit = TranscriptCourseEditModel.From(course);
            edits[course.CourseId] = edit;
        }

        return edit;
    }

    private static bool TryParseCredit(string value, out decimal? credit, out string? error)
    {
        credit = null;
        error = null;
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        if (decimal.TryParse(value, out var parsed) && parsed >= 0 && parsed <= 3)
        {
            credit = parsed;
            return true;
        }

        error = "Earned credit must be blank or a number between 0 and 3.";
        return false;
    }

    private static bool TryParseDate(string value, out DateOnly? date, out string? error)
    {
        date = null;
        error = null;
        if (string.IsNullOrWhiteSpace(value))
        {
            return true;
        }

        if (DateOnly.TryParse(value, out var parsed))
        {
            date = parsed;
            return true;
        }

        error = "Completion date is not a valid date.";
        return false;
    }

    private static string Credit(decimal value)
    {
        return value.ToString("0.0##");
    }

    private static string Blank(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not recorded" : value;
    }

    private sealed class TranscriptCourseEditModel
    {
        public string FinalGrade { get; set; } = "";
        public string EarnedCreditValue { get; set; } = "";
        public string CompletionDate { get; set; } = "";
        public string CreditBasis { get; set; } = "";
        public string ParentNotes { get; set; } = "";
        public bool IncludeInTranscript { get; set; } = true;

        public static TranscriptCourseEditModel From(TranscriptCourseRow row)
        {
            return new TranscriptCourseEditModel
            {
                FinalGrade = row.FinalGrade == "Not recorded" ? "" : row.FinalGrade,
                EarnedCreditValue = row.EarnedCreditValue?.ToString("0.###") ?? "",
                CompletionDate = row.CompletionDate?.ToString("yyyy-MM-dd") ?? "",
                CreditBasis = row.CreditBasis,
                ParentNotes = row.ParentNotes,
                IncludeInTranscript = row.IncludeInTranscript
            };
        }
    }
}

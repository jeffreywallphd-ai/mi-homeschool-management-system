    private async Task Run(Func<Task<OperationResult>> action)
    {
        messages.Clear();
        fieldErrors.Clear();
        var result = await action();
        if (result.Succeeded)
        {
            messages.Add(new PageMessage("Saved.", "alert alert-success"));
            await Refresh();
            return;
        }

        messages.AddRange(result.Errors.Select(error => new PageMessage(error, "alert alert-danger")));
    }

    private void BackToModule()
    {
        NavigationManager.NavigateTo($"/courses/{CourseId}/modules/{ModuleId}");
    }

    private bool ValidateAssignment()
    {
        messages.Clear();
        fieldErrors.Clear();

        if (string.IsNullOrWhiteSpace(assignmentForm.Title))
        {
            fieldErrors["assignment.Title"] = "Title is required.";
        }

        if (string.IsNullOrWhiteSpace(assignmentForm.Instructions))
        {
            fieldErrors["assignment.Instructions"] = "Instructions are required.";
        }

        if (string.IsNullOrWhiteSpace(assignmentForm.RequiredOutput))
        {
            fieldErrors["assignment.RequiredOutput"] = "Required output is required.";
        }

        if (fieldErrors.Count == 0)
        {
            return true;
        }

        messages.Add(new PageMessage("Please complete the required assignment fields.", "alert alert-danger"));
        return false;
    }

    private MarkupString ValidationFor(string key)
    {
        return fieldErrors.TryGetValue(key, out var message)
            ? new MarkupString($"<div class=\"validation-message\">{System.Net.WebUtility.HtmlEncode(message)}</div>")
            : new MarkupString("");
    }

    private UserContext ParentUser()
    {
        return Session.CurrentUser ?? UserContext.Student("Anonymous");
    }

    private AssignmentPortfolioConnectionCommand? BuildPortfolioCommand()
    {
        if (!assignmentForm.IsPortfolioCandidate &&
            string.IsNullOrWhiteSpace(assignmentForm.PortfolioSection) &&
            string.IsNullOrWhiteSpace(assignmentForm.ArtifactTitle) &&
            string.IsNullOrWhiteSpace(assignmentForm.ArtifactPurpose) &&
            string.IsNullOrWhiteSpace(assignmentForm.ReuseInstructions) &&
            assignmentForm.CrossCourseLinks.Count == 0)
        {
            return null;
        }

        return new AssignmentPortfolioConnectionCommand(
            assignmentForm.IsPortfolioCandidate,
            assignmentForm.PortfolioSection,
            assignmentForm.ArtifactTitle,
            assignmentForm.ArtifactPurpose,
            assignmentForm.ReuseInstructions,
            assignmentForm.CrossCourseLinks);
    }

    private LessonRubricCommand? BuildRubricCommand()
    {
        if (string.IsNullOrWhiteSpace(assignmentForm.RubricId) &&
            string.IsNullOrWhiteSpace(assignmentForm.RubricScale) &&
            assignmentForm.RubricCriteria.Count == 0)
        {
            return null;
        }

        return new LessonRubricCommand(
            assignmentForm.RubricId,
            assignmentForm.RubricScale,
            assignmentForm.RubricCriteria
                .Select(criteria => new LessonRubricCriterionCommand(criteria.Criterion, criteria.Level4, criteria.Level3, criteria.Level2, criteria.Level1))
                .ToArray());
    }

    private IReadOnlyList<AssignmentResourceCommand> BuildResourceCommands()
    {
        return assignmentForm.Resources
            .Select(resource => new AssignmentResourceCommand(
                resource.Name,
                resource.Type,
                resource.Url,
                resource.FilePath,
                resource.IsPhysicalResource,
                resource.Required,
                resource.StudentInstructions,
                resource.SourceNote,
                null))
            .Where(item => !string.IsNullOrWhiteSpace(item.Name))
            .ToArray();
    }

    private IReadOnlyList<AssignmentStepCommand> BuildStepCommands()
    {
        return assignmentForm.AssignmentSteps
            .Select((step, index) => new AssignmentStepCommand(index + 1, step.Title, step.Instructions, step.EstimatedMinutes))
            .Where(item => !string.IsNullOrWhiteSpace(item.Title))
            .ToArray();
    }

    private AssignmentRevisionPolicyCommand? BuildRevisionCommand()
    {
        if (!assignmentForm.AllowRevision &&
            string.IsNullOrWhiteSpace(assignmentForm.RevisionExpectation) &&
            assignmentForm.MinimumRevisionCount <= 0)
        {
            return null;
        }

        return new AssignmentRevisionPolicyCommand(
            assignmentForm.AllowRevision,
            assignmentForm.RevisionExpectation,
            assignmentForm.MinimumRevisionCount);
    }

    private AssignmentCompletionCriteriaCommand? BuildCompletionCommand()
    {
        var requirements = assignmentForm.CompletionRequirements;
        if (requirements.Count == 0 && !assignmentForm.RequiresParentReview && assignmentForm.MasteryThreshold is null)
        {
            return null;
        }

        return new AssignmentCompletionCriteriaCommand(requirements, assignmentForm.RequiresParentReview, assignmentForm.MasteryThreshold);
    }

    private AssignmentEvidenceRequirementsCommand? BuildEvidenceCommand()
    {
        var fileTypes = assignmentForm.RecommendedFileTypes;
        if (!assignmentForm.RetainForRecords &&
            fileTypes.Count == 0 &&
            !assignmentForm.RequiresStudentExplanation &&
            !assignmentForm.RequiresParentEvaluation)
        {
            return null;
        }

        return new AssignmentEvidenceRequirementsCommand(
            assignmentForm.RetainForRecords,
            assignmentForm.EvidenceType,
            fileTypes,
            assignmentForm.RequiresStudentExplanation,
            assignmentForm.RequiresParentEvaluation);
    }

    private AssignmentScoringCommand BuildScoringCommand()
    {
        return new AssignmentScoringCommand(
            assignmentForm.PlannedPoints,
            assignmentForm.PlannedWeight,
            assignmentForm.GradingMode,
            assignmentForm.CountsTowardGrade,
            assignmentForm.AllowPartialCredit);
    }

    private static string AssignmentTypeLabel(AssignmentType type)
    {
        return type switch
        {
            AssignmentType.ReadingResponse => "Reading response",
            AssignmentType.ProblemSet => "Problem set",
            AssignmentType.LabOrSimulation => "Lab or simulation",
            AssignmentType.QuizOrTestPrep => "Quiz or test prep",
            AssignmentType.PortfolioArtifact => "Portfolio artifact",
            AssignmentType.PracticalDemonstration => "Practical demonstration",
            _ => type.ToString()
        };
    }

    private static string MethodProfileLabel(InstructionalMethodProfile profile)
    {
        return profile switch
        {
            InstructionalMethodProfile.Hybrid => "Hybrid",
            InstructionalMethodProfile.ExplicitGuidedPractice => "Explicit / guided practice",
            InstructionalMethodProfile.ProjectBasedApplied => "Project-based / applied",
            InstructionalMethodProfile.InquiryDiscussion => "Inquiry / discussion",
            InstructionalMethodProfile.IndependentStudy => "Independent study",
            InstructionalMethodProfile.MasteryPractice => "Mastery practice",
            InstructionalMethodProfile.Digital => "Digital",
            _ => profile.ToString()
        };
    }

    private static string StatusLabel(AssignmentStatus status)
    {
        return status switch
        {
            AssignmentStatus.Planned => "Planned",
            AssignmentStatus.Assigned => "Assigned",
            AssignmentStatus.Submitted => "Submitted",
            AssignmentStatus.Reviewed => "Reviewed",
            AssignmentStatus.Complete => "Complete",
            AssignmentStatus.Skipped => "Skipped",
            _ => status.ToString()
        };
    }

    private static string EnumLabel(string value)
    {
        return Regex.Replace(value, "([a-z])([A-Z])", "$1 $2");
    }


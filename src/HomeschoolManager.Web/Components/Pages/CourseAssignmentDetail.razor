    private string AssignmentStepToggleText() => assignmentForm.ShowAssignmentStepForm ? "Hide" : "Add";

    private void ToggleAssignmentStepForm()
    {
        assignmentForm.ShowAssignmentStepForm = !assignmentForm.ShowAssignmentStepForm;
    }

    private async Task AddAssignmentStep()
    {
        var title = assignmentForm.NewStepTitle.Trim();
        if (string.IsNullOrWhiteSpace(title))
        {
            return;
        }

        assignmentForm.AssignmentSteps.Add(new AssignmentStep(
            assignmentForm.AssignmentSteps.Count + 1,
            title,
            assignmentForm.NewStepInstructions,
            assignmentForm.NewStepEstimatedMinutes));
        assignmentForm.NewStepTitle = "";
        assignmentForm.NewStepInstructions = "";
        assignmentForm.NewStepEstimatedMinutes = 0;
        await AutoSaveAssignment();
    }

    private async Task DeleteAssignmentStep(int index)
    {
        if (index >= 0 && index < assignmentForm.AssignmentSteps.Count)
        {
            assignmentForm.AssignmentSteps.RemoveAt(index);
            await AutoSaveAssignment();
        }
    }

    private async Task MoveAssignmentStep(int index, int direction)
    {
        var target = index + direction;
        if (index < 0 || target < 0 || index >= assignmentForm.AssignmentSteps.Count || target >= assignmentForm.AssignmentSteps.Count)
        {
            return;
        }

        (assignmentForm.AssignmentSteps[index], assignmentForm.AssignmentSteps[target]) = (assignmentForm.AssignmentSteps[target], assignmentForm.AssignmentSteps[index]);
        await AutoSaveAssignment();
    }


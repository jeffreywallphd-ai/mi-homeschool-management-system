@page "/courses/{CourseId:guid}/modules/{ModuleId:guid}/assignments/{AssignmentId:guid}"
@rendermode InteractiveServer
@using HomeschoolManager.Application.Common
@using HomeschoolManager.Application.Courses
@using HomeschoolManager.Domain.Access
@using HomeschoolManager.Domain.Curriculum
@using HomeschoolManager.Web.Services
@using System.Text.RegularExpressions
@inject CourseService CourseService
@inject SessionState Session
@inject NavigationManager NavigationManager

<PageTitle>Assignment Detail</PageTitle>

@if (module is null || assignment is null)
{
    <h1>Assignment not found</h1>
    <p>The requested assignment could not be loaded.</p>
}
else
{
    <div class="page-header-bar">
        <div>
            <h1>@assignment.Title</h1>
            <p>@module.Title</p>
        </div>
        @if (messages.Count > 0)
        {
            <section class="page-header-message" aria-live="polite">
                @foreach (var message in messages)
                {
                    <div class="@message.CssClass">@message.Text</div>
                }
            </section>
        }
    </div>

    @if (!CanEdit)
    {
        <div class="alert alert-warning">Sign in as parent/admin to edit assignments.</div>
    }

    <div class="content-workbench course-detail-workbench">
        <main class="workbench-main">
            <section class="form-section">
                <h2>Assignment Identity</h2>
                @if (module.AssignmentVariants.Count > 0 && CanEdit)
                {
                    <label class="form-label" for="assignment-variant">Built-in variant</label>
                    <select id="assignment-variant" class="form-select" value="@selectedVariantId" @onchange="ApplyVariant">
                        <option value="">Custom assignment</option>
                        @foreach (var variant in module.AssignmentVariants)
                        {
                            <option value="@variant.VariantId">@MethodProfileLabel(variant.MethodProfile): @variant.Title</option>
                        }
                    </select>
                }

                <label class="form-label" for="assignment-title">Title <span class="required-marker">*</span></label>
                <input id="assignment-title" class="form-control" disabled="@(!CanEdit)" @bind="assignmentForm.Title" @bind:after="AutoSaveAssignment" />
                @ValidationFor("assignment.Title")

                <label class="form-label" for="assignment-type">Type</label>
                <select id="assignment-type" class="form-select" disabled="@(!CanEdit)" @bind="assignmentForm.Type" @bind:after="AutoSaveAssignment">
                    @foreach (var type in Enum.GetValues<AssignmentType>())
                    {
                        <option value="@type">@AssignmentTypeLabel(type)</option>
                    }
                </select>

                <label class="form-label" for="assignment-method">Instructional method profile</label>
                <select id="assignment-method" class="form-select" disabled="@(!CanEdit)" @bind="assignmentForm.MethodProfile" @bind:after="AutoSaveAssignment">
                    @foreach (var profile in Enum.GetValues<InstructionalMethodProfile>())
                    {
                        <option value="@profile">@MethodProfileLabel(profile)</option>
                    }
                </select>

                <label class="form-label" for="assignment-status">Status</label>
                <select id="assignment-status" class="form-select" disabled="@(!CanEdit)" @bind="assignmentForm.Status" @bind:after="AutoSaveAssignment">
                    @foreach (var status in Enum.GetValues<AssignmentStatus>())
                    {
                        <option value="@status">@StatusLabel(status)</option>
                    }
                </select>

                <label class="form-label" for="assignment-summary">Summary</label>
                <textarea id="assignment-summary" class="form-control" rows="3" disabled="@(!CanEdit)" @bind="assignmentForm.AssignmentSummary" @bind:after="AutoSaveAssignment"></textarea>

                <label class="form-label" for="assignment-goal">Student-facing goal</label>
                <textarea id="assignment-goal" class="form-control" rows="3" disabled="@(!CanEdit)" @bind="assignmentForm.StudentFacingGoal" @bind:after="AutoSaveAssignment"></textarea>
            </section>

            <section class="form-section">
                <h2>Student Instructions</h2>
                <label class="form-label" for="assignment-instructions">Instructions <span class="required-marker">*</span></label>
                <textarea id="assignment-instructions" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="assignmentForm.Instructions" @bind:after="AutoSaveAssignment"></textarea>
                @ValidationFor("assignment.Instructions")

                <label class="form-label" for="assignment-output">Required output or evidence <span class="required-marker">*</span></label>
                <textarea id="assignment-output" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="assignmentForm.RequiredOutput" @bind:after="AutoSaveAssignment"></textarea>
                @ValidationFor("assignment.RequiredOutput")

                <label class="form-label" for="assignment-deliverables">Required deliverables</label>
                <textarea id="assignment-deliverables" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="assignmentForm.RequiredDeliverablesText" @bind:after="AutoSaveAssignment"></textarea>

                <label class="form-label" for="assignment-checklist">Student checklist</label>
                <textarea id="assignment-checklist" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="assignmentForm.StudentChecklistText" @bind:after="AutoSaveAssignment"></textarea>

                <label class="form-label" for="assignment-reflection">Reflection prompts</label>
                <textarea id="assignment-reflection" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="assignmentForm.ReflectionPromptsText" @bind:after="AutoSaveAssignment"></textarea>
            </section>

            <section class="form-section">
                <h2>Workflow and Resources</h2>
                <label class="form-label" for="assignment-steps">Assignment steps</label>
                <textarea id="assignment-steps" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="assignmentForm.AssignmentStepsText" @bind:after="AutoSaveAssignment"></textarea>

                <label class="form-label" for="assignment-resources">Assignment resources</label>
                <textarea id="assignment-resources" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="assignmentForm.ResourcesText" @bind:after="AutoSaveAssignment"></textarea>

                <label class="form-label" for="assignment-skills">Assessment skills</label>
                <textarea id="assignment-skills" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="assignmentForm.AssessmentSkillsText" @bind:after="AutoSaveAssignment"></textarea>
            </section>

            <section class="form-section">
                <h2>Timing and Planning</h2>
                <label class="form-label" for="assignment-effort">Estimated effort</label>
                <input id="assignment-effort" class="form-control" disabled="@(!CanEdit)" @bind="assignmentForm.EstimatedEffort" @bind:after="AutoSaveAssignment" />

                <div class="two-column-field-row">
                    <div>
                        <label class="form-label" for="assignment-effort-min">Minimum minutes</label>
                        <input id="assignment-effort-min" class="form-control" type="number" min="0" step="1" disabled="@(!CanEdit)" @bind="assignmentForm.EstimatedMinutesMin" @bind:after="AutoSaveAssignment" />
                    </div>
                    <div>
                        <label class="form-label" for="assignment-effort-max">Maximum minutes</label>
                        <input id="assignment-effort-max" class="form-control" type="number" min="0" step="1" disabled="@(!CanEdit)" @bind="assignmentForm.EstimatedMinutesMax" @bind:after="AutoSaveAssignment" />
                    </div>
                </div>

                <label class="form-label" for="assignment-due-label">Due timing label</label>
                <input id="assignment-due-label" class="form-control" disabled="@(!CanEdit)" @bind="assignmentForm.DueTimingLabel" @bind:after="AutoSaveAssignment" />

                <label class="form-label" for="assignment-due-date">Due date</label>
                <input id="assignment-due-date" class="form-control" type="date" disabled="@(!CanEdit)" @bind="assignmentForm.DueDate" @bind:after="AutoSaveAssignment" />

                <label class="form-label" for="assignment-points">Planned points</label>
                <input id="assignment-points" class="form-control" type="number" min="0" step="0.1" disabled="@(!CanEdit)" @bind="assignmentForm.PlannedPoints" @bind:after="AutoSaveAssignment" />

                <label class="form-label" for="assignment-weight">Planned weight</label>
                <input id="assignment-weight" class="form-control" type="number" min="0" step="0.1" disabled="@(!CanEdit)" @bind="assignmentForm.PlannedWeight" @bind:after="AutoSaveAssignment" />

                <label class="form-label" for="assignment-grading-mode">Grading mode</label>
                <select id="assignment-grading-mode" class="form-select" disabled="@(!CanEdit)" @bind="assignmentForm.GradingMode" @bind:after="AutoSaveAssignment">
                    @foreach (var mode in Enum.GetValues<AssignmentGradingMode>())
                    {
                        <option value="@mode">@EnumLabel(mode.ToString())</option>
                    }
                </select>

                <div class="form-check mt-2">
                    <input id="assignment-counts-grade" class="form-check-input" type="checkbox" disabled="@(!CanEdit)" @bind="assignmentForm.CountsTowardGrade" @bind:after="AutoSaveAssignment" />
                    <label class="form-check-label" for="assignment-counts-grade">Counts toward grade</label>
                </div>

                <div class="form-check mt-2">
                    <input id="assignment-partial-credit" class="form-check-input" type="checkbox" disabled="@(!CanEdit)" @bind="assignmentForm.AllowPartialCredit" @bind:after="AutoSaveAssignment" />
                    <label class="form-check-label" for="assignment-partial-credit">Allow partial credit</label>
                </div>

                <div class="form-check mt-2">
                    <input id="assignment-portfolio" class="form-check-input" type="checkbox" disabled="@(!CanEdit)" @bind="assignmentForm.IsPortfolioCandidate" @bind:after="AutoSaveAssignment" />
                    <label class="form-check-label" for="assignment-portfolio">Portfolio-worthy evidence candidate</label>
                </div>
            </section>

            <section class="form-section">
                <h2>Portfolio and Completion</h2>
                <label class="form-label" for="portfolio-section">Portfolio section</label>
                <input id="portfolio-section" class="form-control" disabled="@(!CanEdit)" @bind="assignmentForm.PortfolioSection" @bind:after="AutoSaveAssignment" />

                <label class="form-label" for="portfolio-title">Artifact title</label>
                <input id="portfolio-title" class="form-control" disabled="@(!CanEdit)" @bind="assignmentForm.ArtifactTitle" @bind:after="AutoSaveAssignment" />

                <label class="form-label" for="portfolio-purpose">Artifact purpose</label>
                <textarea id="portfolio-purpose" class="form-control" rows="3" disabled="@(!CanEdit)" @bind="assignmentForm.ArtifactPurpose" @bind:after="AutoSaveAssignment"></textarea>

                <label class="form-label" for="portfolio-reuse">Reuse instructions</label>
                <textarea id="portfolio-reuse" class="form-control" rows="3" disabled="@(!CanEdit)" @bind="assignmentForm.ReuseInstructions" @bind:after="AutoSaveAssignment"></textarea>

                <label class="form-label" for="portfolio-links">Cross-course links</label>
                <textarea id="portfolio-links" class="form-control" rows="3" disabled="@(!CanEdit)" @bind="assignmentForm.CrossCourseLinksText" @bind:after="AutoSaveAssignment"></textarea>

                <label class="form-label" for="completion-requirements">Completion requirements</label>
                <textarea id="completion-requirements" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="assignmentForm.CompletionRequirementsText" @bind:after="AutoSaveAssignment"></textarea>

                <div class="form-check mt-2">
                    <input id="completion-parent-review" class="form-check-input" type="checkbox" disabled="@(!CanEdit)" @bind="assignmentForm.RequiresParentReview" @bind:after="AutoSaveAssignment" />
                    <label class="form-check-label" for="completion-parent-review">Requires parent review</label>
                </div>

                <label class="form-label" for="completion-mastery">Mastery threshold</label>
                <input id="completion-mastery" class="form-control" type="number" min="0" step="0.1" disabled="@(!CanEdit)" @bind="assignmentForm.MasteryThreshold" @bind:after="AutoSaveAssignment" />
            </section>
        </main>

        <aside class="workbench-support">
            <section class="form-section">
                <div class="section-heading-row">
                    <h2>Objectives</h2>
                </div>
                @if (module.LearningObjectiveItems.Count == 0)
                {
                    <p>No module objectives are available.</p>
                }
                else
                {
                    <ul class="itemized-editor-list stacked-editor-list">
                        @foreach (var objective in module.LearningObjectiveItems)
                        {
                            var objectiveText = objective.Text;
                            <li>
                                <label class="form-check-label">
                                    <input class="form-check-input" type="checkbox" disabled="@(!CanEdit)" checked="@assignmentForm.LinkedModuleObjectives.Contains(objectiveText)" @onchange="async _ => await ToggleObjective(objectiveText)" />
                                    @objectiveText
                                </label>
                            </li>
                        }
                    </ul>
                }
            </section>

            <section class="form-section">
                <div class="section-heading-row">
                    <h2>Related Lessons</h2>
                    <button class="btn btn-outline-primary btn-sm" @onclick="BackToModule">Back to module</button>
                </div>
                @if (module.Lessons.Count == 0)
                {
                    <p>No lessons are available.</p>
                }
                else
                {
                    <ul class="itemized-editor-list stacked-editor-list">
                        @foreach (var lesson in module.Lessons.OrderBy(item => item.SequenceOrder))
                        {
                            var lessonId = lesson.Id;
                            <li>
                                <label class="form-check-label">
                                    <input class="form-check-input" type="checkbox" disabled="@(!CanEdit)" checked="@assignmentForm.LinkedLessonIds.Contains(lessonId)" @onchange="async _ => await ToggleLesson(lessonId)" />
                                    @lesson.SequenceOrder. @lesson.Title
                                </label>
                            </li>
                        }
                    </ul>
                }
            </section>

            <section class="form-section">
                <h2>Parent Notes</h2>
                <label class="visually-hidden" for="assignment-parent-notes">Parent notes</label>
                <textarea id="assignment-parent-notes" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="assignmentForm.ParentNotes" @bind:after="AutoSaveAssignment"></textarea>
            </section>

            <section class="form-section">
                <h2>Submission Formats</h2>
                <ul class="itemized-editor-list stacked-editor-list">
                    @foreach (var format in Enum.GetValues<AssignmentSubmissionFormat>())
                    {
                        <li>
                            <label class="form-check-label">
                                <input class="form-check-input" type="checkbox" disabled="@(!CanEdit)" checked="@assignmentForm.SubmissionFormats.Contains(format)" @onchange="async _ => await ToggleSubmissionFormat(format)" />
                                @EnumLabel(format.ToString())
                            </label>
                        </li>
                    }
                </ul>
            </section>

            <section class="form-section">
                <h2>Rubric</h2>
                <label class="form-label" for="assignment-rubric-id">Rubric id</label>
                <input id="assignment-rubric-id" class="form-control" disabled="@(!CanEdit)" @bind="assignmentForm.RubricId" @bind:after="AutoSaveAssignment" />

                <label class="form-label" for="assignment-linked-rubric-id">Linked rubric id</label>
                <input id="assignment-linked-rubric-id" class="form-control" disabled="@(!CanEdit)" @bind="assignmentForm.LinkedRubricId" @bind:after="AutoSaveAssignment" />

                <label class="form-label" for="assignment-rubric-scale">Scale</label>
                <input id="assignment-rubric-scale" class="form-control" disabled="@(!CanEdit)" @bind="assignmentForm.RubricScale" @bind:after="AutoSaveAssignment" />

                <label class="form-label" for="assignment-rubric-criteria">Criteria</label>
                <textarea id="assignment-rubric-criteria" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="assignmentForm.RubricCriteriaText" @bind:after="AutoSaveAssignment"></textarea>
            </section>

            <section class="form-section">
                <h2>Revision and Evidence</h2>
                <div class="form-check mt-2">
                    <input id="assignment-revision" class="form-check-input" type="checkbox" disabled="@(!CanEdit)" @bind="assignmentForm.AllowRevision" @bind:after="AutoSaveAssignment" />
                    <label class="form-check-label" for="assignment-revision">Allow revision</label>
                </div>

                <label class="form-label" for="assignment-revision-expectation">Revision expectation</label>
                <textarea id="assignment-revision-expectation" class="form-control" rows="3" disabled="@(!CanEdit)" @bind="assignmentForm.RevisionExpectation" @bind:after="AutoSaveAssignment"></textarea>

                <label class="form-label" for="assignment-revision-count">Minimum revisions</label>
                <input id="assignment-revision-count" class="form-control" type="number" min="0" step="1" disabled="@(!CanEdit)" @bind="assignmentForm.MinimumRevisionCount" @bind:after="AutoSaveAssignment" />

                <label class="form-label" for="assignment-evidence-type">Evidence type</label>
                <select id="assignment-evidence-type" class="form-select" disabled="@(!CanEdit)" @bind="assignmentForm.EvidenceType" @bind:after="AutoSaveAssignment">
                    @foreach (var type in Enum.GetValues<AssignmentEvidenceType>())
                    {
                        <option value="@type">@EnumLabel(type.ToString())</option>
                    }
                </select>

                <label class="form-label" for="assignment-file-types">Recommended file types</label>
                <textarea id="assignment-file-types" class="form-control" rows="3" disabled="@(!CanEdit)" @bind="assignmentForm.RecommendedFileTypesText" @bind:after="AutoSaveAssignment"></textarea>

                <div class="form-check mt-2">
                    <input id="assignment-retain-records" class="form-check-input" type="checkbox" disabled="@(!CanEdit)" @bind="assignmentForm.RetainForRecords" @bind:after="AutoSaveAssignment" />
                    <label class="form-check-label" for="assignment-retain-records">Retain for records</label>
                </div>

                <div class="form-check mt-2">
                    <input id="assignment-student-explanation" class="form-check-input" type="checkbox" disabled="@(!CanEdit)" @bind="assignmentForm.RequiresStudentExplanation" @bind:after="AutoSaveAssignment" />
                    <label class="form-check-label" for="assignment-student-explanation">Requires student explanation</label>
                </div>

                <div class="form-check mt-2">
                    <input id="assignment-parent-evaluation" class="form-check-input" type="checkbox" disabled="@(!CanEdit)" @bind="assignmentForm.RequiresParentEvaluation" @bind:after="AutoSaveAssignment" />
                    <label class="form-check-label" for="assignment-parent-evaluation">Requires parent evaluation</label>
                </div>
            </section>
        </aside>
    </div>
}

@code {
    [Parameter]
    public Guid CourseId { get; set; }

    [Parameter]
    public Guid ModuleId { get; set; }

    [Parameter]
    public Guid AssignmentId { get; set; }

    private LearningModuleView? module;
    private AssignmentView? assignment;
    private AssignmentFormModel assignmentForm = new();
    private readonly List<PageMessage> messages = [];
    private readonly Dictionary<string, string> fieldErrors = [];
    private string selectedVariantId = "";

    private bool CanEdit => Session.IsParentAdmin;

    protected override async Task OnParametersSetAsync()
    {
        await Refresh();
    }

    private async Task Refresh()
    {
        if (!CanEdit)
        {
            module = null;
            assignment = null;
            if (!Session.IsAuthenticated)
            {
                NavigationManager.NavigateTo("/login", replace: true);
            }

            return;
        }

        module = await CourseService.GetModuleDetailAsync(CourseId, ModuleId);
        assignment = module?.Assignments.FirstOrDefault(item => item.Id == AssignmentId);
        assignmentForm = assignment is null
            ? new AssignmentFormModel()
            : new AssignmentFormModel
            {
                Title = assignment.Title,
                Type = assignment.Type,
                MethodProfile = assignment.MethodProfile,
                Instructions = assignment.Instructions,
                EstimatedEffort = assignment.EstimatedEffort,
                DueTimingLabel = assignment.DueTimingLabel,
                DueDate = assignment.DueDate,
                LinkedModuleObjectives = assignment.LinkedModuleObjectives.ToList(),
                LinkedLessonIds = assignment.LinkedLessonIds.ToList(),
                RequiredOutput = assignment.RequiredOutput,
                ParentNotes = assignment.ParentNotes,
                IsPortfolioCandidate = assignment.IsPortfolioCandidate,
                PlannedPoints = assignment.PlannedPoints,
                PlannedWeight = assignment.PlannedWeight,
                Status = assignment.Status,
                AssignmentSummary = assignment.AssignmentSummary,
                StudentFacingGoal = assignment.StudentFacingGoal,
                EstimatedMinutesMin = assignment.EstimatedMinutesMin,
                EstimatedMinutesMax = assignment.EstimatedMinutesMax,
                RequiredDeliverablesText = Lines(assignment.RequiredDeliverables),
                SubmissionFormats = assignment.SubmissionFormats.ToList(),
                PortfolioSection = assignment.PortfolioConnection?.PortfolioSection ?? "",
                ArtifactTitle = assignment.PortfolioConnection?.ArtifactTitle ?? "",
                ArtifactPurpose = assignment.PortfolioConnection?.ArtifactPurpose ?? "",
                ReuseInstructions = assignment.PortfolioConnection?.ReuseInstructions ?? "",
                CrossCourseLinksText = Lines(assignment.PortfolioConnection?.CrossCourseLinks ?? []),
                RubricId = assignment.Rubric?.RubricId ?? "",
                RubricScale = assignment.Rubric?.Scale ?? "",
                RubricCriteriaText = SerializeRubric(assignment.Rubric),
                LinkedRubricId = assignment.LinkedRubricId,
                AssessmentSkillsText = Lines(assignment.AssessmentSkills),
                StudentChecklistText = Lines(assignment.StudentChecklist),
                ResourcesText = SerializeResources(assignment.Resources),
                AssignmentStepsText = SerializeSteps(assignment.AssignmentSteps),
                AllowRevision = assignment.RevisionPolicy?.AllowRevision ?? false,
                RevisionExpectation = assignment.RevisionPolicy?.RevisionExpectation ?? "",
                MinimumRevisionCount = assignment.RevisionPolicy?.MinimumRevisionCount ?? 0,
                CompletionRequirementsText = Lines(assignment.CompletionCriteria?.MinimumRequirements ?? []),
                RequiresParentReview = assignment.CompletionCriteria?.RequiresParentReview ?? false,
                MasteryThreshold = assignment.CompletionCriteria?.MasteryThreshold,
                ReflectionPromptsText = Lines(assignment.ReflectionPrompts),
                RetainForRecords = assignment.EvidenceRequirements?.RetainForRecords ?? false,
                EvidenceType = assignment.EvidenceRequirements?.EvidenceType ?? AssignmentEvidenceType.PortfolioArtifact,
                RecommendedFileTypesText = Lines(assignment.EvidenceRequirements?.RecommendedFileTypes ?? []),
                RequiresStudentExplanation = assignment.EvidenceRequirements?.RequiresStudentExplanation ?? false,
                RequiresParentEvaluation = assignment.EvidenceRequirements?.RequiresParentEvaluation ?? false,
                GradingMode = assignment.Scoring?.GradingMode ?? AssignmentGradingMode.Points,
                CountsTowardGrade = assignment.Scoring?.CountsTowardGrade ?? true,
                AllowPartialCredit = assignment.Scoring?.AllowPartialCredit ?? true
            };
    }

    private async Task AutoSaveAssignment()
    {
        if (!CanEdit || assignment is null || !ValidateAssignment())
        {
            return;
        }

        await Run(() => CourseService.UpdateAssignmentAsync(
            ParentUser(),
            new UpdateAssignmentCommand(
                CourseId,
                ModuleId,
                AssignmentId,
                assignmentForm.Title,
                assignmentForm.Type,
                assignmentForm.MethodProfile,
                assignmentForm.Instructions,
                assignmentForm.EstimatedEffort,
                assignmentForm.DueTimingLabel,
                assignmentForm.DueDate,
                assignmentForm.LinkedModuleObjectives,
                assignmentForm.LinkedLessonIds,
                assignmentForm.RequiredOutput,
                assignmentForm.ParentNotes,
                assignmentForm.IsPortfolioCandidate,
                assignmentForm.PlannedPoints,
                assignmentForm.PlannedWeight,
                assignmentForm.Status,
                assignmentForm.AssignmentSummary,
                assignmentForm.StudentFacingGoal,
                assignmentForm.EstimatedMinutesMin,
                assignmentForm.EstimatedMinutesMax,
                SplitLines(assignmentForm.RequiredDeliverablesText),
                assignmentForm.SubmissionFormats,
                BuildPortfolioCommand(),
                BuildRubricCommand(),
                assignmentForm.LinkedRubricId,
                SplitLines(assignmentForm.AssessmentSkillsText),
                SplitLines(assignmentForm.StudentChecklistText),
                BuildResourceCommands(),
                BuildStepCommands(),
                BuildRevisionCommand(),
                BuildCompletionCommand(),
                SplitLines(assignmentForm.ReflectionPromptsText),
                BuildEvidenceCommand(),
                BuildScoringCommand())));
    }

    private async Task ApplyVariant(ChangeEventArgs eventArgs)
    {
        selectedVariantId = eventArgs.Value?.ToString() ?? "";
        var variant = module?.AssignmentVariants.FirstOrDefault(item => item.VariantId == selectedVariantId);
        if (variant is null)
        {
            return;
        }

        assignmentForm.Title = variant.Title;
        assignmentForm.Type = variant.Type;
        assignmentForm.MethodProfile = variant.MethodProfile;
        assignmentForm.Instructions = variant.Instructions;
        assignmentForm.EstimatedEffort = variant.EstimatedEffort;
        assignmentForm.DueTimingLabel = variant.DueTimingLabel;
        assignmentForm.DueDate = null;
        assignmentForm.LinkedModuleObjectives = variant.LinkedModuleObjectives.ToList();
        assignmentForm.LinkedLessonIds = variant.LinkedSourceLessonIds
            .Select(sourceId => module?.Lessons.FirstOrDefault(lesson => string.Equals(lesson.SourceLessonId, sourceId, StringComparison.OrdinalIgnoreCase))?.Id ?? Guid.Empty)
            .Where(id => id != Guid.Empty)
            .ToList();
        assignmentForm.RequiredOutput = variant.RequiredOutput;
        assignmentForm.ParentNotes = variant.ParentNotes;
        assignmentForm.IsPortfolioCandidate = variant.IsPortfolioCandidate;
        assignmentForm.PlannedPoints = variant.PlannedPoints;
        assignmentForm.PlannedWeight = variant.PlannedWeight;
        assignmentForm.Status = variant.Status;
        assignmentForm.AssignmentSummary = variant.AssignmentSummary;
        assignmentForm.StudentFacingGoal = variant.StudentFacingGoal;
        assignmentForm.EstimatedMinutesMin = variant.EstimatedMinutesMin;
        assignmentForm.EstimatedMinutesMax = variant.EstimatedMinutesMax;
        assignmentForm.RequiredDeliverablesText = Lines(variant.RequiredDeliverables);
        assignmentForm.SubmissionFormats = variant.SubmissionFormats.ToList();
        assignmentForm.PortfolioSection = variant.PortfolioConnection?.PortfolioSection ?? "";
        assignmentForm.ArtifactTitle = variant.PortfolioConnection?.ArtifactTitle ?? "";
        assignmentForm.ArtifactPurpose = variant.PortfolioConnection?.ArtifactPurpose ?? "";
        assignmentForm.ReuseInstructions = variant.PortfolioConnection?.ReuseInstructions ?? "";
        assignmentForm.CrossCourseLinksText = Lines(variant.PortfolioConnection?.CrossCourseLinks ?? []);
        assignmentForm.RubricId = variant.Rubric?.RubricId ?? "";
        assignmentForm.RubricScale = variant.Rubric?.Scale ?? "";
        assignmentForm.RubricCriteriaText = SerializeRubric(variant.Rubric);
        assignmentForm.LinkedRubricId = variant.LinkedRubricId;
        assignmentForm.AssessmentSkillsText = Lines(variant.AssessmentSkills);
        assignmentForm.StudentChecklistText = Lines(variant.StudentChecklist);
        assignmentForm.ResourcesText = SerializeResources(variant.Resources);
        assignmentForm.AssignmentStepsText = SerializeSteps(variant.AssignmentSteps);
        assignmentForm.AllowRevision = variant.RevisionPolicy?.AllowRevision ?? false;
        assignmentForm.RevisionExpectation = variant.RevisionPolicy?.RevisionExpectation ?? "";
        assignmentForm.MinimumRevisionCount = variant.RevisionPolicy?.MinimumRevisionCount ?? 0;
        assignmentForm.CompletionRequirementsText = Lines(variant.CompletionCriteria?.MinimumRequirements ?? []);
        assignmentForm.RequiresParentReview = variant.CompletionCriteria?.RequiresParentReview ?? false;
        assignmentForm.MasteryThreshold = variant.CompletionCriteria?.MasteryThreshold;
        assignmentForm.ReflectionPromptsText = Lines(variant.ReflectionPrompts);
        assignmentForm.RetainForRecords = variant.EvidenceRequirements?.RetainForRecords ?? false;
        assignmentForm.EvidenceType = variant.EvidenceRequirements?.EvidenceType ?? AssignmentEvidenceType.PortfolioArtifact;
        assignmentForm.RecommendedFileTypesText = Lines(variant.EvidenceRequirements?.RecommendedFileTypes ?? []);
        assignmentForm.RequiresStudentExplanation = variant.EvidenceRequirements?.RequiresStudentExplanation ?? false;
        assignmentForm.RequiresParentEvaluation = variant.EvidenceRequirements?.RequiresParentEvaluation ?? false;
        assignmentForm.GradingMode = variant.Scoring?.GradingMode ?? AssignmentGradingMode.Points;
        assignmentForm.CountsTowardGrade = variant.Scoring?.CountsTowardGrade ?? true;
        assignmentForm.AllowPartialCredit = variant.Scoring?.AllowPartialCredit ?? true;
        await AutoSaveAssignment();
    }

    private async Task ToggleObjective(string objective)
    {
        if (assignmentForm.LinkedModuleObjectives.Contains(objective))
        {
            assignmentForm.LinkedModuleObjectives.Remove(objective);
        }
        else
        {
            assignmentForm.LinkedModuleObjectives.Add(objective);
        }

        await AutoSaveAssignment();
    }

    private async Task ToggleLesson(Guid lessonId)
    {
        if (assignmentForm.LinkedLessonIds.Contains(lessonId))
        {
            assignmentForm.LinkedLessonIds.Remove(lessonId);
        }
        else
        {
            assignmentForm.LinkedLessonIds.Add(lessonId);
        }

        await AutoSaveAssignment();
    }

    private async Task ToggleSubmissionFormat(AssignmentSubmissionFormat format)
    {
        if (assignmentForm.SubmissionFormats.Contains(format))
        {
            assignmentForm.SubmissionFormats.Remove(format);
        }
        else
        {
            assignmentForm.SubmissionFormats.Add(format);
        }

        await AutoSaveAssignment();
    }

    private async Task Run(Func<Task<OperationResult>> action)
    {
        messages.Clear();
        fieldErrors.Clear();
        var result = await action();
        if (result.Succeeded)
        {
            messages.Add(new PageMessage("Saved.", "alert alert-success"));
            await Refresh();
            return;
        }

        messages.AddRange(result.Errors.Select(error => new PageMessage(error, "alert alert-danger")));
    }

    private void BackToModule()
    {
        NavigationManager.NavigateTo($"/courses/{CourseId}/modules/{ModuleId}");
    }

    private bool ValidateAssignment()
    {
        messages.Clear();
        fieldErrors.Clear();

        if (string.IsNullOrWhiteSpace(assignmentForm.Title))
        {
            fieldErrors["assignment.Title"] = "Title is required.";
        }

        if (string.IsNullOrWhiteSpace(assignmentForm.Instructions))
        {
            fieldErrors["assignment.Instructions"] = "Instructions are required.";
        }

        if (string.IsNullOrWhiteSpace(assignmentForm.RequiredOutput))
        {
            fieldErrors["assignment.RequiredOutput"] = "Required output is required.";
        }

        if (fieldErrors.Count == 0)
        {
            return true;
        }

        messages.Add(new PageMessage("Please complete the required assignment fields.", "alert alert-danger"));
        return false;
    }

    private MarkupString ValidationFor(string key)
    {
        return fieldErrors.TryGetValue(key, out var message)
            ? new MarkupString($"<div class=\"validation-message\">{System.Net.WebUtility.HtmlEncode(message)}</div>")
            : new MarkupString("");
    }

    private UserContext ParentUser()
    {
        return Session.CurrentUser ?? UserContext.Student("Anonymous");
    }

    private AssignmentPortfolioConnectionCommand? BuildPortfolioCommand()
    {
        if (!assignmentForm.IsPortfolioCandidate &&
            string.IsNullOrWhiteSpace(assignmentForm.PortfolioSection) &&
            string.IsNullOrWhiteSpace(assignmentForm.ArtifactTitle) &&
            string.IsNullOrWhiteSpace(assignmentForm.ArtifactPurpose) &&
            string.IsNullOrWhiteSpace(assignmentForm.ReuseInstructions) &&
            string.IsNullOrWhiteSpace(assignmentForm.CrossCourseLinksText))
        {
            return null;
        }

        return new AssignmentPortfolioConnectionCommand(
            assignmentForm.IsPortfolioCandidate,
            assignmentForm.PortfolioSection,
            assignmentForm.ArtifactTitle,
            assignmentForm.ArtifactPurpose,
            assignmentForm.ReuseInstructions,
            SplitLines(assignmentForm.CrossCourseLinksText));
    }

    private LessonRubricCommand? BuildRubricCommand()
    {
        var criteria = ParseRubric(assignmentForm.RubricCriteriaText);
        if (string.IsNullOrWhiteSpace(assignmentForm.RubricId) &&
            string.IsNullOrWhiteSpace(assignmentForm.RubricScale) &&
            criteria.Count == 0)
        {
            return null;
        }

        return new LessonRubricCommand(assignmentForm.RubricId, assignmentForm.RubricScale, criteria);
    }

    private IReadOnlyList<AssignmentResourceCommand> BuildResourceCommands()
    {
        return assignmentForm.ResourcesText
            .Split(Environment.NewLine, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select((line, index) =>
            {
                var parts = line.Split('|', StringSplitOptions.TrimEntries);
                var type = parts.Length > 2 && Enum.TryParse<LessonResourceType>(parts[2], true, out var parsedType)
                    ? parsedType
                    : LessonResourceType.Website;
                return new AssignmentResourceCommand(
                    parts.ElementAtOrDefault(0) ?? "",
                    type,
                    parts.ElementAtOrDefault(1) ?? "",
                    "",
                    type == LessonResourceType.PhysicalResource,
                    true,
                    parts.ElementAtOrDefault(3) ?? "",
                    parts.ElementAtOrDefault(4) ?? "",
                    null);
            })
            .Where(item => !string.IsNullOrWhiteSpace(item.Name))
            .ToArray();
    }

    private IReadOnlyList<AssignmentStepCommand> BuildStepCommands()
    {
        return assignmentForm.AssignmentStepsText
            .Split(Environment.NewLine, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select((line, index) =>
            {
                var parts = line.Split('|', StringSplitOptions.TrimEntries);
                var minutes = int.TryParse(parts.ElementAtOrDefault(2), out var parsed) ? parsed : 0;
                return new AssignmentStepCommand(index + 1, parts.ElementAtOrDefault(0) ?? "", parts.ElementAtOrDefault(1) ?? "", minutes);
            })
            .Where(item => !string.IsNullOrWhiteSpace(item.Title))
            .ToArray();
    }

    private AssignmentRevisionPolicyCommand? BuildRevisionCommand()
    {
        if (!assignmentForm.AllowRevision &&
            string.IsNullOrWhiteSpace(assignmentForm.RevisionExpectation) &&
            assignmentForm.MinimumRevisionCount <= 0)
        {
            return null;
        }

        return new AssignmentRevisionPolicyCommand(
            assignmentForm.AllowRevision,
            assignmentForm.RevisionExpectation,
            assignmentForm.MinimumRevisionCount);
    }

    private AssignmentCompletionCriteriaCommand? BuildCompletionCommand()
    {
        var requirements = SplitLines(assignmentForm.CompletionRequirementsText);
        if (requirements.Count == 0 && !assignmentForm.RequiresParentReview && assignmentForm.MasteryThreshold is null)
        {
            return null;
        }

        return new AssignmentCompletionCriteriaCommand(requirements, assignmentForm.RequiresParentReview, assignmentForm.MasteryThreshold);
    }

    private AssignmentEvidenceRequirementsCommand? BuildEvidenceCommand()
    {
        var fileTypes = SplitLines(assignmentForm.RecommendedFileTypesText);
        if (!assignmentForm.RetainForRecords &&
            fileTypes.Count == 0 &&
            !assignmentForm.RequiresStudentExplanation &&
            !assignmentForm.RequiresParentEvaluation)
        {
            return null;
        }

        return new AssignmentEvidenceRequirementsCommand(
            assignmentForm.RetainForRecords,
            assignmentForm.EvidenceType,
            fileTypes,
            assignmentForm.RequiresStudentExplanation,
            assignmentForm.RequiresParentEvaluation);
    }

    private AssignmentScoringCommand BuildScoringCommand()
    {
        return new AssignmentScoringCommand(
            assignmentForm.PlannedPoints,
            assignmentForm.PlannedWeight,
            assignmentForm.GradingMode,
            assignmentForm.CountsTowardGrade,
            assignmentForm.AllowPartialCredit);
    }

    private static IReadOnlyList<string> SplitLines(string value)
    {
        return value
            .Split(Environment.NewLine, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(line => !string.IsNullOrWhiteSpace(line))
            .ToArray();
    }

    private static string Lines(IEnumerable<string> values)
    {
        return string.Join(Environment.NewLine, values.Where(value => !string.IsNullOrWhiteSpace(value)));
    }

    private static IReadOnlyList<LessonRubricCriterionCommand> ParseRubric(string value)
    {
        return value
            .Split(Environment.NewLine, StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(line =>
            {
                var parts = line.Split('|', StringSplitOptions.TrimEntries);
                return new LessonRubricCriterionCommand(
                    parts.ElementAtOrDefault(0) ?? "",
                    parts.ElementAtOrDefault(1) ?? "",
                    parts.ElementAtOrDefault(2) ?? "",
                    parts.ElementAtOrDefault(3) ?? "",
                    parts.ElementAtOrDefault(4) ?? "");
            })
            .Where(item => !string.IsNullOrWhiteSpace(item.Criterion))
            .ToArray();
    }

    private static string SerializeRubric(LessonRubric? rubric)
    {
        return rubric is null
            ? ""
            : Lines(rubric.Criteria.Select(item => $"{item.Criterion} | {item.Level4} | {item.Level3} | {item.Level2} | {item.Level1}"));
    }

    private static string SerializeResources(IReadOnlyList<AssignmentResource> resources)
    {
        return Lines(resources.Select(item => $"{item.Name} | {item.Url} | {item.Type} | {item.StudentInstructions} | {item.SourceNote}"));
    }

    private static string SerializeSteps(IReadOnlyList<AssignmentStep> steps)
    {
        return Lines(steps.OrderBy(step => step.StepOrder).Select(item => $"{item.Title} | {item.Instructions} | {item.EstimatedMinutes}"));
    }

    private static string AssignmentTypeLabel(AssignmentType type)
    {
        return type switch
        {
            AssignmentType.ReadingResponse => "Reading response",
            AssignmentType.ProblemSet => "Problem set",
            AssignmentType.LabOrSimulation => "Lab or simulation",
            AssignmentType.QuizOrTestPrep => "Quiz or test prep",
            AssignmentType.PortfolioArtifact => "Portfolio artifact",
            AssignmentType.PracticalDemonstration => "Practical demonstration",
            _ => type.ToString()
        };
    }

    private static string MethodProfileLabel(InstructionalMethodProfile profile)
    {
        return profile switch
        {
            InstructionalMethodProfile.Hybrid => "Hybrid",
            InstructionalMethodProfile.ExplicitGuidedPractice => "Explicit / guided practice",
            InstructionalMethodProfile.ProjectBasedApplied => "Project-based / applied",
            InstructionalMethodProfile.InquiryDiscussion => "Inquiry / discussion",
            InstructionalMethodProfile.IndependentStudy => "Independent study",
            InstructionalMethodProfile.MasteryPractice => "Mastery practice",
            InstructionalMethodProfile.Digital => "Digital",
            _ => profile.ToString()
        };
    }

    private static string StatusLabel(AssignmentStatus status)
    {
        return status switch
        {
            AssignmentStatus.Planned => "Planned",
            AssignmentStatus.Assigned => "Assigned",
            AssignmentStatus.Submitted => "Submitted",
            AssignmentStatus.Reviewed => "Reviewed",
            AssignmentStatus.Complete => "Complete",
            AssignmentStatus.Skipped => "Skipped",
            _ => status.ToString()
        };
    }

    private static string EnumLabel(string value)
    {
        return Regex.Replace(value, "([a-z])([A-Z])", "$1 $2");
    }


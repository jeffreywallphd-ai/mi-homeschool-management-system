    private static IEnumerable<string> SplitLines(string value)
    {
        return (value ?? "")
            .Split(["\r\n", "\n"], StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(line => !string.IsNullOrWhiteSpace(line));
    }

    private static string Lines(IEnumerable<string> values)
    {
        return string.Join(Environment.NewLine, values.Where(value => !string.IsNullOrWhiteSpace(value)));
    }

    private static IEnumerable<LessonLearningObjectiveCommand> ParseLessonObjectives(string value)
    {
        return SplitLines(value)
            .Select(line =>
            {
                var parts = line.Split('|', 3, StringSplitOptions.TrimEntries);
                var bloom = parts.Length > 1 && Enum.TryParse<BloomLevel>(parts[1], true, out var parsedBloom)
                    ? parsedBloom
                    : BloomLevel.Apply;
                return new LessonLearningObjectiveCommand(
                    parts.Length > 0 ? parts[0] : "",
                    parts.Length > 2 ? parts[2] : parts[0],
                    bloom);
            });
    }

    private static string SerializeLessonObjectives(IEnumerable<LessonLearningObjectiveView> objectives)
    {
        return Lines(objectives.Select(objective => $"{objective.ObjectiveId} | {objective.BloomLevel} | {objective.Text}"));
    }

    private static IEnumerable<StandardsAlignmentCommand> ParseStandards(string value)
    {
        return SplitLines(value)
            .Select(line =>
            {
                var parts = line.Split('|', 3, StringSplitOptions.TrimEntries);
                return new StandardsAlignmentCommand(
                    parts.Length > 0 ? parts[0] : "",
                    parts.Length > 1 ? parts[1] : "",
                    parts.Length > 2 ? parts[2] : "");
            });
    }

    private static string SerializeStandards(IEnumerable<StandardsAlignmentView> standards)
    {
        return Lines(standards.Select(standard => $"{standard.Framework} | {standard.Code} | {standard.Description}"));
    }

    private static IEnumerable<LessonStepCommand> ParseLessonSteps(string value)
    {
        return SplitLines(value).Select((line, index) =>
        {
            var parts = line.Split('|', 5, StringSplitOptions.TrimEntries);
            var type = parts.Length > 1 && Enum.TryParse<LessonStepType>(parts[1], true, out var parsedType)
                ? parsedType
                : LessonStepType.Practice;
            var minutes = parts.Length > 3 && int.TryParse(parts[3], out var parsedMinutes)
                ? parsedMinutes
                : 0;
            var required = parts.Length <= 4 || !bool.TryParse(parts[4], out var parsedRequired) || parsedRequired;
            return new LessonStepCommand(
                index + 1,
                parts.Length > 0 ? parts[0] : $"Step {index + 1}",
                type,
                parts.Length > 2 ? parts[2] : line,
                minutes,
                required);
        });
    }

    private static string SerializeLessonSteps(IEnumerable<LessonStepView> steps)
    {
        return Lines(steps.Select(step => $"{step.Title} | {step.StepType} | {step.Instructions} | {step.EstimatedMinutes} | {step.Required}"));
    }

    private static IEnumerable<LessonProblemSetCommand> ParseProblemSets(string value)
    {
        return SplitLines(value).Select((line, index) =>
        {
            var parts = line.Split('|', 5, StringSplitOptions.TrimEntries);
            var minutes = parts.Length > 2 && int.TryParse(parts[2], out var parsedMinutes)
                ? parsedMinutes
                : 0;
            var problemPrompt = parts.Length > 3 ? parts[3] : "";
            var problem = string.IsNullOrWhiteSpace(problemPrompt)
                ? Array.Empty<LessonProblemCommand>()
                : [new LessonProblemCommand($"{parts[0]}-problem-1", problemPrompt, ProblemResponseType.WorkedSolution, parts.Length > 4 ? parts[4] : "", "", [], "")];
            return new LessonProblemSetCommand(
                parts.Length > 0 ? parts[0] : $"problem-set-{index + 1}",
                parts.Length > 1 ? parts[1] : line,
                "",
                minutes,
                problem);
        });
    }

    private static string SerializeProblemSets(IEnumerable<LessonProblemSetView> problemSets)
    {
        return Lines(problemSets.Select(problemSet =>
            $"{problemSet.ProblemSetId} | {problemSet.Title} | {problemSet.EstimatedMinutes} | {problemSet.Problems.FirstOrDefault()?.Prompt ?? ""} | {problemSet.Problems.FirstOrDefault()?.ExpectedAnswer ?? ""}"));
    }

    private static IEnumerable<LessonPortfolioConnectionCommand> ParsePortfolioConnections(string value)
    {
        return SplitLines(value)
            .Select(line =>
            {
                var parts = line.Split('|', 5, StringSplitOptions.TrimEntries);
                return new LessonPortfolioConnectionCommand(
                    parts.Length > 0 ? parts[0] : "",
                    parts.Length > 1 ? parts[1] : "",
                    parts.Length > 2 ? parts[2] : "",
                    parts.Length > 3 ? parts[3].Split(';', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries) : [],
                    parts.Length > 4 ? parts[4] : "");
            });
    }

    private static string SerializePortfolioConnections(IEnumerable<LessonPortfolioConnectionView> connections)
    {
        return Lines(connections.Select(connection => $"{connection.PortfolioSection} | {connection.ArtifactTitle} | {connection.ArtifactPurpose} | {string.Join("; ", connection.CrossCourseLinks)} | {connection.ReuseInstructions}"));
    }

    private static LessonRubricCommand? ParseRubric(string value)
    {
        var criteria = SplitLines(value)
            .Select(line =>
            {
                var parts = line.Split('|', 5, StringSplitOptions.TrimEntries);
                return new LessonRubricCriterionCommand(
                    parts.Length > 0 ? parts[0] : "",
                    parts.Length > 1 ? parts[1] : "",
                    parts.Length > 2 ? parts[2] : "",
                    parts.Length > 3 ? parts[3] : "",
                    parts.Length > 4 ? parts[4] : "");
            })
            .Where(item => !string.IsNullOrWhiteSpace(item.Criterion))
            .ToArray();
        return criteria.Length == 0 ? null : new LessonRubricCommand("lesson-rubric", "4-point", criteria);
    }

    private static string SerializeRubric(LessonRubricView? rubric)
    {
        return rubric is null
            ? ""
            : Lines(rubric.Criteria.Select(criteria => $"{criteria.Criterion} | {criteria.Level4} | {criteria.Level3} | {criteria.Level2} | {criteria.Level1}"));
    }

    private static string EnumLabel(string value)
    {
        return System.Text.RegularExpressions.Regex.Replace(value, "([a-z])([A-Z])", "$1 $2");
    }


@page "/courses/{CourseId:guid}/modules/{ModuleId:guid}/lessons/{LessonId:guid}"
@rendermode InteractiveServer
@using HomeschoolManager.Application.Common
@using HomeschoolManager.Application.Courses
@using HomeschoolManager.Domain.Access
@using HomeschoolManager.Domain.Curriculum
@using HomeschoolManager.Infrastructure.Persistence
@using HomeschoolManager.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject CourseService CourseService
@inject SessionState Session
@inject NavigationManager NavigationManager
@inject AppDataPaths AppDataPaths

<PageTitle>Lesson Detail</PageTitle>

@if (module is null || lesson is null)
{
    <h1>Lesson not found</h1>
    <p>The requested lesson could not be loaded.</p>
}
else
{
    <div class="page-header-bar">
        <div>
            <h1>@lesson.Title</h1>
            <p>@module.Title</p>
        </div>
        @if (messages.Count > 0)
        {
            <section class="page-header-message" aria-live="polite">
                @foreach (var message in messages)
                {
                    <div class="@message.CssClass">@message.Text</div>
                }
            </section>
        }
    </div>

    @if (!CanEdit)
    {
        <div class="alert alert-warning">Sign in as parent/admin to edit lessons.</div>
    }

    <div class="content-workbench course-detail-workbench">
        <main class="workbench-main">
            <section class="form-section">
                <h2>Lesson Identity</h2>
                <label class="form-label" for="lesson-title">Title <span class="required-marker">*</span></label>
                <input id="lesson-title" class="form-control" disabled="@(!CanEdit)" @bind="lessonForm.Title" @bind:after="AutoSaveLesson" />
                @ValidationFor("lesson.Title")

                <label class="form-label" for="lesson-objective">Linked module objective</label>
                <select id="lesson-objective" class="form-select" disabled="@(!CanEdit)" @bind="lessonForm.LinkedModuleObjective" @bind:after="AutoSaveLesson">
                    <option value="">No objective link</option>
                    @foreach (var objective in module.LearningObjectiveItems)
                    {
                        <option value="@objective.Text">@objective.Text</option>
                    }
                </select>

                <label class="form-label" for="lesson-intro">Introductory text <span class="required-marker">*</span></label>
                <textarea id="lesson-intro" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="lessonForm.IntroductoryText" @bind:after="AutoSaveLesson"></textarea>
                @ValidationFor("lesson.IntroductoryText")

                <div class="form-grid two-column-form-grid">
                    <div>
                        <label class="form-label" for="lesson-type">Lesson type</label>
                        <select id="lesson-type" class="form-select" disabled="@(!CanEdit)" @bind="lessonForm.LessonType" @bind:after="AutoSaveLesson">
                            @foreach (var type in Enum.GetValues<LessonType>())
                            {
                                <option value="@type">@EnumLabel(type.ToString())</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label" for="lesson-difficulty">Difficulty</label>
                        <select id="lesson-difficulty" class="form-select" disabled="@(!CanEdit)" @bind="lessonForm.DifficultyLevel" @bind:after="AutoSaveLesson">
                            @foreach (var level in Enum.GetValues<LessonDifficultyLevel>())
                            {
                                <option value="@level">@EnumLabel(level.ToString())</option>
                            }
                        </select>
                    </div>
                    <div>
                        <label class="form-label" for="lesson-minutes">Estimated minutes</label>
                        <input id="lesson-minutes" class="form-control" type="number" min="0" disabled="@(!CanEdit)" @bind="lessonForm.EstimatedMinutes" @bind:after="AutoSaveLesson" />
                    </div>
                    <div>
                        <label class="form-label" for="lesson-days">Suggested days</label>
                        <input id="lesson-days" class="form-control" type="number" min="0" disabled="@(!CanEdit)" @bind="lessonForm.SuggestedDays" @bind:after="AutoSaveLesson" />
                    </div>
                </div>
            </section>

            <section class="form-section">
                <h2>Planning Metadata</h2>
                <ItemizedTextListEditor Title="Subject areas" EntryLabel="Subject area" EmptyText="No subject areas have been added." Items="lessonForm.SubjectAreas" ItemsChanged="UpdateLessonSubjectAreas" Disabled="@(!CanEdit)" />
                <ItemizedTextListEditor Title="Tags" EntryLabel="Tag" EmptyText="No tags have been added." Items="lessonForm.Tags" ItemsChanged="UpdateLessonTags" Disabled="@(!CanEdit)" />
                <ItemizedTextListEditor Title="Prerequisites" EntryLabel="Prerequisite" EmptyText="No prerequisites have been added." Items="lessonForm.Prerequisites" ItemsChanged="UpdateLessonPrerequisites" Disabled="@(!CanEdit)" />
            </section>

            <section class="form-section">
                <h2>Student Workflow</h2>
                <div class="section-heading-row mt-3">
                    <h3>Lesson learning objectives</h3>
                    @if (CanEdit)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleLessonObjectiveForm">@LessonObjectiveToggleText()</button>
                    }
                </div>
                @if (lessonForm.ShowLessonObjectiveForm && CanEdit)
                {
                    <div class="inline-entry-form">
                        <label class="form-label" for="lesson-objective-id">Objective id</label>
                        <input id="lesson-objective-id" class="form-control" @bind="lessonForm.NewObjectiveId" />
                        <label class="form-label" for="lesson-objective-bloom">Bloom level</label>
                        <select id="lesson-objective-bloom" class="form-select" @bind="lessonForm.NewObjectiveBloomLevel">
                            @foreach (var level in Enum.GetValues<BloomLevel>())
                            {
                                <option value="@level">@EnumLabel(level.ToString())</option>
                            }
                        </select>
                        <label class="form-label" for="lesson-objective-text">Objective text</label>
                        <textarea id="lesson-objective-text" class="form-control" rows="3" @bind="lessonForm.NewObjectiveText"></textarea>
                        <button class="btn btn-secondary mt-2" @onclick="AddLessonObjective">Add objective</button>
                    </div>
                }
                @if (lessonForm.LearningObjectives.Count == 0)
                {
                    <p>No lesson learning objectives have been added.</p>
                }
                else
                {
                    <ul class="itemized-editor-list stacked-editor-list">
                        @for (var index = 0; index < lessonForm.LearningObjectives.Count; index++)
                        {
                            var objectiveIndex = index;
                            var objective = lessonForm.LearningObjectives[index];
                            <li>
                                <div class="itemized-editor-content">
                                    <strong>@objective.Text</strong>
                                    <small>@objective.ObjectiveId</small>
                                    <small>@EnumLabel(objective.BloomLevel.ToString())</small>
                                </div>
                                @if (CanEdit)
                                {
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteLessonObjective(objectiveIndex)">Delete</button>
                                }
                            </li>
                        }
                    </ul>
                }
                <div class="section-heading-row mt-3">
                    <h3>Standards alignment</h3>
                    @if (CanEdit)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleStandardsForm">@StandardsToggleText()</button>
                    }
                </div>
                @if (lessonForm.ShowStandardsForm && CanEdit)
                {
                    <div class="inline-entry-form">
                        <label class="form-label" for="lesson-standard-framework">Framework</label>
                        <input id="lesson-standard-framework" class="form-control" @bind="lessonForm.NewStandardFramework" />
                        <label class="form-label" for="lesson-standard-code">Code</label>
                        <input id="lesson-standard-code" class="form-control" @bind="lessonForm.NewStandardCode" />
                        <label class="form-label" for="lesson-standard-description">Description</label>
                        <textarea id="lesson-standard-description" class="form-control" rows="3" @bind="lessonForm.NewStandardDescription"></textarea>
                        <button class="btn btn-secondary mt-2" @onclick="AddStandard">Add standard</button>
                    </div>
                }
                @if (lessonForm.StandardsAlignments.Count == 0)
                {
                    <p>No standards alignments have been added.</p>
                }
                else
                {
                    <ul class="itemized-editor-list stacked-editor-list">
                        @for (var index = 0; index < lessonForm.StandardsAlignments.Count; index++)
                        {
                            var standardIndex = index;
                            var standard = lessonForm.StandardsAlignments[index];
                            <li>
                                <div class="itemized-editor-content">
                                    <strong>@standard.Code</strong>
                                    <small>@standard.Framework</small>
                                    <span>@standard.Description</span>
                                </div>
                                @if (CanEdit)
                                {
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteStandard(standardIndex)">Delete</button>
                                }
                            </li>
                        }
                    </ul>
                }
                <ItemizedTextListEditor Title="Success criteria" EntryLabel="Success criterion" EmptyText="No success criteria have been added." Items="lessonForm.SuccessCriteria" ItemsChanged="UpdateLessonSuccessCriteria" Disabled="@(!CanEdit)" AllowReorder="true" />
                <div class="section-heading-row mt-3">
                    <h3>Lesson steps</h3>
                    @if (CanEdit)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleLessonStepForm">@LessonStepToggleText()</button>
                    }
                </div>
                @if (lessonForm.ShowLessonStepForm && CanEdit)
                {
                    <div class="inline-entry-form">
                        <label class="form-label" for="lesson-step-title">Title</label>
                        <input id="lesson-step-title" class="form-control" @bind="lessonForm.NewStepTitle" />
                        <label class="form-label" for="lesson-step-type">Step type</label>
                        <select id="lesson-step-type" class="form-select" @bind="lessonForm.NewStepType">
                            @foreach (var type in Enum.GetValues<LessonStepType>())
                            {
                                <option value="@type">@EnumLabel(type.ToString())</option>
                            }
                        </select>
                        <label class="form-label" for="lesson-step-instructions">Instructions</label>
                        <textarea id="lesson-step-instructions" class="form-control" rows="3" @bind="lessonForm.NewStepInstructions"></textarea>
                        <label class="form-label" for="lesson-step-minutes">Estimated minutes</label>
                        <input id="lesson-step-minutes" class="form-control" type="number" min="0" step="1" @bind="lessonForm.NewStepEstimatedMinutes" />
                        <div class="form-check mt-2">
                            <input id="lesson-step-required" class="form-check-input" type="checkbox" @bind="lessonForm.NewStepRequired" />
                            <label class="form-check-label" for="lesson-step-required">Required step</label>
                        </div>
                        <button class="btn btn-secondary mt-2" @onclick="AddLessonStep">Add step</button>
                    </div>
                }
                @if (lessonForm.LessonSteps.Count == 0)
                {
                    <p>No lesson steps have been added.</p>
                }
                else
                {
                    <ul class="itemized-editor-list stacked-editor-list">
                        @for (var index = 0; index < lessonForm.LessonSteps.Count; index++)
                        {
                            var stepIndex = index;
                            var step = lessonForm.LessonSteps[index];
                            <li>
                                <div class="itemized-editor-content">
                                    <strong>@step.Title</strong>
                                    <span>@step.Instructions</span>
                                    <small>@EnumLabel(step.StepType.ToString())@(step.EstimatedMinutes > 0 ? $" | {step.EstimatedMinutes} minutes" : "")@(step.Required ? " | Required" : " | Optional")</small>
                                </div>
                                @if (CanEdit)
                                {
                                    <div class="module-order-actions">
                                        <button class="btn btn-outline-secondary btn-sm" disabled="@(stepIndex == 0)" @onclick="() => MoveLessonStep(stepIndex, -1)">Up</button>
                                        <button class="btn btn-outline-secondary btn-sm" disabled="@(stepIndex == lessonForm.LessonSteps.Count - 1)" @onclick="() => MoveLessonStep(stepIndex, 1)">Down</button>
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteLessonStep(stepIndex)">Delete</button>
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                }
            </section>

            <section class="form-section">
                <div class="section-heading-row">
                    <h2>Lesson Resources</h2>
                    @if (CanEdit)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleResourceForm">@ResourceToggleText()</button>
                    }
                </div>
                @ValidationFor("lesson.Resources")
                @if (lessonForm.ShowResourceForm && CanEdit)
                {
                    <div class="inline-entry-form">
                        <label class="form-label" for="lesson-resource-name">Name</label>
                        <input id="lesson-resource-name" class="form-control" @bind="lessonForm.NewResourceName" />
                        <label class="form-label" for="lesson-resource-type">Type</label>
                        <select id="lesson-resource-type" class="form-select" @bind="lessonForm.NewResourceType">
                            @foreach (var type in Enum.GetValues<LessonResourceType>())
                            {
                                <option value="@type">@ResourceTypeLabel(type)</option>
                            }
                        </select>
                        <label class="form-label" for="lesson-resource-url">Link</label>
                        <input id="lesson-resource-url" class="form-control" type="url" @bind="lessonForm.NewResourceUrl" />
                        <label class="form-label" for="lesson-resource-file">File upload</label>
                        <InputFile id="lesson-resource-file" class="form-control" OnChange="SelectResourceFile" />
                        <div class="form-check mt-2">
                            <input id="lesson-resource-physical" class="form-check-input" type="checkbox" @bind="lessonForm.NewResourceIsPhysical" />
                            <label class="form-check-label" for="lesson-resource-physical">Physical resource</label>
                        </div>
                        <label class="form-label" for="lesson-resource-note">Source note</label>
                        <input id="lesson-resource-note" class="form-control" @bind="lessonForm.NewResourceSourceNote" />
                        <div class="form-grid two-column-form-grid">
                            <div class="form-check mt-2">
                                <input id="lesson-resource-required" class="form-check-input" type="checkbox" @bind="lessonForm.NewResourceRequired" />
                                <label class="form-check-label" for="lesson-resource-required">Required resource</label>
                            </div>
                            <div>
                                <label class="form-label" for="lesson-resource-minutes">Estimated minutes</label>
                                <input id="lesson-resource-minutes" class="form-control" type="number" min="0" @bind="lessonForm.NewResourceEstimatedMinutes" />
                            </div>
                        </div>
                        <label class="form-label" for="lesson-resource-instructions">Student instructions</label>
                        <textarea id="lesson-resource-instructions" class="form-control" rows="4" @bind="lessonForm.NewResourceStudentInstructions"></textarea>
                        <label class="form-label" for="lesson-resource-notes-prompt">Notes prompt</label>
                        <textarea id="lesson-resource-notes-prompt" class="form-control" rows="4" @bind="lessonForm.NewResourceNotesPrompt"></textarea>
                        <button class="btn btn-secondary mt-2" @onclick="AddResource">Add resource</button>
                    </div>
                }
                @if (lessonForm.Resources.Count == 0)
                {
                    <p>No lesson resources have been added.</p>
                }
                else
                {
                    <ul class="itemized-editor-list stacked-editor-list">
                        @for (var index = 0; index < lessonForm.Resources.Count; index++)
                        {
                            var resourceIndex = index;
                            var resource = lessonForm.Resources[index];
                            <li>
                                <div class="itemized-editor-content">
                                    <strong>@resource.Name</strong>
                                    <small>@ResourceTypeLabel(resource.Type)</small>
                                    @if (!string.IsNullOrWhiteSpace(resource.Url))
                                    {
                                        <a href="@resource.Url" target="_blank" rel="noopener">View</a>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(resource.FilePath))
                                    {
                                        <small>File: @Path.GetFileName(resource.FilePath)</small>
                                    }
                                    @if (resource.IsPhysicalResource)
                                    {
                                        <small>Physical resource</small>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(resource.SourceNote))
                                    {
                                        <small>@resource.SourceNote</small>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(resource.StudentInstructions))
                                    {
                                        <small>Student use: @resource.StudentInstructions</small>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(resource.NotesPrompt))
                                    {
                                        <small>Notes prompt: @resource.NotesPrompt</small>
                                    }
                                    @if (resource.EstimatedMinutes > 0)
                                    {
                                        <small>@resource.EstimatedMinutes minutes</small>
                                    }
                                </div>
                                @if (CanEdit)
                                {
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveResource(resourceIndex)">Delete</button>
                                }
                            </li>
                        }
                    </ul>
                }
            </section>

            <section class="form-section">
                <h2>Practice and Evidence</h2>
                <div class="section-heading-row">
                    <h3>Problem sets</h3>
                    @if (CanEdit)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleProblemSetForm">@ProblemSetToggleText()</button>
                    }
                </div>
                @if (lessonForm.ShowProblemSetForm && CanEdit)
                {
                    <div class="inline-entry-form">
                        <label class="form-label" for="lesson-problem-set-id">Problem set id</label>
                        <input id="lesson-problem-set-id" class="form-control" @bind="lessonForm.NewProblemSetId" />
                        <label class="form-label" for="lesson-problem-set-title">Title</label>
                        <input id="lesson-problem-set-title" class="form-control" @bind="lessonForm.NewProblemSetTitle" />
                        <label class="form-label" for="lesson-problem-set-minutes">Estimated minutes</label>
                        <input id="lesson-problem-set-minutes" class="form-control" type="number" min="0" @bind="lessonForm.NewProblemSetEstimatedMinutes" />
                        <label class="form-label" for="lesson-problem-prompt">Problem prompt</label>
                        <textarea id="lesson-problem-prompt" class="form-control" rows="3" @bind="lessonForm.NewProblemPrompt"></textarea>
                        <label class="form-label" for="lesson-problem-answer">Expected answer</label>
                        <textarea id="lesson-problem-answer" class="form-control" rows="3" @bind="lessonForm.NewProblemExpectedAnswer"></textarea>
                        <button class="btn btn-secondary mt-2" @onclick="AddProblemSet">Add problem set</button>
                    </div>
                }
                @if (lessonForm.ProblemSets.Count == 0)
                {
                    <p>No problem sets have been added.</p>
                }
                else
                {
                    <ul class="itemized-editor-list stacked-editor-list">
                        @for (var index = 0; index < lessonForm.ProblemSets.Count; index++)
                        {
                            var problemSetIndex = index;
                            var problemSet = lessonForm.ProblemSets[index];
                            <li>
                                <div class="itemized-editor-content">
                                    <strong>@problemSet.Title</strong>
                                    <small>@problemSet.ProblemSetId</small>
                                    @if (problemSet.EstimatedMinutes > 0)
                                    {
                                        <small>@problemSet.EstimatedMinutes minutes</small>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(problemSet.ProblemPrompt))
                                    {
                                        <small>Prompt: @problemSet.ProblemPrompt</small>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(problemSet.ExpectedAnswer))
                                    {
                                        <small>Expected answer: @problemSet.ExpectedAnswer</small>
                                    }
                                </div>
                                @if (CanEdit)
                                {
                                    <div class="module-order-actions">
                                        <button class="btn btn-outline-secondary btn-sm" disabled="@(problemSetIndex == 0)" @onclick="() => MoveProblemSet(problemSetIndex, -1)">Up</button>
                                        <button class="btn btn-outline-secondary btn-sm" disabled="@(problemSetIndex == lessonForm.ProblemSets.Count - 1)" @onclick="() => MoveProblemSet(problemSetIndex, 1)">Down</button>
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteProblemSet(problemSetIndex)">Delete</button>
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                }

                <div class="section-heading-row mt-3">
                    <h3>Portfolio connections</h3>
                    @if (CanEdit)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="TogglePortfolioConnectionForm">@PortfolioConnectionToggleText()</button>
                    }
                </div>
                @if (lessonForm.ShowPortfolioConnectionForm && CanEdit)
                {
                    <div class="inline-entry-form">
                        <label class="form-label" for="lesson-portfolio-section">Portfolio section</label>
                        <input id="lesson-portfolio-section" class="form-control" @bind="lessonForm.NewPortfolioSection" />
                        <label class="form-label" for="lesson-portfolio-artifact">Artifact title</label>
                        <input id="lesson-portfolio-artifact" class="form-control" @bind="lessonForm.NewPortfolioArtifactTitle" />
                        <label class="form-label" for="lesson-portfolio-purpose">Artifact purpose</label>
                        <textarea id="lesson-portfolio-purpose" class="form-control" rows="3" @bind="lessonForm.NewPortfolioArtifactPurpose"></textarea>
                        <ItemizedTextListEditor Title="Cross-course links" EntryLabel="Cross-course link" EmptyText="No cross-course links have been added." Items="lessonForm.NewPortfolioCrossCourseLinks" ItemsChanged="UpdateNewPortfolioCrossCourseLinks" />
                        <label class="form-label" for="lesson-portfolio-reuse">Reuse instructions</label>
                        <textarea id="lesson-portfolio-reuse" class="form-control" rows="3" @bind="lessonForm.NewPortfolioReuseInstructions"></textarea>
                        <button class="btn btn-secondary mt-2" @onclick="AddPortfolioConnection">Add portfolio connection</button>
                    </div>
                }
                @if (lessonForm.PortfolioConnections.Count == 0)
                {
                    <p>No portfolio connections have been added.</p>
                }
                else
                {
                    <ul class="itemized-editor-list stacked-editor-list">
                        @for (var index = 0; index < lessonForm.PortfolioConnections.Count; index++)
                        {
                            var connectionIndex = index;
                            var connection = lessonForm.PortfolioConnections[index];
                            <li>
                                <div class="itemized-editor-content">
                                    <strong>@connection.ArtifactTitle</strong>
                                    <small>@connection.PortfolioSection</small>
                                    @if (!string.IsNullOrWhiteSpace(connection.ArtifactPurpose))
                                    {
                                        <small>Purpose: @connection.ArtifactPurpose</small>
                                    }
                                    @if (connection.CrossCourseLinks.Count > 0)
                                    {
                                        <small>Links: @string.Join(", ", connection.CrossCourseLinks)</small>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(connection.ReuseInstructions))
                                    {
                                        <small>Reuse: @connection.ReuseInstructions</small>
                                    }
                                </div>
                                @if (CanEdit)
                                {
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeletePortfolioConnection(connectionIndex)">Delete</button>
                                }
                            </li>
                        }
                    </ul>
                }
                <ItemizedTextListEditor Title="Reflection prompts" EntryLabel="Reflection prompt" EmptyText="No reflection prompts have been added." Items="lessonForm.ReflectionPrompts" ItemsChanged="UpdateLessonReflectionPrompts" Disabled="@(!CanEdit)" AllowReorder="true" UseTextArea="true" />
            </section>

            <section class="form-section">
                <h2>Rubric and Parent Notes</h2>
                <div class="section-heading-row mt-3">
                    <h3>Rubric criteria</h3>
                    @if (CanEdit)
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleRubricCriterionForm">@RubricCriterionToggleText()</button>
                    }
                </div>
                @if (lessonForm.ShowRubricCriterionForm && CanEdit)
                {
                    <div class="inline-entry-form">
                        <label class="form-label" for="lesson-rubric-criterion">Criterion</label>
                        <input id="lesson-rubric-criterion" class="form-control" @bind="lessonForm.NewRubricCriterion" />
                        <label class="form-label" for="lesson-rubric-level4">Level 4</label>
                        <input id="lesson-rubric-level4" class="form-control" @bind="lessonForm.NewRubricLevel4" />
                        <label class="form-label" for="lesson-rubric-level3">Level 3</label>
                        <input id="lesson-rubric-level3" class="form-control" @bind="lessonForm.NewRubricLevel3" />
                        <label class="form-label" for="lesson-rubric-level2">Level 2</label>
                        <input id="lesson-rubric-level2" class="form-control" @bind="lessonForm.NewRubricLevel2" />
                        <label class="form-label" for="lesson-rubric-level1">Level 1</label>
                        <input id="lesson-rubric-level1" class="form-control" @bind="lessonForm.NewRubricLevel1" />
                        <button class="btn btn-secondary mt-2" @onclick="AddRubricCriterion">Add criterion</button>
                    </div>
                }
                @if (lessonForm.RubricCriteria.Count == 0)
                {
                    <p>No rubric criteria have been added.</p>
                }
                else
                {
                    <ul class="itemized-editor-list stacked-editor-list">
                        @for (var index = 0; index < lessonForm.RubricCriteria.Count; index++)
                        {
                            var criterionIndex = index;
                            var criterion = lessonForm.RubricCriteria[index];
                            <li>
                                <div class="itemized-editor-content">
                                    <strong>@criterion.Criterion</strong>
                                    <small>Level 4: @criterion.Level4</small>
                                    <small>Level 3: @criterion.Level3</small>
                                    <small>Level 2: @criterion.Level2</small>
                                    <small>Level 1: @criterion.Level1</small>
                                </div>
                                @if (CanEdit)
                                {
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteRubricCriterion(criterionIndex)">Delete</button>
                                }
                            </li>
                        }
                    </ul>
                }
                <label class="form-label" for="lesson-instructor-notes">Instructor overview</label>
                <textarea id="lesson-instructor-notes" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="lessonForm.InstructorOverview" @bind:after="AutoSaveLesson"></textarea>
                <ItemizedTextListEditor Title="Look fors" EntryLabel="Look for" EmptyText="No look fors have been added." Items="lessonForm.LookFors" ItemsChanged="UpdateLessonLookFors" Disabled="@(!CanEdit)" AllowReorder="true" />
                <ItemizedTextListEditor Title="Common issues" EntryLabel="Common issue" EmptyText="No common issues have been added." Items="lessonForm.CommonIssues" ItemsChanged="UpdateLessonCommonIssues" Disabled="@(!CanEdit)" AllowReorder="true" />
                <ItemizedTextListEditor Title="Suggested feedback" EntryLabel="Suggested feedback" EmptyText="No suggested feedback has been added." Items="lessonForm.SuggestedFeedback" ItemsChanged="UpdateLessonSuggestedFeedback" Disabled="@(!CanEdit)" AllowReorder="true" UseTextArea="true" />
            </section>
        </main>

        <aside class="workbench-support">
            <section class="form-section">
                <h2>Linked Assignments</h2>
                @if (module.Assignments.Count == 0)
                {
                    <p>No module assignments are available to link.</p>
                }
                else
                {
                    <ul class="itemized-editor-list stacked-editor-list">
                        @foreach (var assignment in module.Assignments.OrderBy(item => item.SequenceOrder))
                        {
                            <li>
                                <label class="form-check-label">
                                    <input class="form-check-input me-2" type="checkbox" disabled="@(!CanEdit)" checked="@lessonForm.LinkedAssignmentIds.Contains(assignment.Id)" @onchange="async _ => await ToggleLinkedAssignment(assignment.Id)" />
                                    @assignment.SequenceOrder. @assignment.Title
                                </label>
                            </li>
                        }
                    </ul>
                }
            </section>

            <section class="form-section">
                <div class="section-heading-row">
                    <h2>Module Lessons</h2>
                    <button class="btn btn-outline-primary btn-sm" @onclick="BackToModule">Back to module</button>
                </div>
                <ul class="module-nav-list">
                    @foreach (var item in module.Lessons.OrderBy(item => item.SequenceOrder))
                    {
                        <li>
                            <button class="@LessonButtonCss(item.Id)" @onclick="() => OpenLesson(item.Id)">
                                @item.SequenceOrder. @item.Title
                            </button>
                            @if (CanEdit)
                            {
                                <div class="module-order-actions">
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => MoveLesson(item.Id, -1)">Up</button>
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => MoveLesson(item.Id, 1)">Down</button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => OpenDeleteModal(item.Id)">Delete</button>
                                </div>
                            }
                        </li>
                    }
                </ul>
            </section>
        </aside>
    </div>

    @if (deleteLessonId.HasValue)
    {
        <div class="modal-backdrop-panel" role="presentation">
            <section class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="delete-lesson-heading">
                <h2 id="delete-lesson-heading">Delete lesson?</h2>
                <p>This permanently removes the selected lesson from the module. Type Delete to confirm.</p>
                <label class="form-label" for="delete-confirmation">Confirmation</label>
                <input id="delete-confirmation" class="form-control" @bind="deleteConfirmation" />
                <div class="modal-actions">
                    <button class="btn btn-outline-secondary" @onclick="CloseDeleteModal">Cancel</button>
                    <button class="btn btn-danger" disabled="@(!CanConfirmDelete())" @onclick="DeleteLesson">Delete</button>
                </div>
            </section>
        </div>
    }
}

@code {
    [Parameter]
    public Guid CourseId { get; set; }

    [Parameter]
    public Guid ModuleId { get; set; }

    [Parameter]
    public Guid LessonId { get; set; }

    private LearningModuleView? module;
    private LessonView? lesson;
    private LessonFormModel lessonForm = new();
    private readonly List<PageMessage> messages = [];
    private readonly Dictionary<string, string> fieldErrors = [];
    private Guid? deleteLessonId;
    private string deleteConfirmation = "";
    private IBrowserFile? pendingResourceFile;

    private bool CanEdit => Session.IsParentAdmin;

    protected override async Task OnParametersSetAsync()
    {
        await Refresh();
    }

    private async Task AutoSaveLesson()
    {
        if (!CanEdit || lesson is null || !ValidateLesson())
        {
            return;
        }

        await AutoSave(() => CourseService.UpdateLessonAsync(
            ParentUser(),
            new UpdateLessonCommand(
                CourseId,
                ModuleId,
                LessonId,
                lessonForm.Title,
                lessonForm.IntroductoryText,
                lessonForm.LinkedModuleObjective,
                lessonForm.Resources.Select(ToCommand).ToArray(),
                lessonForm.LessonType,
                lessonForm.EstimatedMinutes,
                lessonForm.SuggestedDays,
                lessonForm.DifficultyLevel,
                lessonForm.SubjectAreas.ToArray(),
                lessonForm.Tags.ToArray(),
                lessonForm.Prerequisites.ToArray(),
                lessonForm.LearningObjectives
                    .Select(objective => new LessonLearningObjectiveCommand(objective.ObjectiveId, objective.Text, objective.BloomLevel))
                    .ToArray(),
                lessonForm.StandardsAlignments
                    .Select(standard => new StandardsAlignmentCommand(standard.Framework, standard.Code, standard.Description))
                    .ToArray(),
                lessonForm.SuccessCriteria.ToArray(),
                lessonForm.LessonSteps
                    .Select((step, index) => new LessonStepCommand(index + 1, step.Title, step.StepType, step.Instructions, step.EstimatedMinutes, step.Required))
                    .ToArray(),
                lessonForm.ProblemSets
                    .Select(problemSet => new LessonProblemSetCommand(
                        problemSet.ProblemSetId,
                        problemSet.Title,
                        "",
                        problemSet.EstimatedMinutes,
                        string.IsNullOrWhiteSpace(problemSet.ProblemPrompt)
                            ? []
                            : [new LessonProblemCommand($"{problemSet.ProblemSetId}-problem-1", problemSet.ProblemPrompt, ProblemResponseType.WorkedSolution, problemSet.ExpectedAnswer, "", [], "")]))
                    .ToArray(),
                lessonForm.PortfolioConnections
                    .Select(connection => new LessonPortfolioConnectionCommand(
                        connection.PortfolioSection,
                        connection.ArtifactTitle,
                        connection.ArtifactPurpose,
                        connection.CrossCourseLinks.ToArray(),
                        connection.ReuseInstructions))
                    .ToArray(),
                BuildLessonRubricCommand(),
                lessonForm.ReflectionPrompts.ToArray(),
                new LessonInstructorNotesCommand(
                    lessonForm.InstructorOverview,
                    lessonForm.LookFors.ToArray(),
                    lessonForm.CommonIssues.ToArray(),
                    lessonForm.SuggestedFeedback.ToArray()),
                lessonForm.LinkedAssignmentIds.ToArray())));
    }

    private async Task MoveLesson(Guid lessonId, int direction)
    {
        if (!CanEdit || module is null)
        {
            return;
        }

        var lessons = module.Lessons.OrderBy(item => item.SequenceOrder).ToList();
        var index = lessons.FindIndex(item => item.Id == lessonId);
        var targetIndex = index + direction;
        if (index < 0 || targetIndex < 0 || targetIndex >= lessons.Count)
        {
            return;
        }

        (lessons[index], lessons[targetIndex]) = (lessons[targetIndex], lessons[index]);
        await Run(() => CourseService.ReorderLessonsAsync(
            ParentUser(),
            new ReorderLessonsCommand(CourseId, ModuleId, lessons.Select(item => item.Id).ToArray())));
        OpenLesson(lessonId);
    }

    private async Task DeleteLesson()
    {
        if (!deleteLessonId.HasValue)
        {
            return;
        }

        var deletingCurrent = LessonId == deleteLessonId.Value;
        await Run(() => CourseService.DeleteLessonAsync(
            ParentUser(),
            new DeleteLessonCommand(CourseId, ModuleId, deleteLessonId.Value, deleteConfirmation)));
        CloseDeleteModal();
        if (deletingCurrent)
        {
            var nextLessonId = module?.Lessons.OrderBy(item => item.SequenceOrder).FirstOrDefault()?.Id;
            NavigationManager.NavigateTo(nextLessonId.HasValue
                ? $"/courses/{CourseId}/modules/{ModuleId}/lessons/{nextLessonId.Value}"
                : $"/courses/{CourseId}/modules/{ModuleId}");
        }
    }

    private async Task Refresh()
    {
        module = await CourseService.GetModuleDetailAsync(CourseId, ModuleId);
        lesson = module?.Lessons.FirstOrDefault(item => item.Id == LessonId);
        lessonForm = lesson is null
            ? new LessonFormModel()
            : new LessonFormModel
            {
                Title = lesson.Title,
                IntroductoryText = lesson.IntroductoryText,
                LinkedModuleObjective = lesson.LinkedModuleObjective,
                LessonType = lesson.LessonType,
                EstimatedMinutes = lesson.EstimatedMinutes,
                SuggestedDays = lesson.SuggestedDays,
                DifficultyLevel = lesson.DifficultyLevel,
                SubjectAreas = lesson.SubjectAreas.ToList(),
                Tags = lesson.Tags.ToList(),
                Prerequisites = lesson.Prerequisites.ToList(),
                LearningObjectives = lesson.LearningObjectives
                    .Select(objective => new LessonObjectiveFormItem(objective.ObjectiveId, objective.Text, objective.BloomLevel))
                    .ToList(),
                StandardsAlignments = lesson.StandardsAlignments
                    .Select(standard => new StandardFormItem(standard.Framework, standard.Code, standard.Description))
                    .ToList(),
                SuccessCriteria = lesson.SuccessCriteria.ToList(),
                LessonSteps = lesson.LessonSteps
                    .OrderBy(step => step.StepOrder)
                    .Select(step => new LessonStepFormItem(step.Title, step.StepType, step.Instructions, step.EstimatedMinutes, step.Required))
                    .ToList(),
                ProblemSets = lesson.ProblemSets
                    .Select(problemSet => new LessonProblemSetFormItem(
                        problemSet.ProblemSetId,
                        problemSet.Title,
                        problemSet.EstimatedMinutes,
                        problemSet.Problems.FirstOrDefault()?.Prompt ?? "",
                        problemSet.Problems.FirstOrDefault()?.ExpectedAnswer ?? ""))
                    .ToList(),
                PortfolioConnections = lesson.PortfolioConnections
                    .Select(connection => new LessonPortfolioConnectionFormItem(
                        connection.PortfolioSection,
                        connection.ArtifactTitle,
                        connection.ArtifactPurpose,
                        connection.CrossCourseLinks.ToList(),
                        connection.ReuseInstructions))
                    .ToList(),
                RubricCriteria = lesson.Rubric?.Criteria
                    .Select(criteria => new RubricCriterionFormItem(criteria.Criterion, criteria.Level4, criteria.Level3, criteria.Level2, criteria.Level1))
                    .ToList() ?? [],
                ReflectionPrompts = lesson.ReflectionPrompts.ToList(),
                InstructorOverview = lesson.InstructorNotes?.Overview ?? "",
                LookFors = (lesson.InstructorNotes?.LookFors ?? []).ToList(),
                CommonIssues = (lesson.InstructorNotes?.CommonIssues ?? []).ToList(),
                SuggestedFeedback = (lesson.InstructorNotes?.SuggestedFeedback ?? []).ToList(),
                LinkedAssignmentIds = lesson.LinkedAssignmentIds.ToList(),
                Resources = lesson.Resources
                    .Select(resource => new LessonResourceFormItem(
                        resource.Name,
                        resource.Type,
                        resource.Url,
                        resource.FilePath,
                        resource.IsPhysicalResource,
                        resource.SourceNote,
                        resource.Required,
                        resource.EstimatedMinutes,
                        resource.StudentInstructions,
                        resource.NotesPrompt,
                        resource.Citation?.Title ?? "",
                        resource.Citation?.Publisher ?? "",
                        resource.Citation?.AccessedAtUtc,
                        resource.OfflineAvailable,
                        resource.License))
                    .ToList()
            };
    }

    private async Task Run(Func<Task<OperationResult>> action)
    {
        messages.Clear();
        fieldErrors.Clear();
        var result = await action();
        if (result.Succeeded)
        {
            messages.Add(new PageMessage("Saved.", "alert alert-success"));
            await Refresh();
            return;
        }

        messages.AddRange(result.Errors.Select(error => new PageMessage(error, "alert alert-danger")));
    }

    private async Task AutoSave(Func<Task<OperationResult>> action)
    {
        await Run(action);
    }

    private void OpenLesson(Guid lessonId)
    {
        NavigationManager.NavigateTo($"/courses/{CourseId}/modules/{ModuleId}/lessons/{lessonId}");
    }

    private void BackToModule()
    {
        NavigationManager.NavigateTo($"/courses/{CourseId}/modules/{ModuleId}");
    }

    private void OpenDeleteModal(Guid lessonId)
    {
        deleteLessonId = lessonId;
        deleteConfirmation = "";
    }

    private void CloseDeleteModal()
    {
        deleteLessonId = null;
        deleteConfirmation = "";
    }

    private bool CanConfirmDelete()
    {
        return string.Equals(deleteConfirmation, "Delete", StringComparison.Ordinal);
    }

    private string LessonButtonCss(Guid lessonId)
    {
        return lesson?.Id == lessonId
            ? "btn btn-primary btn-sm module-nav-button"
            : "btn btn-outline-secondary btn-sm module-nav-button";
    }

    private string ResourceToggleText()
    {
        return lessonForm.ShowResourceForm ? "Hide" : "Add";
    }

    private void ToggleResourceForm()
    {
        lessonForm.ShowResourceForm = !lessonForm.ShowResourceForm;
    }

    private void SelectResourceFile(InputFileChangeEventArgs eventArgs)
    {
        pendingResourceFile = eventArgs.File;
        if (string.IsNullOrWhiteSpace(lessonForm.NewResourceName))
        {
            lessonForm.NewResourceName = eventArgs.File.Name;
        }

        lessonForm.NewResourceType = LessonResourceType.File;
    }

    private async Task AddResource()
    {
        var name = lessonForm.NewResourceName.Trim();
        if (string.IsNullOrWhiteSpace(name))
        {
            return;
        }

        var filePath = pendingResourceFile is null ? "" : await SaveResourceFileAsync(pendingResourceFile);
        lessonForm.Resources.Add(new LessonResourceFormItem(
            name,
            lessonForm.NewResourceType,
            lessonForm.NewResourceUrl.Trim(),
            filePath,
            lessonForm.NewResourceIsPhysical || lessonForm.NewResourceType == LessonResourceType.PhysicalResource,
            lessonForm.NewResourceSourceNote.Trim(),
            lessonForm.NewResourceRequired,
            lessonForm.NewResourceEstimatedMinutes,
            lessonForm.NewResourceStudentInstructions.Trim(),
            lessonForm.NewResourceNotesPrompt.Trim(),
            "",
            "",
            null,
            false,
            ""));
        lessonForm.NewResourceName = "";
        lessonForm.NewResourceUrl = "";
        lessonForm.NewResourceIsPhysical = false;
        lessonForm.NewResourceSourceNote = "";
        lessonForm.NewResourceRequired = true;
        lessonForm.NewResourceEstimatedMinutes = 0;
        lessonForm.NewResourceStudentInstructions = "";
        lessonForm.NewResourceNotesPrompt = "";
        lessonForm.NewResourceType = LessonResourceType.Reading;
        pendingResourceFile = null;
        await AutoSaveLesson();
    }

    private async Task<string> SaveResourceFileAsync(IBrowserFile file)
    {
        var safeFileName = string.Join("_", file.Name.Split(Path.GetInvalidFileNameChars(), StringSplitOptions.RemoveEmptyEntries));
        var folder = Path.Combine(AppDataPaths.DataRoot, "files", "curriculum", "lesson-resources", CourseId.ToString("N"), ModuleId.ToString("N"), LessonId.ToString("N"));
        Directory.CreateDirectory(folder);
        var path = Path.Combine(folder, $"{Guid.NewGuid():N}_{safeFileName}");
        await using var source = file.OpenReadStream(maxAllowedSize: 25 * 1024 * 1024);
        await using var target = File.Create(path);
        await source.CopyToAsync(target);
        return path;
    }

    private async Task RemoveResource(int index)
    {
        if (index >= 0 && index < lessonForm.Resources.Count)
        {
            lessonForm.Resources.RemoveAt(index);

    private Guid FirstSectionId()
    {
        return workspace?.Design.Sections
            .Where(item => item.IncludeInPortfolio)
            .OrderBy(item => item.SortOrder)
            .Select(item => item.SectionId)
            .FirstOrDefault() ?? Guid.Empty;
    }

    private static bool IsDraft(PortfolioDraftItemView item)
    {
        return item.Status == PortfolioDraftStatus.Draft;
    }

    private static IReadOnlyList<string> SplitSkills(string value)
    {
        return value
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Where(item => !string.IsNullOrWhiteSpace(item))
            .ToArray();
    }

    private static string DesignStatusText(PortfolioDesignStatus status)
    {
        return status switch
        {
            PortfolioDesignStatus.SubmittedForReview => "Submitted for review",
            PortfolioDesignStatus.NeedsRevision => "Needs revision",
            PortfolioDesignStatus.ReadyForApproval => "Ready for approval",
            PortfolioDesignStatus.Approved => "Approved",
            _ => "Working"
        };
    }

    private static string SectionStatusText(PortfolioSectionStatus status)
    {
        return status switch
        {
            PortfolioSectionStatus.SuggestionsOpen => "Suggestions open",
            PortfolioSectionStatus.Resolved => "Resolved",
            PortfolioSectionStatus.Excluded => "Excluded",
            _ => "No suggestions"
        };
    }

    private static string ItemStatusText(PortfolioDraftStatus status)
    {
        return status switch
        {
            PortfolioDraftStatus.SubmittedForReview => "In review",
            PortfolioDraftStatus.NeedsRevision => "Needs revision",
            PortfolioDraftStatus.ParentApproved => "Approved",
            PortfolioDraftStatus.Excluded => "Excluded",
            _ => "Working"
        };
    }

    private static string AssignmentSuggestionStatusText(PortfolioAssignmentSuggestionStatus status)
    {
        return status switch
        {
            PortfolioAssignmentSuggestionStatus.EvidenceAccepted => "Evidence accepted",
            PortfolioAssignmentSuggestionStatus.NotIncluded => "Not included",
            _ => "Suggested"
        };
    }


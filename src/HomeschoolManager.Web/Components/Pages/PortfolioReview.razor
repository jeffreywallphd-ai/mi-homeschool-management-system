    private async Task OnExportSnapshotChangedAsync(ChangeEventArgs args)
    {
        selectedExportSnapshotId = args.Value?.ToString() ?? "";
        await RefreshExportPreviewAsync();
    }

    private async Task RefreshExportPreviewAsync(bool addMessages = true)
    {
        if (workspace is null || Session.CurrentUser is null || workspace.Design.ApprovalSnapshots.Count == 0)
        {
            exportPreview = null;
            return;
        }

        if (!Guid.TryParse(selectedExportSnapshotId, out var snapshotId) ||
            workspace.Design.ApprovalSnapshots.All(item => item.ApprovalSnapshotId != snapshotId))
        {
            snapshotId = workspace.Design.ApprovalSnapshots
                .OrderByDescending(item => item.ApprovedAtUtc)
                .Select(item => item.ApprovalSnapshotId)
                .First();
            selectedExportSnapshotId = snapshotId.ToString();
        }

        var result = await PortfolioExports.GetExportPreviewAsync(Session.CurrentUser, workspace.StudentId, snapshotId);
        if (result.Succeeded)
        {
            exportPreview = result.Value;
            if (addMessages)
            {
                messages.Clear();
                lastActionSucceeded = true;
                messages.Add("Approved portfolio export preview refreshed.");
            }
        }
        else
        {
            exportPreview = null;
            if (addMessages)
            {
                messages.Clear();
                messages.AddRange(result.Errors);
            }
        }
    }

    private async Task DownloadArchivePacketAsync()
    {
        if (workspace is null || Session.CurrentUser is null)
        {
            return;
        }

        messages.Clear();
        lastActionSucceeded = false;
        var snapshotId = Guid.TryParse(selectedExportSnapshotId, out var parsedSnapshotId)
            ? parsedSnapshotId
            : (Guid?)null;
        var result = await PortfolioExports.CreateArchivePacketAsync(
            Session.CurrentUser,
            new CreatePortfolioExportCommand(workspace.StudentId, snapshotId));
        if (!result.Succeeded || result.Value is null)
        {
            messages.AddRange(result.Errors);
            return;
        }

        await JS.InvokeVoidAsync(
            "homeschoolFiles.downloadBase64",
            result.Value.FileName,
            result.Value.ContentType,
            Convert.ToBase64String(result.Value.Content));
        exportPreview = PortfolioExportPreviewFromDownload(result.Value);
        lastActionSucceeded = true;
        messages.Add($"Downloaded {result.Value.FileName}.");
    }

    private async Task RunAsync(Func<Task> action)
    {
        messages.Clear();
        lastActionSucceeded = false;
        await action();
    }

    private async Task HandleResultAsync(OperationResult result, string successMessage)
    {
        if (result.Succeeded)
        {
            lastActionSucceeded = true;
            messages.Add(successMessage);
            await LoadAsync(workspace?.StudentId);
        }
        else
        {
            messages.AddRange(result.Errors);
        }
    }

    private async Task HandleResultAsync<T>(OperationResult<T> result, string successMessage)
    {
        if (result.Succeeded)
        {
            lastActionSucceeded = true;
            messages.Add(successMessage);
            await LoadAsync(workspace?.StudentId);
        }
        else
        {
            messages.AddRange(result.Errors);
        }
    }

    private void SyncEditModels()
    {
        if (workspace is null)
        {
            designEdit = new PortfolioDesignEditModel();
            sectionEdits.Clear();
            itemEdits.Clear();
            evidenceAdds.Clear();
            candidateAdds.Clear();
            return;
        }

        designEdit = PortfolioDesignEditModel.From(workspace.Design);
        foreach (var section in workspace.Design.Sections)
        {
            sectionEdits[section.SectionId] = PortfolioSectionEditModel.From(section);
        }

        foreach (var item in workspace.Items)
        {
            itemEdits[item.PortfolioDraftItemId] = PortfolioItemEditModel.From(item);
        }

        foreach (var evidence in workspace.AvailableEvidence)
        {
            if (!evidenceAdds.ContainsKey(evidence.EvidenceRecordId))
            {
                evidenceAdds[evidence.EvidenceRecordId] = new EvidenceAddModel { SectionId = FirstSectionId() };
            }
        }

        foreach (var candidate in workspace.AssignmentCandidates)
        {
            if (!candidateAdds.ContainsKey(candidate.EvidenceRecordId))
            {
                candidateAdds[candidate.EvidenceRecordId] = new CandidateAddModel
                {
                    SectionId = FirstSectionId(),
                    ParentReviewNotes = candidate.ParentNotes
                };
            }
        }

        if (workspace.Design.ApprovalSnapshots.Count == 0)
        {
            selectedExportSnapshotId = "";
            exportPreview = null;
        }
        else if (!Guid.TryParse(selectedExportSnapshotId, out var selectedSnapshot) ||
            workspace.Design.ApprovalSnapshots.All(item => item.ApprovalSnapshotId != selectedSnapshot))
        {
            selectedExportSnapshotId = workspace.Design.ApprovalSnapshots
                .OrderByDescending(item => item.ApprovedAtUtc)
                .Select(item => item.ApprovalSnapshotId.ToString())
                .First();
        }
    }

    private static PortfolioExportPreview PortfolioExportPreviewFromDownload(PortfolioExportDownloadFile download)
    {
        var manifest = download.Manifest;
        return new PortfolioExportPreview(
            manifest.StudentId,
            manifest.StudentName,
            manifest.ApprovalSnapshotId,
            manifest.SnapshotVersion,
            manifest.PortfolioTitle,
            manifest.ApprovedAtUtc,
            manifest.ApprovedBy,
            download.FileName,
            "portfolio.html",
            "manifest.json",
            "manifest.md",
            manifest.SectionCount,
            manifest.ItemCount,
            manifest.AttachedFileCount,
            manifest.MissingFileCount,
            manifest.Sections
                .Select(section => new PortfolioExportSectionPreview(section.SectionId, section.Heading, section.SortOrder, section.Items.Count))
                .ToArray(),
            new PortfolioPreviewView(
                manifest.StudentId,
                manifest.StudentName,
                manifest.PortfolioTitle,
                "",
                PortfolioDesignStatus.Approved,
                manifest.SnapshotVersion,
                manifest.ApprovedAtUtc,
                [],
                manifest.Sections
                    .OrderBy(section => section.SortOrder)
                    .Select(section => new PortfolioPreviewSectionView(
                        section.SectionId,
                        section.Heading,
                        section.Introduction,
                        section.SortOrder,
                        section.Items
                            .OrderBy(item => item.SortOrder)
                            .Select(item => new PortfolioPreviewItemView(
                                item.PortfolioDraftItemId,
                                item.EvidenceRecordId,
                                item.DisplayTitle,
                                item.CourseTitle,
                                item.ModuleTitle,
                                item.AssignmentTitle,
                                item.StudentReflection,
                                item.ChosenReason,
                                item.SkillsShown,
                                item.ParentReviewNotes,
                                item.Files.Count,
                                item.SortOrder))
                            .ToArray()))
                    .ToArray()),
            manifest.Warnings);
    }

    private IEnumerable<PortfolioDraftItemView> ItemsForSection(Guid sectionId)
    {
        if (workspace is null)
        {
            return Array.Empty<PortfolioDraftItemView>();
        }

        return workspace.Items
            .Where(item => item.PortfolioSectionId == sectionId)
            .OrderBy(item => item.SortOrder)
            .ThenBy(item => item.DisplayTitle);
    }

    private IReadOnlyList<PortfolioSuggestionView> OpenSuggestionsFor(PortfolioSuggestionTargetType targetType, Guid? targetId)
    {
        return workspace?.Design.Suggestions
            .Where(item => item.TargetType == targetType)
            .Where(item => item.TargetId == targetId)
            .Where(item => item.Status == PortfolioSuggestionStatus.Open)
            .OrderByDescending(item => item.CreatedAtUtc)
            .ToArray() ?? [];
    }


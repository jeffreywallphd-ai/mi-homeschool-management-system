@page "/portfolio"
@rendermode InteractiveServer
@using HomeschoolManager.Application.Common
@using HomeschoolManager.Application.Portfolio
@using HomeschoolManager.Domain.Submissions
@using HomeschoolManager.Web.Services
@inject PortfolioService Portfolio
@inject PortfolioExportService PortfolioExports
@inject SessionState Session
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Portfolio Review</PageTitle>

@if (!canView)
{
    <h1>Portfolio Review</h1>
    <div class="alert alert-warning">Sign in as parent/admin to review portfolio designs.</div>
}
else if (workspace is null)
{
    <div class="page-header-bar">
        <div>
            <span class="hm-icon-tile" aria-hidden="true">
                <img class="hm-icon-lg" src="icons/hm/svg/currentcolor/form-course-description-document.svg" alt="" />
            </span>
            <h1>Portfolio Review</h1>
            <p>Review portfolio designs and approve the family portfolio packet preview.</p>
        </div>
        <a class="btn btn-outline-primary" href="/">Back to dashboard</a>
    </div>

    @foreach (var message in messages)
    {
        <div class="alert alert-warning">@message</div>
    }
}
else
{
    <div class="page-header-bar">
        <div>
            <span class="hm-icon-tile" aria-hidden="true">
                <img class="hm-icon-lg" src="icons/hm/svg/currentcolor/form-course-description-document.svg" alt="" />
            </span>
            <h1>Portfolio Review</h1>
            <p>@ReviewPostureText</p>
        </div>
        <a class="btn btn-outline-primary" href="/">Back to dashboard</a>
    </div>

    <div class="gradebook-selector-bar hm-card portfolio-selector-bar">
        <div>
            <label class="form-label" for="portfolio-student">Student</label>
            <select id="portfolio-student" class="form-select" value="@selectedStudentId" @onchange="OnStudentChangedAsync">
                @foreach (var student in workspace.Students)
                {
                    <option value="@student.StudentId">@student.Name</option>
                }
            </select>
        </div>
        <div>
            <label class="form-label">Portfolio status</label>
            <div class="portfolio-status-display">
                <span class="submission-status-pill">@DesignStatusText(workspace.Design.Status)</span>
                <span>Version @workspace.Design.Version</span>
            </div>
        </div>
    </div>

    @foreach (var message in messages)
    {
        <div class="alert @(lastActionSucceeded ? "alert-success" : "alert-warning")">@message</div>
    }

    <section class="dashboard-metrics" aria-label="Portfolio review summary">
        <article class="hm-card dashboard-metric-card">
            <img class="hm-icon" src="icons/hm/svg/purple/form-course-description-document.svg" alt="" aria-hidden="true" />
            <span>Sections</span>
            <strong>@workspace.Design.Sections.Count(item => item.IncludeInPortfolio)</strong>
        </article>
        <article class="hm-card dashboard-metric-card">
            <img class="hm-icon" src="icons/hm/svg/purple/form-assignment-clipboard.svg" alt="" aria-hidden="true" />
            <span>Portfolio items</span>
            <strong>@workspace.Items.Count(item => item.IncludeInDraft && item.Status != PortfolioDraftStatus.Excluded)</strong>
        </article>
        <article class="hm-card dashboard-metric-card">
            <img class="hm-icon" src="icons/hm/svg/purple/status-alert-triangle.svg" alt="" aria-hidden="true" />
            <span>Open suggestions</span>
            <strong>@OpenSuggestionCount</strong>
        </article>
        <article class="hm-card dashboard-metric-card">
            <img class="hm-icon" src="icons/hm/svg/purple/metric-credit-award.svg" alt="" aria-hidden="true" />
            <span>Approved snapshots</span>
            <strong>@workspace.Design.ApprovalSnapshots.Count</strong>
        </article>
    </section>

    <div class="dashboard-grid portfolio-review-grid">
        <main class="dashboard-main">
            <section class="hm-card dashboard-card portfolio-editor-card">
                <div class="section-heading-row">
                    <div>
                        <h2>Portfolio Design</h2>
                        <p class="form-text">Use direct edits when needed; suggestions are best for guiding older students.</p>
                    </div>
                    <button class="btn btn-outline-primary" type="button" @onclick="SaveDesignAsync">Save design</button>
                </div>

                <div class="two-column-form-grid">
                    <div>
                        <label class="form-label" for="portfolio-title">Title <span class="required-marker">*</span></label>
                        <input id="portfolio-title" class="form-control" @bind="designEdit.Title" />
                    </div>
                    <div>
                        <label class="form-label" for="portfolio-purpose">Purpose</label>
                        <input id="portfolio-purpose" class="form-control" @bind="designEdit.Purpose" />
                    </div>
                </div>

                @foreach (var narrative in designEdit.Narratives.OrderBy(item => item.SortOrder))
                {
                    var suggestionEdit = SuggestionEditFor(PortfolioSuggestionTargetType.Narrative, narrative.NarrativeId);
                    <div class="portfolio-review-block">
                        <label class="form-label" for="@($"narrative-{narrative.NarrativeId}")">@narrative.Prompt</label>
                        <textarea id="@($"narrative-{narrative.NarrativeId}")" class="form-control" rows="4" @bind="narrative.Response"></textarea>
                        <div class="portfolio-suggestion-editor">
                            <label class="form-label" for="@($"narrative-suggestion-{narrative.NarrativeId}")">Suggestion for this narrative</label>
                            <textarea id="@($"narrative-suggestion-{narrative.NarrativeId}")" class="form-control" rows="3" @bind="suggestionEdit.Text"></textarea>
                            <button class="btn btn-outline-primary btn-sm" type="button" @onclick="() => AddSuggestionAsync(PortfolioSuggestionTargetType.Narrative, narrative.NarrativeId)">Save suggestion</button>
                        </div>
                        <OpenSuggestionList Suggestions="OpenSuggestionsFor(PortfolioSuggestionTargetType.Narrative, narrative.NarrativeId)" OnResolve="ResolveSuggestionAsync" />
                    </div>
                }
            </section>

            <section class="hm-card dashboard-card portfolio-editor-card">
                <div class="section-heading-row">
                    <div>
                        <h2>Sections and Items</h2>
                        <p class="form-text">Review section structure, item placement, reflections, and source context.</p>
                    </div>
                    <span class="submission-status-pill">@workspace.Items.Count total items</span>
                </div>

                <div class="inline-entry-form portfolio-add-section">
                    <div class="two-column-form-grid">
                        <div>
                            <label class="form-label" for="new-section-heading">New section heading</label>
                            <input id="new-section-heading" class="form-control" @bind="newSectionHeading" />
                        </div>
                        <div>
                            <label class="form-label" for="new-section-intro">Introduction</label>
                            <input id="new-section-intro" class="form-control" @bind="newSectionIntroduction" />
                        </div>
                    </div>
                    <button class="btn btn-outline-primary" type="button" @onclick="AddSectionAsync">Add section</button>
                </div>

                <div class="portfolio-section-stack">
                    @foreach (var portfolioSection in workspace.Design.Sections.OrderBy(item => item.SortOrder))
                    {
                        var sectionEdit = SectionEditFor(portfolioSection);
                        var sectionSuggestion = SuggestionEditFor(PortfolioSuggestionTargetType.Section, portfolioSection.SectionId);
                        var sectionItems = ItemsForSection(portfolioSection.SectionId).ToArray();
                        <article class="portfolio-section-card @(portfolioSection.IncludeInPortfolio ? "" : "portfolio-section-muted")">
                            <div class="section-heading-row portfolio-section-heading">
                                <div>
                                    <h3>@portfolioSection.Heading</h3>
                                    <small>@SectionStatusText(portfolioSection.Status) | @sectionItems.Length items</small>
                                </div>
                                <span class="student-grade-pill">@portfolioSection.SortOrder</span>
                            </div>

                            <div class="inline-entry-form">
                                <div class="two-column-form-grid">
                                    <div>
                                        <label class="form-label" for="@($"portfolio-section-heading-{portfolioSection.SectionId}")">Heading</label>
                                        <input id="@($"portfolio-section-heading-{portfolioSection.SectionId}")" class="form-control" @bind="sectionEdit.Heading" />
                                    </div>
                                    <div>
                                        <label class="form-label" for="@($"portfolio-section-order-{portfolioSection.SectionId}")">Order</label>
                                        <input id="@($"portfolio-section-order-{portfolioSection.SectionId}")" class="form-control" type="number" min="0" @bind="sectionEdit.SortOrder" />
                                    </div>
                                </div>
                                <label class="form-label" for="@($"portfolio-section-intro-{portfolioSection.SectionId}")">Introduction</label>
                                <textarea id="@($"portfolio-section-intro-{portfolioSection.SectionId}")" class="form-control" rows="3" @bind="sectionEdit.Introduction"></textarea>
                                <div class="checkbox-row">
                                    <input id="@($"portfolio-section-include-{portfolioSection.SectionId}")" class="form-check-input" type="checkbox" @bind="sectionEdit.IncludeInPortfolio" />
                                    <label class="form-check-label" for="@($"portfolio-section-include-{portfolioSection.SectionId}")">Include this section</label>
                                </div>
                                <button class="btn btn-outline-primary" type="button" @onclick="() => SaveSectionAsync(portfolioSection.SectionId)">Save section</button>
                            </div>

                            <div class="portfolio-suggestion-editor">
                                <label class="form-label" for="@($"portfolio-section-suggestion-{portfolioSection.SectionId}")">Suggestion for this section</label>
                                <textarea id="@($"portfolio-section-suggestion-{portfolioSection.SectionId}")" class="form-control" rows="3" @bind="sectionSuggestion.Text"></textarea>
                                <button class="btn btn-outline-primary btn-sm" type="button" @onclick="() => AddSuggestionAsync(PortfolioSuggestionTargetType.Section, portfolioSection.SectionId)">Save suggestion</button>
                            </div>
                            <OpenSuggestionList Suggestions="OpenSuggestionsFor(PortfolioSuggestionTargetType.Section, portfolioSection.SectionId)" OnResolve="ResolveSuggestionAsync" />

                            @if (sectionItems.Length == 0)
                            {
                                <p class="student-muted">No evidence is placed in this section yet.</p>
                            }
                            else
                            {
                                <div class="portfolio-item-stack">
                                    @foreach (var item in sectionItems)
                                    {
                                        var itemEdit = ItemEditFor(item);
                                        var itemSuggestion = SuggestionEditFor(PortfolioSuggestionTargetType.Item, item.PortfolioDraftItemId);
                                        <article class="portfolio-item-card">
                                            <div class="student-card-heading">
                                                <div>
                                                    <h4>@item.DisplayTitle</h4>
                                                    <small>@item.StudentName | @item.CourseTitle | @item.AssignmentTitle</small>
                                                </div>
                                                <span class="student-grade-pill">@ItemStatusText(item.Status)</span>
                                            </div>

                                            <dl class="student-detail-facts">
                                                <div>
                                                    <dt>Files</dt>
                                                    <dd>@item.FileCount</dd>
                                                </div>
                                                <div>
                                                    <dt>Order</dt>
                                                    <dd>@item.SortOrder</dd>
                                                </div>
                                                <div>
                                                    <dt>Included</dt>
                                                    <dd>@(item.IncludeInDraft ? "Yes" : "No")</dd>
                                                </div>
                                            </dl>

                                            <div class="inline-entry-form">
                                                <div class="two-column-form-grid">
                                                    <div>
                                                        <label class="form-label" for="@($"item-title-{item.PortfolioDraftItemId}")">Display title</label>
                                                        <input id="@($"item-title-{item.PortfolioDraftItemId}")" class="form-control" @bind="itemEdit.DisplayTitle" />
                                                    </div>
                                                    <div>
                                                        <label class="form-label" for="@($"item-section-{item.PortfolioDraftItemId}")">Section</label>
                                                        <select id="@($"item-section-{item.PortfolioDraftItemId}")" class="form-select" @bind="itemEdit.PortfolioSectionId">
                                                            @foreach (var option in workspace.Design.Sections.Where(item => item.IncludeInPortfolio).OrderBy(item => item.SortOrder))
                                                            {
                                                                <option value="@option.SectionId">@option.Heading</option>
                                                            }
                                                        </select>
                                                    </div>
                                                    <div>
                                                        <label class="form-label" for="@($"item-skills-{item.PortfolioDraftItemId}")">Skills shown</label>
                                                        <input id="@($"item-skills-{item.PortfolioDraftItemId}")" class="form-control" @bind="itemEdit.SkillsShownText" />
                                                    </div>
                                                    <div>
                                                        <label class="form-label" for="@($"item-order-{item.PortfolioDraftItemId}")">Order</label>
                                                        <input id="@($"item-order-{item.PortfolioDraftItemId}")" class="form-control" type="number" min="0" @bind="itemEdit.SortOrder" />
                                                    </div>
                                                </div>
                                                <label class="form-label" for="@($"item-reflection-{item.PortfolioDraftItemId}")">Student reflection</label>
                                                <textarea id="@($"item-reflection-{item.PortfolioDraftItemId}")" class="form-control" rows="3" @bind="itemEdit.StudentReflection"></textarea>
                                                <label class="form-label" for="@($"item-reason-{item.PortfolioDraftItemId}")">Reason for inclusion</label>
                                                <textarea id="@($"item-reason-{item.PortfolioDraftItemId}")" class="form-control" rows="3" @bind="itemEdit.ChosenReason"></textarea>
                                                <div class="checkbox-row">
                                                    <input id="@($"item-include-{item.PortfolioDraftItemId}")" class="form-check-input" type="checkbox" @bind="itemEdit.IncludeInDraft" />
                                                    <label class="form-check-label" for="@($"item-include-{item.PortfolioDraftItemId}")">Include in approved design</label>
                                                </div>
                                                <button class="btn btn-outline-primary" type="button" @onclick="() => SaveItemAsync(item.PortfolioDraftItemId)">Save item</button>
                                            </div>

                                            <div class="portfolio-suggestion-editor">
                                                <label class="form-label" for="@($"item-suggestion-{item.PortfolioDraftItemId}")">Suggestion for this item</label>
                                                <textarea id="@($"item-suggestion-{item.PortfolioDraftItemId}")" class="form-control" rows="3" @bind="itemSuggestion.Text"></textarea>
                                                <button class="btn btn-outline-primary btn-sm" type="button" @onclick="() => AddSuggestionAsync(PortfolioSuggestionTargetType.Item, item.PortfolioDraftItemId)">Save suggestion</button>
                                            </div>
                                            <OpenSuggestionList Suggestions="OpenSuggestionsFor(PortfolioSuggestionTargetType.Item, item.PortfolioDraftItemId)" OnResolve="ResolveSuggestionAsync" />

                                            <div class="inline-entry-form">
                                                <label class="form-label" for="@($"item-review-notes-{item.PortfolioDraftItemId}")">Parent item notes</label>
                                                <textarea id="@($"item-review-notes-{item.PortfolioDraftItemId}")" class="form-control" rows="3" @bind="itemEdit.ParentReviewNotes"></textarea>
                                                <div class="review-action-row">
                                                    <button type="button" class="btn btn-primary" disabled="@IsDraft(item)" @onclick="() => ReviewItemAsync(item.PortfolioDraftItemId, PortfolioDraftStatus.ParentApproved)">Approve item</button>
                                                    <button type="button" class="btn btn-outline-primary" disabled="@IsDraft(item)" @onclick="() => ReviewItemAsync(item.PortfolioDraftItemId, PortfolioDraftStatus.NeedsRevision)">Needs revision</button>
                                                    <button type="button" class="btn btn-outline-danger" disabled="@IsDraft(item)" @onclick="() => ReviewItemAsync(item.PortfolioDraftItemId, PortfolioDraftStatus.Excluded)">Exclude</button>
                                                    <a class="btn btn-outline-secondary" href="@($"submissions/{item.SubmissionId}")">Open submission</a>
                                                </div>
                                            </div>
                                        </article>
                                    }
                                </div>
                            }
                        </article>
                    }
                </div>
            </section>
        </main>

        <aside class="dashboard-support portfolio-support-column">
            <section class="hm-card dashboard-card">
                <h2>Review Actions</h2>
                <p>@ReviewPostureText</p>
                <div class="portfolio-suggestion-editor">
                    <label class="form-label" for="portfolio-suggestion">Overall suggestion</label>
                    <textarea id="portfolio-suggestion" class="form-control" rows="3" @bind="portfolioSuggestionText"></textarea>
                    <button class="btn btn-outline-primary" type="button" @onclick="() => AddSuggestionAsync(PortfolioSuggestionTargetType.Portfolio, null)">Save suggestion</button>
                </div>
                <OpenSuggestionList Suggestions="OpenSuggestionsFor(PortfolioSuggestionTargetType.Portfolio, null)" OnResolve="ResolveSuggestionAsync" />
                <label class="form-label" for="revision-notes">Revision request</label>
                <textarea id="revision-notes" class="form-control" rows="3" @bind="revisionNotes"></textarea>
                <div class="review-action-row">
                    <button class="btn btn-outline-primary" type="button" @onclick="RequestRevisionAsync">Request revision</button>
                    <button class="btn btn-primary" type="button" @onclick="ApproveDesignAsync">Approve portfolio design</button>
                </div>
            </section>

            <section class="hm-card dashboard-card">
                <div class="section-heading-row">
                    <h2>Approved Portfolio</h2>
                    <span class="submission-status-pill">@workspace.Design.ApprovalSnapshots.Count snapshot@(workspace.Design.ApprovalSnapshots.Count == 1 ? "" : "s")</span>
                </div>
                @if (workspace.Design.ApprovalSnapshots.Count == 0)
                {
                    <p>Approve a portfolio design before creating an official archive packet.</p>
                }
                else
                {
                    <label class="form-label" for="approved-snapshot">Approved snapshot</label>
                    <select id="approved-snapshot" class="form-select" value="@selectedExportSnapshotId" @onchange="OnExportSnapshotChangedAsync">
                        @foreach (var snapshot in workspace.Design.ApprovalSnapshots.OrderByDescending(item => item.ApprovedAtUtc))
                        {
                            <option value="@snapshot.ApprovalSnapshotId">Version @snapshot.Version | @snapshot.ApprovedAtUtc.ToLocalTime().ToString("g")</option>
                        }
                    </select>

                    @if (exportPreview is not null)
                    {
                        <div class="portfolio-export-summary">
                            <div>
                                <span>Sections</span>
                                <strong>@exportPreview.SectionCount</strong>
                            </div>
                            <div>
                                <span>Items</span>
                                <strong>@exportPreview.ItemCount</strong>
                            </div>
                            <div>
                                <span>Files</span>
                                <strong>@exportPreview.AttachedFileCount</strong>
                            </div>
                            <div>
                                <span>Missing</span>
                                <strong>@exportPreview.MissingFileCount</strong>
                            </div>
                        </div>
                        <p class="form-text">Exports use the approved snapshot and do not include later draft edits.</p>
                        @if (exportPreview.Warnings.Count > 0)
                        {
                            <div class="alert alert-warning">
                                @foreach (var warning in exportPreview.Warnings)
                                {
                                    <div>@warning</div>
                                }
                            </div>
                        }
                        <div class="portfolio-approved-preview-frame">
                            <PortfolioPreview Preview="exportPreview.Preview" />
                        </div>
                    }

                    <div class="review-action-row">
                        <button class="btn btn-outline-primary" type="button" @onclick="() => RefreshExportPreviewAsync()">Refresh preview</button>
                        <button class="btn btn-primary" type="button" @onclick="DownloadArchivePacketAsync">Download archive packet</button>
                    </div>
                }
            </section>

            <section class="hm-card dashboard-card">
                <div class="section-heading-row">
                    <h2>Accepted Evidence</h2>
                    <span class="submission-status-pill">@workspace.AvailableEvidence.Count(item => !item.AlreadyAdded) available</span>
                </div>
                <div class="portfolio-suggestion-list">
                    @foreach (var evidence in workspace.AvailableEvidence.Where(item => !item.AlreadyAdded).Take(6))
                    {
                        var add = EvidenceAddFor(evidence);
                        <article class="portfolio-mini-card">
                            <strong>@evidence.Title</strong>
                            <small>@evidence.CourseTitle | @evidence.AssignmentTitle</small>
                            <select class="form-select" @bind="add.SectionId">
                                @foreach (var sectionOption in workspace.Design.Sections.Where(item => item.IncludeInPortfolio).OrderBy(item => item.SortOrder))
                                {
                                    <option value="@sectionOption.SectionId">@sectionOption.Heading</option>
                                }
                            </select>
                            <button class="btn btn-outline-primary btn-sm" type="button" @onclick="() => AddEvidenceAsync(evidence.EvidenceRecordId)">Add evidence</button>
                        </article>
                    }
                </div>
            </section>

            <section class="hm-card dashboard-card">
                <div class="section-heading-row">
                    <h2>Assignment Candidates</h2>
                    <span class="submission-status-pill">@PendingAssignmentCandidateCount pending</span>
                </div>
                @if (workspace.AssignmentCandidates.Count == 0)
                {
                    <p>No accepted assignments are marked as portfolio candidates yet.</p>
                }
                else
                {
                    <div class="portfolio-suggestion-list">
                        @foreach (var candidate in workspace.AssignmentCandidates)
                        {
                            var candidateAdd = CandidateAddFor(candidate);
                            <article class="portfolio-mini-card">
                                <strong>@candidate.Title</strong>
                                <small>@candidate.CourseTitle | @candidate.AssignmentTitle</small>
                                @if (candidate.PortfolioDraftStatus.HasValue)
                                {
                                    <span class="submission-status-pill">@ItemStatusText(candidate.PortfolioDraftStatus.Value)</span>
                                }
                                else
                                {
                                    <select class="form-select" @bind="candidateAdd.SectionId">
                                        @foreach (var sectionOption in workspace.Design.Sections.Where(item => item.IncludeInPortfolio).OrderBy(item => item.SortOrder))
                                        {
                                            <option value="@sectionOption.SectionId">@sectionOption.Heading</option>
                                        }
                                    </select>
                                    <textarea class="form-control" rows="2" @bind="candidateAdd.ParentReviewNotes"></textarea>
                                    <button class="btn btn-outline-primary btn-sm" type="button" @onclick="() => AcceptCandidateAsync(candidate.EvidenceRecordId)">Accept candidate</button>
                                }
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="hm-card dashboard-card">
                <div class="section-heading-row">
                    <h2>Assignment Ideas</h2>
                    <span class="submission-status-pill">@workspace.AssignmentSuggestions.Count suggested</span>
                </div>
                @if (workspace.AssignmentSuggestions.Count == 0)
                {
                    <p>No planned assignment suggestions yet.</p>
                }
                else
                {
                    <div class="portfolio-suggestion-list">
                        @foreach (var suggestion in workspace.AssignmentSuggestions)
                        {
                            <article class="portfolio-mini-card">
                                <strong>@suggestion.AssignmentTitle</strong>
                                <small>@AssignmentSuggestionStatusText(suggestion.Status)</small>
                                <p>@(string.IsNullOrWhiteSpace(suggestion.StudentReason) ? "No reason added." : suggestion.StudentReason)</p>
                            </article>
                        }
                    </div>
                }
            </section>

            <section class="hm-card dashboard-card gradebook-preview-card">
                <div class="section-heading-row">
                    <h2>Preview</h2>
                    <span class="hm-chip">@DesignStatusText(workspace.Preview.Status)</span>
                </div>
                <PortfolioPreview Preview="workspace.Preview" />
            </section>

            @if (workspace.Design.ApprovalSnapshots.Count > 0)
            {
                <section class="hm-card dashboard-card">
                    <h2>Approved Snapshots</h2>
                    <div class="portfolio-suggestion-list">
                        @foreach (var snapshot in workspace.Design.ApprovalSnapshots)
                        {
                            <article class="portfolio-mini-card">
                                <strong>@snapshot.Title</strong>
                                <small>Version @snapshot.Version | @snapshot.ApprovedAtUtc.ToLocalTime().ToString("g")</small>
                                <p>@snapshot.SectionCount sections | @snapshot.ItemCount items</p>
                                <small>@snapshot.ExportManifestName</small>
                            </article>
                        }
                    </div>
                </section>
            }
        </aside>
    </div>
}

@code {
    [SupplyParameterFromQuery]
    public Guid? StudentId { get; set; }

    private bool canView;
    private bool lastActionSucceeded;
    private PortfolioReviewWorkspace? workspace;
    private string selectedStudentId = "";
    private PortfolioDesignEditModel designEdit = new();
    private readonly List<string> messages = [];
    private readonly Dictionary<Guid, PortfolioSectionEditModel> sectionEdits = [];
    private readonly Dictionary<Guid, PortfolioItemEditModel> itemEdits = [];
    private readonly Dictionary<string, SuggestionEditModel> suggestionEdits = [];
    private readonly Dictionary<Guid, EvidenceAddModel> evidenceAdds = [];
    private readonly Dictionary<Guid, CandidateAddModel> candidateAdds = [];
    private string newSectionHeading = "";
    private string newSectionIntroduction = "";
    private string portfolioSuggestionText = "";
    private string revisionNotes = "";
    private string selectedExportSnapshotId = "";
    private PortfolioExportPreview? exportPreview;

    private int OpenSuggestionCount => workspace?.Design.Suggestions.Count(item => item.Status == PortfolioSuggestionStatus.Open) ?? 0;

    private int PendingAssignmentCandidateCount => workspace?.AssignmentCandidates.Count(item => !item.PortfolioDraftStatus.HasValue) ?? 0;

    private string ReviewPostureText => workspace is null
        ? "Review portfolio designs before approval."
        : workspace.StudentAuthoringAllowed
            ? "For this grade level, guide the student's portfolio design and give final approval."
            : "For this grade level, the parent/admin controls portfolio creation and approval.";

    protected override async Task OnParametersSetAsync()
    {
        if (!Session.IsAuthenticated)
        {
            Navigation.NavigateTo("/login", replace: true);
            return;
        }

        canView = Session.IsParentAdmin;
        if (!canView || Session.CurrentUser is null)
        {
            return;
        }

        await LoadAsync(StudentId);
    }

    private async Task LoadAsync(Guid? studentId)
    {
        if (Session.CurrentUser is null)
        {
            return;
        }

        var result = await Portfolio.GetReviewWorkspaceAsync(Session.CurrentUser, studentId);
        if (result.Succeeded && result.Value is not null)
        {
            workspace = result.Value;
            selectedStudentId = workspace.StudentId.ToString();
            messages.Clear();
            SyncEditModels();
            await RefreshExportPreviewAsync(addMessages: false);
        }
        else
        {
            workspace = null;
            exportPreview = null;
            messages.Clear();
            messages.AddRange(result.Errors);
        }
    }


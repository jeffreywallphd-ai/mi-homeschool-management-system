@page "/login"
@rendermode InteractiveServer
@using HomeschoolManager.Infrastructure.Access
@using HomeschoolManager.Web.Services
@inject LocalAccessService AccessService
@inject SessionState Session
@inject NavigationManager Navigation

<PageTitle>Login</PageTitle>

<div class="page-header-bar">
    <div>
        <span class="hm-icon-tile" aria-hidden="true">
            <img class="hm-icon" src="icons/hm/svg/currentcolor/profile-user.svg" alt="" />
        </span>
        <h1>Parent/Admin Login</h1>
        <p>Use the local parent/admin session to manage records and planning.</p>
    </div>
</div>

@if (Session.IsAuthenticated)
{
    <div class="alert alert-success">
        Signed in as @Session.CurrentUser?.DisplayName (@Session.CurrentUser?.Role).
    </div>
}
else
{
    <section class="form-section">
        <h2>Parent/admin</h2>
        <p>Use the current Windows user as the local parent/admin session.</p>
        <button class="btn btn-primary" @onclick="SignInParent">Sign in as parent/admin</button>
    </section>
}

@code {
    private void SignInParent()
    {
        Session.SignIn(AccessService.CreateParentSession());
        Navigation.NavigateTo("/");
    }
}

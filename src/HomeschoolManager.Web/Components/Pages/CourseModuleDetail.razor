    private static string AssignmentPackFailureText(IReadOnlyList<string> errors)
    {
        if (errors.Count == 0)
        {
            return "The assignment pack could not be imported. The file may be damaged or in a format this app does not support yet.";
        }

        var first = errors[0];
        if (first.Contains("version", StringComparison.OrdinalIgnoreCase))
        {
            return "This assignment pack was made for a different version of the app and cannot be imported yet.";
        }

        if (first.Contains("valid JSON", StringComparison.OrdinalIgnoreCase) ||
            first.Contains("recognized assignment pack", StringComparison.OrdinalIgnoreCase) ||
            first.Contains("could not be read", StringComparison.OrdinalIgnoreCase))
        {
            return "The selected file is not a readable assignment pack. Choose a downloaded .assignmentpack file and try again.";
        }

        if (first.Contains("zip", StringComparison.OrdinalIgnoreCase))
        {
            return "This assignment pack uses a zipped attachment format that is not supported yet.";
        }

        return $"The assignment pack could not be imported. {first}";
    }


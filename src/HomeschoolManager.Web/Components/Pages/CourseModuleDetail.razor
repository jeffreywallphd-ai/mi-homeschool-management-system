@page "/courses/{CourseId:guid}/modules"
@page "/courses/{CourseId:guid}/modules/new"
@page "/courses/{CourseId:guid}/modules/{ModuleId:guid}"
@rendermode InteractiveServer
@using HomeschoolManager.Application.Common
@using HomeschoolManager.Application.Courses
@using HomeschoolManager.Domain.Access
@using HomeschoolManager.Domain.Curriculum
@using HomeschoolManager.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject CourseService CourseService
@inject SessionState Session
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Course Module</PageTitle>

@if (course is null)
{
    <h1>Course not found</h1>
    <p>The requested course could not be loaded.</p>
}
else
{
    <div class="page-header-bar">
        <div>
            <span class="hm-icon-tile" aria-hidden="true">
                <img class="hm-icon-lg" src="icons/hm/svg/currentcolor/form-lessons-book.svg" alt="" />
            </span>
            <h1>@HeaderTitle()</h1>
            <p>@course.Title</p>
        </div>
        @if (messages.Count > 0)
        {
            <section class="page-header-message" aria-live="polite">
                @foreach (var message in messages)
                {
                    <div class="@message.CssClass">@message.Text</div>
                }
            </section>
        }
    </div>

    @if (!CanEdit)
    {
        <div class="alert alert-warning">Sign in as parent/admin to edit learning modules.</div>
    }

    <div class="content-workbench course-detail-workbench">
        <main class="workbench-main">
            <section class="form-section">
                <div class="section-heading-row">
                    <h2>Modules</h2>
                    @if (CanEdit)
                    {
                        <button class="btn btn-primary btn-sm" @onclick="CreateModule">New module</button>
                    }
                </div>
                @if (course.Modules.Count == 0)
                {
                    <p>No modules have been added for this course.</p>
                }
                else
                {
                    <ul class="module-nav-list">
                        @foreach (var module in OrderedModules())
                        {
                            <li>
                                <button class="@ModuleButtonCss(module.Id)" @onclick="() => OpenModule(module.Id)">
                                    @module.SequenceOrder. @module.Title
                                </button>
                                @if (CanEdit)
                                {
                                    <div class="module-order-actions">
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => MoveModule(module.Id, -1)">Up</button>
                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => MoveModule(module.Id, 1)">Down</button>
                                        <button class="btn btn-danger btn-sm" @onclick="() => OpenDeleteModal(module.Id)">Delete</button>
                                    </div>
                                }
                            </li>
                        }
                    </ul>
                }
            </section>

            @if (selectedModule is not null)
            {
                <section class="form-section">
                    <h2>Module identity</h2>
                    <label class="form-label" for="module-title">Title <span class="required-marker">*</span></label>
                    <input id="module-title" class="form-control" disabled="@(!CanEdit)" @bind="moduleForm.Title" @bind:after="AutoSaveModule" />
                    @ValidationFor("module.Title")
                    @if (ShouldShowSemesterPlacement())
                    {
                        <label class="form-label" for="module-term">Semester</label>
                        <select id="module-term" class="form-select" disabled="@(!CanEdit)" @bind="moduleForm.TermId" @bind:after="AutoSaveModule">
                            <option value="">Unassigned</option>
                            @foreach (var term in course.Terms)
                            {
                                <option value="@term.Id">@term.Name</option>
                            }
                        </select>
                    }
                    <label class="form-label" for="module-status">Status</label>
                    <select id="module-status" class="form-select" disabled="@(!CanEdit)" @bind="moduleForm.Status" @bind:after="AutoSaveModule">
                        <option value="@ModuleStatus.Planned">Planned</option>
                        <option value="@ModuleStatus.Active">Active</option>
                        <option value="@ModuleStatus.Complete">Complete</option>
                    </select>
                    <label class="form-label" for="module-estimated-length">Estimated length</label>
                    <input id="module-estimated-length" class="form-control" disabled="@(!CanEdit)" @bind="moduleForm.EstimatedLength" @bind:after="AutoSaveModule" />
                    <label class="form-label" for="module-description">Description</label>
                    <textarea id="module-description" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="moduleForm.Description" @bind:after="AutoSaveModule"></textarea>
                </section>

                <section class="form-section">
                    <h2>Instructions</h2>
                    <label class="form-label" for="module-instructions">Instructions <span class="required-marker">*</span></label>
                    <textarea id="module-instructions" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="moduleForm.Instructions" @bind:after="AutoSaveModule"></textarea>
                    @ValidationFor("module.Instructions")
                    <label class="form-label" for="module-evidence">Assignment/evidence placeholder</label>
                    <textarea id="module-evidence" class="form-control" rows="4" disabled="@(!CanEdit)" @bind="moduleForm.AssignmentEvidencePlaceholder" @bind:after="AutoSaveModule"></textarea>
                </section>
            }
        </main>

        <aside class="workbench-support">
            @if (selectedModule is null)
            {
                <section class="status-panel">
                    <h2>Module details</h2>
                    <p>Select or create a module to edit its details.</p>
                </section>
            }
            else
            {
                <section class="form-section">
                    <div class="section-heading-row">
                        <h2>Learning objectives</h2>
                        @if (CanEdit)
                        {
                            <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleObjectiveForm">@ObjectiveToggleText()</button>
                        }
                    </div>
                    @if (moduleForm.ShowObjectiveForm && CanEdit)
                    {
                        <div class="inline-entry-form">
                            <label class="form-label" for="module-objective-text">Objective</label>
                            <input id="module-objective-text" class="form-control" @bind="moduleForm.NewObjectiveText" />
                            <label class="form-label" for="course-objective-link">Linked course objective</label>
                            <select id="course-objective-link" class="form-select" @bind="moduleForm.NewLinkedCourseObjective">
                                <option value="">Module specific objective</option>
                                @foreach (var objective in CourseObjectives())
                                {
                                    <option value="@objective">@objective</option>
                                }
                            </select>
                            <button class="btn btn-secondary mt-2" @onclick="AddObjective">Add objective</button>
                        </div>
                    }
                    @ValidationFor("module.Objectives")
                    @if (moduleForm.Objectives.Count == 0)
                    {
                        <p>No module objectives have been added.</p>
                    }
                    else
                    {
                        <ul class="itemized-editor-list stacked-editor-list">
                            @for (var index = 0; index < moduleForm.Objectives.Count; index++)
                            {
                                var objectiveIndex = index;
                                var objective = moduleForm.Objectives[index];
                                <li>
                                    <div class="itemized-editor-content">
                                        <span>@objective.Text</span>
                                        @if (!string.IsNullOrWhiteSpace(objective.LinkedCourseObjective))
                                        {
                                            <small>Aligned to: @objective.LinkedCourseObjective</small>
                                        }
                                    </div>
                                    @if (CanEdit)
                                    {
                                        <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveObjective(objectiveIndex)">Delete</button>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </section>

                <section class="form-section">
                    <div class="section-heading-row">
                        <h2>Lessons</h2>
                        @if (CanEdit)
                        {
                            <button class="btn btn-primary btn-sm" @onclick="CreateLesson">New lesson</button>
                        }
                    </div>
                    @if (CanEdit)
                    {
                        <div class="lesson-pack-tools">
                            <div class="lesson-pack-install">
                                <label class="form-label" for="lesson-pack-install">Import .lessonpack</label>
                                <InputFile id="lesson-pack-install" class="form-control" accept=".lessonpack,application/json" OnChange="SelectLessonPackFile" disabled="@isImportingLessonPack" />
                                @if (!string.IsNullOrWhiteSpace(selectedLessonPackFileName))
                                {
                                    <p class="form-text">Ready to import: @selectedLessonPackFileName</p>
                                }
                                <button class="btn btn-outline-primary btn-sm mt-2" disabled="@(selectedLessonPackFileBytes is null || isImportingLessonPack)" @onclick="ImportSelectedLessonPack">
                                    @if (isImportingLessonPack)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                                        <span>Importing...</span>
                                    }
                                    else
                                    {
                                        <span>Import lessons</span>
                                    }
                                </button>
                            </div>
                            <div class="lesson-pack-downloads">
                                <button class="btn btn-outline-secondary btn-sm" @onclick="DownloadLessonPackTemplate">Download template</button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="DownloadModuleLessonPack" disabled="@(selectedModule.Lessons.Count == 0)">Download module lessons</button>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(lessonPackStatus))
                        {
                            <div class="@lessonPackStatusCss" role="status" aria-live="polite">
                                @lessonPackStatus
                            </div>
                        }
                    }
                    @if (selectedModule.Lessons.Count == 0)
                    {
                        <p>No lessons have been added for this module.</p>
                    }
                    else
                    {
                        <ul class="module-nav-list">
                            @foreach (var lesson in selectedModule.Lessons.OrderBy(lesson => lesson.SequenceOrder))
                            {
                                <li>
                                    <button class="btn btn-outline-secondary btn-sm module-nav-button" @onclick="() => OpenLesson(lesson.Id)">
                                        @lesson.SequenceOrder. @lesson.Title
                                    </button>
                                    @if (CanEdit)
                                    {
                                        <div class="module-order-actions">
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => MoveLesson(lesson.Id, -1)">Up</button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => MoveLesson(lesson.Id, 1)">Down</button>
                                            <button class="btn btn-danger btn-sm" @onclick="() => OpenDeleteLessonModal(lesson.Id)">Delete</button>
                                        </div>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </section>

                <section class="form-section">
                    <div class="section-heading-row">
                        <h2>Assignments</h2>
                        @if (CanEdit)
                        {
                            <button class="btn btn-primary btn-sm" @onclick="CreateAssignment">New assignment</button>
                        }
                    </div>
                    @if (CanEdit)
                    {
                        <div class="assignment-pack-tools">
                            <div class="assignment-pack-install">
                                <label class="form-label" for="assignment-pack-install">Import .assignmentpack</label>
                                <InputFile id="assignment-pack-install" class="form-control" accept=".assignmentpack,application/json" OnChange="SelectAssignmentPackFile" disabled="@isImportingAssignmentPack" />
                                @if (!string.IsNullOrWhiteSpace(selectedAssignmentPackFileName))
                                {
                                    <p class="form-text">Ready to import: @selectedAssignmentPackFileName</p>
                                }
                                <button class="btn btn-outline-primary btn-sm mt-2" disabled="@(selectedAssignmentPackFileBytes is null || isImportingAssignmentPack)" @onclick="ImportSelectedAssignmentPack">
                                    @if (isImportingAssignmentPack)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                                        <span>Importing...</span>
                                    }
                                    else
                                    {
                                        <span>Import assignments</span>
                                    }
                                </button>
                            </div>
                            <div class="assignment-pack-downloads">
                                <button class="btn btn-outline-secondary btn-sm" @onclick="DownloadAssignmentPackTemplate">Download template</button>
                                <button class="btn btn-outline-secondary btn-sm" @onclick="DownloadModuleAssignmentPack" disabled="@(selectedModule.Assignments.Count == 0)">Download module assignments</button>
                            </div>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(assignmentPackStatus))
                        {
                            <div class="@assignmentPackStatusCss" role="status" aria-live="polite">
                                @assignmentPackStatus
                            </div>
                        }
                    }
                    @if (selectedModule.Assignments.Count == 0)
                    {
                        <p>No assignments have been added for this module.</p>
                    }
                    else
                    {
                        <ul class="module-nav-list">
                            @foreach (var assignment in selectedModule.Assignments.OrderBy(assignment => assignment.SequenceOrder))
                            {
                                <li>
                                    <button class="btn btn-outline-secondary btn-sm module-nav-button" @onclick="() => OpenAssignment(assignment.Id)">
                                        @assignment.SequenceOrder. @assignment.Title
                                    </button>
                                    @if (CanEdit)
                                    {
                                        <div class="module-order-actions">
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => MoveAssignment(assignment.Id, -1)">Up</button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => MoveAssignment(assignment.Id, 1)">Down</button>
                                            <button class="btn btn-danger btn-sm" @onclick="() => OpenDeleteAssignmentModal(assignment.Id)">Delete</button>
                                        </div>
                                    }
                                </li>
                            }
                        </ul>
                    }
                </section>
            }
        </aside>
    </div>

    @if (deleteModuleId.HasValue)
    {
        <div class="modal-backdrop-panel" role="presentation">
            <section class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="delete-module-heading">
                <h2 id="delete-module-heading">Delete module?</h2>
                <p>This permanently removes the selected module from the course. Type Delete to confirm.</p>
                <label class="form-label" for="delete-confirmation">Confirmation</label>
                <input id="delete-confirmation" class="form-control" @bind="deleteConfirmation" />
                <div class="modal-actions">
                    <button class="btn btn-outline-secondary" @onclick="CloseDeleteModal">Cancel</button>
                    <button class="btn btn-danger" disabled="@(!CanConfirmDelete())" @onclick="DeleteModule">Delete</button>
                </div>
            </section>
        </div>
    }

    @if (deleteLessonId.HasValue)
    {
        <div class="modal-backdrop-panel" role="presentation">
            <section class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="delete-lesson-heading">
                <h2 id="delete-lesson-heading">Delete lesson?</h2>
                <p>This permanently removes the selected lesson from the module. Type Delete to confirm.</p>
                <label class="form-label" for="delete-lesson-confirmation">Confirmation</label>
                <input id="delete-lesson-confirmation" class="form-control" @bind="deleteLessonConfirmation" />
                <div class="modal-actions">
                    <button class="btn btn-outline-secondary" @onclick="CloseDeleteLessonModal">Cancel</button>
                    <button class="btn btn-danger" disabled="@(!CanConfirmLessonDelete())" @onclick="DeleteLesson">Delete</button>
                </div>
            </section>
        </div>
    }

    @if (deleteAssignmentId.HasValue)
    {
        <div class="modal-backdrop-panel" role="presentation">
            <section class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="delete-assignment-heading">
                <h2 id="delete-assignment-heading">Delete assignment?</h2>
                <p>This permanently removes the selected assignment from the module. Type Delete to confirm.</p>
                <label class="form-label" for="delete-assignment-confirmation">Confirmation</label>
                <input id="delete-assignment-confirmation" class="form-control" @bind="deleteAssignmentConfirmation" />
                <div class="modal-actions">
                    <button class="btn btn-outline-secondary" @onclick="CloseDeleteAssignmentModal">Cancel</button>
                    <button class="btn btn-danger" disabled="@(!CanConfirmAssignmentDelete())" @onclick="DeleteAssignment">Delete</button>
                </div>
            </section>
        </div>
    }
}

@code {
    [Parameter]
    public Guid CourseId { get; set; }

    [Parameter]
    public Guid? ModuleId { get; set; }

    private const long MaxLessonPackFileSize = 5 * 1024 * 1024;
    private const long MaxAssignmentPackFileSize = 5 * 1024 * 1024;
    private HomeschoolManager.Application.Courses.CourseDetail? course;
    private LearningModuleView? selectedModule;
    private ModuleFormModel moduleForm = new();
    private readonly List<PageMessage> messages = [];
    private readonly Dictionary<string, string> fieldErrors = [];
    private byte[]? selectedLessonPackFileBytes;
    private string selectedLessonPackFileName = "";
    private string lessonPackStatus = "";
    private string lessonPackStatusCss = "alert alert-info mt-2";
    private bool isImportingLessonPack;
    private byte[]? selectedAssignmentPackFileBytes;
    private string selectedAssignmentPackFileName = "";
    private string assignmentPackStatus = "";
    private string assignmentPackStatusCss = "alert alert-info mt-2";
    private bool isImportingAssignmentPack;
    private Guid? deleteModuleId;
    private string deleteConfirmation = "";
    private Guid? deleteLessonId;
    private string deleteLessonConfirmation = "";
    private Guid? deleteAssignmentId;
    private string deleteAssignmentConfirmation = "";
    private bool newModuleRouteHandled;

    private bool CanEdit => Session.IsParentAdmin;

    protected override async Task OnParametersSetAsync()
    {
        if (IsNewModuleRoute() && !newModuleRouteHandled)
        {
            newModuleRouteHandled = true;
            await Refresh();
            await CreateModule();
            return;
        }

        await Refresh();
    }

    private async Task CreateModule()
    {
        if (!CanEdit)
        {
            messages.Clear();
            messages.Add(new PageMessage("Sign in as parent/admin to create learning modules.", "alert alert-danger"));
            return;
        }

        var result = await CourseService.CreateLearningModuleAsync(
            ParentUser(),
            new CreateLearningModuleCommand(
                CourseId,
                "New module",
                "",
                DefaultTermId(),
                "",
                "Add module instructions.",
                [new ModuleLearningObjectiveCommand("Add module learning objective.", "")],
                [],
                "Add planned assignments or evidence for this module.",
                ModuleStatus.Planned));
        if (!result.Succeeded)
        {
            messages.Clear();
            messages.AddRange(result.Errors.Select(error => new PageMessage(error, "alert alert-danger")));
            return;
        }

        NavigationManager.NavigateTo($"/courses/{CourseId}/modules/{result.Value}");
    }

    private async Task CreateLesson()
    {
        if (!CanEdit || selectedModule is null)
        {
            return;
        }

        var objective = selectedModule.LearningObjectiveItems.FirstOrDefault()?.Text ?? "";
        var result = await CourseService.CreateLessonAsync(
            ParentUser(),
            new CreateLessonCommand(
                CourseId,
                selectedModule.Id,
                "New lesson",
                "Add a short introduction that explains the lesson topic and what the student should focus on.",
                objective,
                [new LessonResourceCommand("Parent-selected lesson resource", LessonResourceType.PhysicalResource, "", "", true, "Parent-selected resource.")]));
        if (!result.Succeeded)
        {
            messages.Clear();
            messages.AddRange(result.Errors.Select(error => new PageMessage(error, "alert alert-danger")));
            return;
        }

        NavigationManager.NavigateTo($"/courses/{CourseId}/modules/{selectedModule.Id}/lessons/{result.Value}");
    }

    private async Task SelectLessonPackFile(InputFileChangeEventArgs eventArgs)
    {
        lessonPackStatus = "";
        var file = eventArgs.File;
        if (!file.Name.EndsWith(".lessonpack", StringComparison.OrdinalIgnoreCase))
        {
            SetLessonPackStatus("Choose a .lessonpack file to import.", false);
            selectedLessonPackFileBytes = null;
            selectedLessonPackFileName = "";
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: MaxLessonPackFileSize);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            selectedLessonPackFileBytes = memory.ToArray();
            selectedLessonPackFileName = file.Name;
            SetLessonPackStatus("Lesson pack file is ready. Click Import lessons to add it to this module.", true);
        }
        catch (IOException)
        {
            selectedLessonPackFileBytes = null;
            selectedLessonPackFileName = "";
            SetLessonPackStatus("The lesson pack file could not be read. Try choosing it again.", false);
        }
        catch (InvalidOperationException)
        {
            selectedLessonPackFileBytes = null;
            selectedLessonPackFileName = "";
            SetLessonPackStatus("The lesson pack file is too large to import here. Use a file under 5 MB.", false);
        }
    }

    private async Task ImportSelectedLessonPack()
    {
        if (!CanEdit || selectedModule is null)
        {
            SetLessonPackStatus("Sign in as parent/admin to import lessons.", false);
            return;
        }

        if (selectedLessonPackFileBytes is null)
        {
            SetLessonPackStatus("Choose a .lessonpack file before importing.", false);
            return;
        }

        isImportingLessonPack = true;
        SetLessonPackStatus("Importing lessons. This may take a moment.", true);
        StateHasChanged();

        try
        {
            var result = await CourseService.ImportLessonPackAsync(
                ParentUser(),
                CourseId,
                selectedModule.Id,
                selectedLessonPackFileBytes);
            if (!result.Succeeded)
            {
                SetLessonPackStatus(LessonPackFailureText(result.Errors), false);
                return;
            }

            selectedLessonPackFileBytes = null;
            selectedLessonPackFileName = "";
            var count = result.Value?.LessonCount ?? 0;
            SetLessonPackStatus(count == 1 ? "Imported 1 lesson into this module." : $"Imported {count} lessons into this module.", true);
            await Refresh();
        }
        catch (Exception)
        {
            SetLessonPackStatus("The lesson pack could not be imported. The file may be damaged or in a format this app does not support yet.", false);
        }
        finally
        {
            isImportingLessonPack = false;
        }
    }

    private async Task DownloadModuleLessonPack()
    {
        if (selectedModule is null)
        {
            return;
        }

        var result = await CourseService.DownloadModuleLessonPackAsync(CourseId, selectedModule.Id);
        if (!result.Succeeded || result.Value is null)
        {
            SetLessonPackStatus("The module lessons could not be prepared for download.", false);
            return;
        }

        await DownloadLessonPackFile(result.Value);
        SetLessonPackStatus("Module lesson pack downloaded.", true);
    }

    private async Task DownloadLessonPackTemplate()
    {
        var result = CourseService.DownloadLessonPackTemplate();
        if (!result.Succeeded || result.Value is null)
        {
            SetLessonPackStatus("The lesson pack template could not be prepared for download.", false);
            return;
        }

        await DownloadLessonPackFile(result.Value);
        SetLessonPackStatus("Lesson pack template downloaded.", true);
    }

    private async Task DownloadLessonPackFile(LessonPackDownloadFile file)
    {
        await JS.InvokeVoidAsync(
            "homeschoolFiles.downloadBase64",
            file.FileName,
            file.ContentType,
            Convert.ToBase64String(file.Content));
    }

    private void SetLessonPackStatus(string text, bool isSuccessOrProgress)
    {
        lessonPackStatus = text;
        lessonPackStatusCss = isSuccessOrProgress
            ? "alert alert-info mt-2"
            : "alert alert-danger mt-2";
    }

    private static string LessonPackFailureText(IReadOnlyList<string> errors)
    {
        if (errors.Count == 0)
        {
            return "The lesson pack could not be imported. The file may be damaged or in a format this app does not support yet.";
        }

        var first = errors[0];
        if (first.Contains("version", StringComparison.OrdinalIgnoreCase))
        {
            return "This lesson pack was made for a different version of the app and cannot be imported yet.";
        }

        if (first.Contains("valid JSON", StringComparison.OrdinalIgnoreCase) ||
            first.Contains("recognized lesson pack", StringComparison.OrdinalIgnoreCase) ||
            first.Contains("could not be read", StringComparison.OrdinalIgnoreCase))
        {
            return "The selected file is not a readable lesson pack. Choose a downloaded .lessonpack file and try again.";
        }

        if (first.Contains("zip", StringComparison.OrdinalIgnoreCase))
        {
            return "This lesson pack uses a zipped attachment format that is not supported yet.";
        }

        return $"The lesson pack could not be imported. {first}";
    }

    private async Task SelectAssignmentPackFile(InputFileChangeEventArgs eventArgs)
    {
        assignmentPackStatus = "";
        var file = eventArgs.File;
        if (!file.Name.EndsWith(".assignmentpack", StringComparison.OrdinalIgnoreCase))
        {
            SetAssignmentPackStatus("Choose a .assignmentpack file to import.", false);
            selectedAssignmentPackFileBytes = null;
            selectedAssignmentPackFileName = "";
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: MaxAssignmentPackFileSize);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            selectedAssignmentPackFileBytes = memory.ToArray();
            selectedAssignmentPackFileName = file.Name;
            SetAssignmentPackStatus("Assignment pack file is ready. Click Import assignments to add it to this module.", true);
        }
        catch (IOException)
        {
            selectedAssignmentPackFileBytes = null;
            selectedAssignmentPackFileName = "";
            SetAssignmentPackStatus("The assignment pack file could not be read. Try choosing it again.", false);
        }
        catch (InvalidOperationException)
        {
            selectedAssignmentPackFileBytes = null;
            selectedAssignmentPackFileName = "";
            SetAssignmentPackStatus("The assignment pack file is too large to import here. Use a file under 5 MB.", false);
        }
    }

    private async Task ImportSelectedAssignmentPack()
    {
        if (!CanEdit || selectedModule is null)
        {
            SetAssignmentPackStatus("Sign in as parent/admin to import assignments.", false);
            return;
        }

        if (selectedAssignmentPackFileBytes is null)
        {
            SetAssignmentPackStatus("Choose a .assignmentpack file before importing.", false);
            return;
        }

        isImportingAssignmentPack = true;
        SetAssignmentPackStatus("Importing assignments. This may take a moment.", true);
        StateHasChanged();

        try
        {
            var result = await CourseService.ImportAssignmentPackAsync(
                ParentUser(),
                CourseId,
                selectedModule.Id,
                selectedAssignmentPackFileBytes);
            if (!result.Succeeded)
            {
                SetAssignmentPackStatus(AssignmentPackFailureText(result.Errors), false);
                return;
            }

            selectedAssignmentPackFileBytes = null;
            selectedAssignmentPackFileName = "";
            var count = result.Value?.AssignmentCount ?? 0;
            SetAssignmentPackStatus(count == 1 ? "Imported 1 assignment into this module." : $"Imported {count} assignments into this module.", true);
            await Refresh();
        }
        catch (Exception)
        {
            SetAssignmentPackStatus("The assignment pack could not be imported. The file may be damaged or in a format this app does not support yet.", false);
        }
        finally
        {
            isImportingAssignmentPack = false;
        }
    }


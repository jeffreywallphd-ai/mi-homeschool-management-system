                InstructionalMethodProfile.Hybrid,
                "Add student-facing assignment instructions.",
                "",
                "",
                null,
                string.IsNullOrWhiteSpace(objective) ? [] : [objective],
                lessonId.HasValue ? [lessonId.Value] : [],
                "Add the expected student work or evidence.",

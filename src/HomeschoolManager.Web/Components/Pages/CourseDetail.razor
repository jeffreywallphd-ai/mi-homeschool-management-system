@page "/courses/{CourseId:guid}"
@rendermode InteractiveServer
@using HomeschoolManager.Application.Common
@using HomeschoolManager.Application.Courses
@using HomeschoolManager.Application.Requirements
@using HomeschoolManager.Domain.Access
@using HomeschoolManager.Domain.Curriculum
@using HomeschoolManager.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject CourseService CourseService
@inject RequirementService RequirementService
@inject SessionState Session
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Course Detail</PageTitle>

@if (detail is null)
{
    <h1>Course not found</h1>
    <p>The requested course could not be loaded.</p>
}
else
{
    <div class="page-header-bar">
        <div>
            <h1>@detail.Title</h1>
            <p>@CourseOwnerText(detail), @DurationText(detail.Duration), @detail.PlannedCreditValue planned credit(s)</p>
        </div>
        @if (messages.Count > 0)
        {
            <section class="page-header-message" aria-live="polite">
                @foreach (var message in messages)
                {
                    <div class="@message.CssClass">@message.Text</div>
                }
            </section>
        }
    </div>

    @if (!Session.IsParentAdmin)
    {
        <div class="alert alert-warning">Sign in as parent/admin to edit course planning records.</div>
    }
    else
    {
        <div class="content-workbench course-detail-workbench">
            <main class="workbench-main">
                <section class="form-section">
            <h2>Course identity</h2>
            <label class="form-label" for="title">Title <span class="required-marker">*</span></label>
            <input id="title" class="form-control" @bind="courseForm.Title" @bind:after="AutoSaveCourse" />
            @ValidationFor("course.Title")
            <label class="form-label" for="duration">Duration <span class="required-marker">*</span></label>
            <select id="duration" class="form-select" @bind="courseForm.Duration" @bind:after="AutoSaveCourse">
                <option value="@CourseDuration.OneSemester">One semester</option>
                <option value="@CourseDuration.TwoSemesters">Two semesters</option>
            </select>
            @ValidationFor("course.Duration")
            <label class="form-label" for="credit">Planned credit value <span class="required-marker">*</span></label>
            <input id="credit" class="form-control" type="number" step="0.25" min="0.25" max="3" @bind="courseForm.PlannedCreditValue" @bind:after="AutoSaveCourse" />
            @ValidationFor("course.PlannedCreditValue")
                </section>

                <section class="form-section">
            <h2>Course description</h2>
            <label class="form-label" for="description">Description</label>
            <textarea id="description" class="form-control" rows="4" @bind="descriptionForm.Description" @bind:after="AutoSaveDescription"></textarea>
            <label class="form-label" for="methods-preset">Instructional methods</label>
            <select id="methods-preset" class="form-select" value="@selectedInstructionalMethodId" @onchange="ChangeInstructionalMethod">
                @foreach (var option in InstructionalMethodOptions)
                {
                    <option value="@option.Id">@option.Name</option>
                }
            </select>
            <label class="visually-hidden" for="methods">Instructional methods details</label>
            <textarea id="methods" class="form-control" rows="4" @bind="descriptionForm.InstructionalMethods" @bind:after="AutoSaveDescription"></textarea>
            <label class="form-label" for="topics">Major topics</label>
            <textarea id="topics" class="form-control" rows="4" @bind="descriptionForm.MajorTopics" @bind:after="AutoSaveDescription"></textarea>
                </section>

                <section class="form-section">
            <div class="section-heading-row mt-3">
                <h2>Texts and resources</h2>
                <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleResourceForm">@ResourceToggleText()</button>
            </div>
            @if (descriptionForm.ShowResourceForm)
            {
                <div class="inline-entry-form">
                    <label class="form-label" for="resource-name">Name</label>
                    <input id="resource-name" class="form-control" @bind="descriptionForm.NewResourceName" />
                    <label class="form-label" for="resource-link">Link</label>
                    <input id="resource-link" class="form-control" type="url" @bind="descriptionForm.NewResourceLink" />
                    <button class="btn btn-secondary mt-2" @onclick="AddResource">Add resource</button>
                </div>
            }
            @if (descriptionForm.Resources.Count == 0)
            {
                <p>No texts or resources have been added.</p>
            }
            else
            {
                <ul class="itemized-editor-list">
                    @for (var index = 0; index < descriptionForm.Resources.Count; index++)
                    {
                        var resourceIndex = index;
                        var resource = descriptionForm.Resources[index];
                        <li>
                            <div>
                                <strong>@resource.Name</strong>
                                @if (!string.IsNullOrWhiteSpace(resource.Link))
                                {
                                    <a href="@resource.Link" target="_blank" rel="noopener">View</a>
                                }
                            </div>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveResource(resourceIndex)">Delete</button>
                        </li>
                    }
                </ul>
            }
                </section>

                <section class="form-section">
            <h2>Assessment and grading</h2>
            <label class="form-label" for="assessment-preset">Assessment methods</label>
            <select id="assessment-preset" class="form-select" value="@selectedAssessmentMethodId" @onchange="ChangeAssessmentMethod">
                @foreach (var option in AssessmentMethodOptions)
                {
                    <option value="@option.Id">@option.Name</option>
                }
            </select>
            <label class="visually-hidden" for="assessment">Assessment methods details</label>
            <textarea id="assessment" class="form-control" rows="4" @bind="descriptionForm.AssessmentMethods" @bind:after="AutoSaveDescription"></textarea>
            <label class="form-label" for="grading-preset">Grading basis</label>
            <select id="grading-preset" class="form-select" value="@selectedGradingBasisId" @onchange="ChangeGradingBasis">
                @foreach (var option in GradingBasisOptions)
                {
                    <option value="@option.Id">@option.Name</option>
                }
            </select>
            <label class="visually-hidden" for="grading">Grading basis details</label>
            <textarea id="grading" class="form-control" rows="4" @bind="descriptionForm.GradingBasis" @bind:after="AutoSaveDescription"></textarea>
                </section>

            </main>

            <aside class="workbench-support">
                <section class="form-section">
            <h2>Curriculum plan</h2>
            <label class="form-label" for="goals">Goals</label>
            <textarea id="goals" class="form-control" rows="4" @bind="planForm.Goals" @bind:after="AutoSavePlan"></textarea>
            <div class="section-heading-row mt-3">
                <h3>Learning objectives</h3>
                <button class="btn btn-outline-secondary btn-sm" @onclick="ToggleObjectiveForm">@ObjectiveToggleText()</button>
            </div>
            @if (planForm.ShowObjectiveForm)
            {
                <div class="inline-entry-form">
                    <label class="form-label" for="objective-text">Objective</label>
                    <input id="objective-text" class="form-control" @bind="planForm.NewObjectiveText" />
                    <button class="btn btn-secondary mt-2" @onclick="AddObjective">Add objective</button>
                </div>
            }
            @if (planForm.LearningObjectives.Count == 0)
            {
                <p>No learning objectives have been added.</p>
            }
            else
            {
                <ul class="itemized-editor-list">
                    @for (var index = 0; index < planForm.LearningObjectives.Count; index++)
                    {
                        var objectiveIndex = index;
                        var objective = planForm.LearningObjectives[index];
                        <li>
                            <span>@objective.Text</span>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => RemoveObjective(objectiveIndex)">Delete</button>
                        </li>
                    }
                </ul>
            }
            <label class="form-label" for="sequence">Planned sequence</label>
            <textarea id="sequence" class="form-control" rows="4" @bind="planForm.PlannedSequence" @bind:after="AutoSavePlan"></textarea>
            <label class="form-label" for="notes">Parent notes</label>
            <textarea id="notes" class="form-control" rows="4" @bind="planForm.ParentNotes" @bind:after="AutoSavePlan"></textarea>
                </section>

                <section class="form-section">
            <h2>Requirement mapping</h2>
            <p>Mappings show selected coverage. They are parent-owned evidence summaries, not legal determinations.</p>
            <label class="form-label" for="requirement-area">Requirement area</label>
            <select id="requirement-area" class="form-select" @bind="mappingForm.RequirementAreaId">
                <option value="@Guid.Empty">Choose an area</option>
                @foreach (var item in requirementAreas)
                {
                    <option value="@item.RequirementAreaId">@item.View - @item.Name (@item.GradeBand)</option>
                }
            </select>
            <label class="form-label" for="coverage-level">Coverage level</label>
            <select id="coverage-level" class="form-select" @bind="mappingForm.CoverageLevel">
                <option value="@CoverageLevel.Primary">Primary</option>
                <option value="@CoverageLevel.Secondary">Secondary</option>
                <option value="@CoverageLevel.Supporting">Supporting</option>
            </select>
            <label class="form-label" for="mapping-notes">Notes</label>
            <textarea id="mapping-notes" class="form-control" rows="4" @bind="mappingForm.Notes"></textarea>
            <button class="btn btn-primary mt-2" @onclick="AddOrUpdateMapping">Add or update mapping</button>
                </section>

                @CurrentMappingsSection()

                @ModulesSection()
            </aside>
        </div>
    }

    @if (!Session.IsParentAdmin)
    {
        @CurrentMappingsSection()
    }

    @if (deleteModuleId.HasValue)
    {
        <div class="modal-backdrop-panel" role="presentation">
            <section class="confirm-modal" role="dialog" aria-modal="true" aria-labelledby="delete-course-module-heading">
                <h2 id="delete-course-module-heading">Delete module?</h2>
                <p>This permanently removes the selected module from the course. Type Delete to confirm.</p>
                <label class="form-label" for="delete-module-confirmation">Confirmation</label>
                <input id="delete-module-confirmation" class="form-control" @bind="deleteModuleConfirmation" />
                <div class="modal-actions">
                    <button class="btn btn-outline-secondary" @onclick="CloseDeleteModuleModal">Cancel</button>
                    <button class="btn btn-danger" disabled="@(!CanConfirmModuleDelete())" @onclick="DeleteModule">Delete</button>
                </div>
            </section>
        </div>
    }
}

@code {
    [Parameter]
    public Guid CourseId { get; set; }

    private HomeschoolManager.Application.Courses.CourseDetail? detail;
    private IReadOnlyList<RequirementChecklistItem> requirementAreas = [];
    private readonly List<PageMessage> messages = [];
    private readonly Dictionary<string, string> fieldErrors = [];
    private CourseFormModel courseForm = new();
    private DescriptionFormModel descriptionForm = new();
    private PlanFormModel planForm = new();
    private MappingFormModel mappingForm = new();
    private string selectedInstructionalMethodId = DefaultInstructionalMethodId;
    private string selectedAssessmentMethodId = DefaultAssessmentMethodId;
    private string selectedGradingBasisId = DefaultGradingBasisId;
    private const long MaxModulePackFileSize = 5 * 1024 * 1024;
    private byte[]? selectedModulePackFileBytes;
    private string selectedModulePackFileName = "";
    private string modulePackStatus = "";
    private string modulePackStatusCss = "alert alert-info mt-2";
    private bool isImportingModulePack;
    private Guid? deleteModuleId;
    private string deleteModuleConfirmation = "";
    private const string DefaultInstructionalMethodId = "hybrid-instruction";
    private const string DefaultAssessmentMethodId = "hybrid-assessment";
    private const string DefaultGradingBasisId = "hybrid-grading";
    private const string OtherPresetId = "other";

    protected override async Task OnInitializedAsync()
    {
        requirementAreas = await RequirementService.GetChecklistAsync();
        await Refresh();
    }

    private async Task AutoSaveCourse()
    {
        if (!ValidateCourse())
        {
            return;
        }

        await AutoSave(() => CourseService.UpdateCourseAsync(
            ParentUser(),
            new UpdateCourseCommand(CourseId, courseForm.Title, [], courseForm.Duration, courseForm.PlannedCreditValue)));
    }

    private async Task AutoSaveDescription()
    {
        await AutoSave(() => CourseService.SaveCourseDescriptionAsync(
            ParentUser(),
            new SaveCourseDescriptionCommand(
                CourseId,
                descriptionForm.Description,
                descriptionForm.InstructionalMethods,
                descriptionForm.MajorTopics,
                SerializeResources(descriptionForm.Resources),
                descriptionForm.AssessmentMethods,
                descriptionForm.GradingBasis)));
    }

    private async Task AutoSavePlan()
    {
        await AutoSave(() => CourseService.SaveCurriculumPlanAsync(
            ParentUser(),
            new SaveCurriculumPlanCommand(
                CourseId,
                planForm.Goals,
                SerializeObjectives(planForm.LearningObjectives),
                "",
                planForm.PlannedSequence,
                planForm.ParentNotes)));
    }

    private async Task AddOrUpdateMapping()
    {
        if (detail is null)
        {
            return;
        }

        var mappings = detail.Mappings
            .Where(mapping => mapping.RequirementAreaId != mappingForm.RequirementAreaId)
            .Select(mapping => new RequirementMappingCommand(mapping.RequirementAreaId, mapping.CoverageLevel, mapping.Notes))
            .ToList();

        mappings.Add(new RequirementMappingCommand(mappingForm.RequirementAreaId, mappingForm.CoverageLevel, mappingForm.Notes));

        await Run(() => CourseService.SetRequirementMappingsAsync(
            ParentUser(),
            new SetCourseRequirementMappingsCommand(CourseId, mappings)));

        mappingForm = new MappingFormModel();
    }

    private async Task Run(Func<Task<OperationResult>> action)
    {
        messages.Clear();
        fieldErrors.Clear();
        var result = await action();
        if (result.Succeeded)
        {
            messages.Add(new PageMessage("Saved.", "alert alert-success"));
            await Refresh();
            return;
        }

        messages.AddRange(result.Errors.Select(error => new PageMessage(error, "alert alert-danger")));
    }

    private async Task AutoSave(Func<Task<OperationResult>> action)
    {
        messages.Clear();
        fieldErrors.Clear();
        var result = await action();
        if (result.Succeeded)
        {
            messages.Add(new PageMessage("Saved.", "alert alert-success"));
            await UpdateLoadedDetail();
            return;
        }

        messages.AddRange(result.Errors.Select(error => new PageMessage(error, "alert alert-danger")));
    }

    private async Task UpdateLoadedDetail()
    {
        detail = await CourseService.GetCourseDetailAsync(CourseId);
    }

    private async Task Refresh()
    {
        detail = await CourseService.GetCourseDetailAsync(CourseId);
        if (detail is null)
        {
            return;
        }

        courseForm = new CourseFormModel
        {
            Title = detail.Title,
            Duration = detail.Duration,
            PlannedCreditValue = detail.PlannedCreditValue
        };
        descriptionForm = new DescriptionFormModel
        {
            Description = detail.Description,
            InstructionalMethods = detail.InstructionalMethods,
            MajorTopics = detail.MajorTopics,
            Resources = ParseResources(detail.TextsAndResources).ToList(),
            AssessmentMethods = detail.AssessmentMethods,
            GradingBasis = detail.GradingBasis
        };
        ApplyDefaultPresetsForBlankFields();
        selectedInstructionalMethodId = MatchPreset(InstructionalMethodOptions, descriptionForm.InstructionalMethods, DefaultInstructionalMethodId);
        selectedAssessmentMethodId = MatchPreset(AssessmentMethodOptions, descriptionForm.AssessmentMethods, DefaultAssessmentMethodId);
        selectedGradingBasisId = MatchPreset(GradingBasisOptions, descriptionForm.GradingBasis, DefaultGradingBasisId);
        planForm = new PlanFormModel
        {
            Goals = detail.Goals,
            LearningObjectives = ParseObjectives(detail.LearningObjectives).ToList(),
            PlannedSequence = detail.PlannedSequence,
            ParentNotes = detail.ParentNotes
        };

    }

    private UserContext ParentUser()
    {
        return Session.CurrentUser ?? UserContext.Student("Anonymous");
    }

    private static string DurationText(CourseDuration duration)
    {
        return duration == CourseDuration.OneSemester ? "one semester" : "two semesters";
    }

    private static string CourseOwnerText(HomeschoolManager.Application.Courses.CourseDetail course)
    {
        return string.IsNullOrWhiteSpace(course.StudentName)
            ? "Selected student"
            : course.StudentName;
    }

    private async Task ChangeInstructionalMethod(ChangeEventArgs eventArgs)
    {
        selectedInstructionalMethodId = eventArgs.Value?.ToString() ?? OtherPresetId;
        ApplyPreset(InstructionalMethodOptions, selectedInstructionalMethodId, value => descriptionForm.InstructionalMethods = value);
        await AutoSaveDescription();
    }

    private async Task ChangeAssessmentMethod(ChangeEventArgs eventArgs)
    {
        selectedAssessmentMethodId = eventArgs.Value?.ToString() ?? OtherPresetId;
        ApplyPreset(AssessmentMethodOptions, selectedAssessmentMethodId, value => descriptionForm.AssessmentMethods = value);
        await AutoSaveDescription();
    }

    private async Task ChangeGradingBasis(ChangeEventArgs eventArgs)
    {
        selectedGradingBasisId = eventArgs.Value?.ToString() ?? OtherPresetId;
        ApplyPreset(GradingBasisOptions, selectedGradingBasisId, value => descriptionForm.GradingBasis = value);
        await AutoSaveDescription();
    }

    private void ApplyDefaultPresetsForBlankFields()
    {
        descriptionForm.InstructionalMethods = FillBlank(descriptionForm.InstructionalMethods, PresetText(InstructionalMethodOptions, DefaultInstructionalMethodId));
        descriptionForm.AssessmentMethods = FillBlank(descriptionForm.AssessmentMethods, PresetText(AssessmentMethodOptions, DefaultAssessmentMethodId));
        descriptionForm.GradingBasis = FillBlank(descriptionForm.GradingBasis, PresetText(GradingBasisOptions, DefaultGradingBasisId));
    }

    private static void ApplyPreset(IReadOnlyList<PresetOption> options, string selectedId, Action<string> apply)
    {
        if (selectedId == OtherPresetId)
        {
            apply("");
            return;
        }

        var option = options.FirstOrDefault(item => item.Id == selectedId);
        if (option is not null)
        {
            apply(option.Text);
        }
    }

    private static string MatchPreset(IReadOnlyList<PresetOption> options, string value, string defaultId)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return defaultId;
        }

        return options.FirstOrDefault(option => option.Text == value)?.Id ?? OtherPresetId;
    }

    private static string PresetText(IReadOnlyList<PresetOption> options, string id)
    {
        return options.First(option => option.Id == id).Text;
    }

    private static string FillBlank(string value, string fallback)
    {
        return string.IsNullOrWhiteSpace(value) ? fallback : value;
    }

    private RenderFragment CurrentMappingsSection()
    {
        return @<section class="status-panel">
            <h2>Current mappings</h2>
            @if (detail?.Mappings.Count == 0)
            {
                <p>No requirement mappings yet.</p>
            }
            else
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>View</th>
                            <th>Area</th>
                            <th>Coverage</th>
                            <th>Notes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var mapping in detail?.Mappings ?? [])
                        {
                            <tr>
                                <td>@mapping.RequirementView</td>
                                <td>@mapping.RequirementAreaName</td>
                                <td>@mapping.CoverageLevel</td>
                                <td>@mapping.Notes</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>;
    }

    private RenderFragment ModulesSection()
    {
        return @<section class="form-section">
            <div class="section-heading-row">
                <h2>Modules</h2>
                @if (Session.IsParentAdmin)
                {
                    <button class="btn btn-primary btn-sm" @onclick="CreateModule">New module</button>
                }
            </div>
            @if (Session.IsParentAdmin)
            {
                <div class="lesson-pack-tools">
                    <div class="lesson-pack-install">
                        <label class="form-label" for="module-pack-install">Import .modulepack</label>
                        <InputFile id="module-pack-install" class="form-control" accept=".modulepack,application/json" OnChange="SelectModulePackFile" disabled="@isImportingModulePack" />
                        @if (!string.IsNullOrWhiteSpace(selectedModulePackFileName))
                        {
                            <p class="form-text">Ready to import: @selectedModulePackFileName</p>
                        }
                        <button class="btn btn-outline-primary btn-sm mt-2" disabled="@(selectedModulePackFileBytes is null || isImportingModulePack)" @onclick="ImportSelectedModulePack">
                            @if (isImportingModulePack)
                            {
                                <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                                <span>Importing...</span>
                            }
                            else
                            {
                                <span>Import module</span>
                            }
                        </button>
                    </div>
                    <div class="lesson-pack-downloads">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="DownloadModulePackTemplate">Download template</button>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(modulePackStatus))
                {
                    <div class="@modulePackStatusCss" role="status" aria-live="polite">
                        @modulePackStatus
                    </div>
                }
            }
            @if (detail?.Modules.Count == 0)
            {
                <p>No modules have been added for this course.</p>
            }
            else
            {
                <ul class="module-nav-list">
                    @foreach (var module in OrderedModules())
                    {
                        <li>
                            <button class="btn btn-outline-secondary btn-sm module-nav-button" @onclick="() => OpenModule(module.Id)">
                                @module.SequenceOrder. @module.Title
                            </button>
                            @if (Session.IsParentAdmin)
                            {
                                <div class="module-order-actions">
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => MoveModule(module.Id, -1)">Up</button>
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => MoveModule(module.Id, 1)">Down</button>
                                    <button class="btn btn-outline-secondary btn-sm" @onclick="() => DownloadModulePack(module.Id)">Download</button>
                                    <button class="btn btn-danger btn-sm" @onclick="() => OpenDeleteModuleModal(module.Id)">Delete</button>
                                </div>
                            }
                        </li>
                    }
                </ul>
            }
        </section>;
    }

    private string ResourceToggleText()
    {
        return descriptionForm.ShowResourceForm ? "Hide" : "Add";
    }

    private IEnumerable<LearningModuleView> OrderedModules()
    {
        return detail is null
            ? Enumerable.Empty<LearningModuleView>()
            : detail.Modules.OrderBy(module => module.SequenceOrder);
    }

    private void OpenModule(Guid moduleId)
    {
        NavigationManager.NavigateTo($"/courses/{CourseId}/modules/{moduleId}");
    }

    private void CreateModule()
    {
        NavigationManager.NavigateTo($"/courses/{CourseId}/modules/new");
    }

    private async Task MoveModule(Guid moduleId, int direction)
    {
        if (!Session.IsParentAdmin || detail is null)
        {
            return;
        }

        var modules = OrderedModules().ToList();
        var index = modules.FindIndex(module => module.Id == moduleId);
        var targetIndex = index + direction;
        if (index < 0 || targetIndex < 0 || targetIndex >= modules.Count)
        {
            return;
        }

        (modules[index], modules[targetIndex]) = (modules[targetIndex], modules[index]);
        await Run(() => CourseService.ReorderLearningModulesAsync(
            ParentUser(),
            new ReorderLearningModulesCommand(CourseId, modules.Select(module => module.Id).ToArray())));
    }

    private async Task SelectModulePackFile(InputFileChangeEventArgs eventArgs)
    {
        var file = eventArgs.File;
        if (!file.Name.EndsWith(".modulepack", StringComparison.OrdinalIgnoreCase))
        {
            selectedModulePackFileBytes = null;
            selectedModulePackFileName = "";
            SetModulePackStatus("Choose a .modulepack file to import.", false);
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: MaxModulePackFileSize);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            selectedModulePackFileBytes = memory.ToArray();
            selectedModulePackFileName = file.Name;
            SetModulePackStatus("Module pack file is ready. Click Import module to add it to this course.", true);
        }
        catch (IOException)
        {
            selectedModulePackFileBytes = null;
            selectedModulePackFileName = "";
            SetModulePackStatus("The module pack file could not be read. Try choosing it again.", false);
        }
    }

    private async Task ImportSelectedModulePack()
    {
        if (!Session.IsParentAdmin)
        {
            SetModulePackStatus("Sign in as parent/admin to import modules.", false);
            return;
        }

        if (selectedModulePackFileBytes is null)
        {
            SetModulePackStatus("Choose a .modulepack file before importing.", false);
            return;
        }

        isImportingModulePack = true;
        SetModulePackStatus("Importing module. This may take a moment.", true);
        StateHasChanged();

        try
        {
            var result = await CourseService.ImportModulePackAsync(ParentUser(), CourseId, selectedModulePackFileBytes);
            if (!result.Succeeded || result.Value is null)
            {
                SetModulePackStatus(ModulePackFailureText(result.Errors), false);
                return;
            }

            selectedModulePackFileBytes = null;
            selectedModulePackFileName = "";
            SetModulePackStatus($"Imported module: {result.Value.ModuleTitle}.", true);
            await Refresh();
        }
        catch (Exception)
        {
            SetModulePackStatus("The module pack could not be imported. The file may be damaged or in a format this app does not support yet.", false);
        }
        finally
        {
            isImportingModulePack = false;
        }
    }

    private async Task DownloadModulePack(Guid moduleId)
    {
        var result = await CourseService.DownloadModulePackAsync(CourseId, moduleId);
        if (!result.Succeeded || result.Value is null)
        {
            SetModulePackStatus("The module pack could not be prepared for download.", false);
            return;
        }

        await DownloadModulePackFile(result.Value);
        SetModulePackStatus("Module pack downloaded.", true);
    }

    private async Task DownloadModulePackTemplate()
    {
        var result = CourseService.DownloadModulePackTemplate();
        if (!result.Succeeded || result.Value is null)
        {
            SetModulePackStatus("The module pack template could not be prepared for download.", false);
            return;
        }

        await DownloadModulePackFile(result.Value);
        SetModulePackStatus("Module pack template downloaded.", true);
    }

    private async Task DownloadModulePackFile(ModulePackDownloadFile file)
    {
        await JS.InvokeVoidAsync(
            "homeschoolFiles.downloadBase64",
            file.FileName,
            file.ContentType,
            Convert.ToBase64String(file.Content));
    }

    private void SetModulePackStatus(string text, bool isSuccessOrProgress)
    {
        modulePackStatus = text;
        modulePackStatusCss = isSuccessOrProgress
            ? "alert alert-info mt-2"
            : "alert alert-danger mt-2";
    }

    private static string ModulePackFailureText(IReadOnlyList<string> errors)
    {
        if (errors.Count == 0)
        {
            return "The module pack could not be imported. The file may be damaged or in a format this app does not support yet.";
        }

        var first = errors[0];
        if (first.Contains("version", StringComparison.OrdinalIgnoreCase))
        {
            return "This module pack was made for a different version of the app and cannot be imported yet.";
        }

        if (first.Contains("valid JSON", StringComparison.OrdinalIgnoreCase) ||
            first.Contains("recognized module pack", StringComparison.OrdinalIgnoreCase) ||
            first.Contains("could not be read", StringComparison.OrdinalIgnoreCase))
        {
            return "The selected file is not a readable module pack. Choose a downloaded .modulepack file and try again.";
        }

        if (first.Contains("zip", StringComparison.OrdinalIgnoreCase))
        {
            return "This module pack uses a zipped attachment format that is not supported yet.";
        }

        return $"The module pack could not be imported. {first}";
    }


@page "/courses"
@rendermode InteractiveServer
@using HomeschoolManager.Application.Common
@using HomeschoolManager.Application.Courses
@using HomeschoolManager.Application.Setup
@using HomeschoolManager.Domain.Curriculum
@using HomeschoolManager.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.JSInterop
@inject CourseService CourseService
@inject SetupService SetupService
@inject SessionState Session
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Courses</PageTitle>

<div class="page-header-bar">
    <div>
        <h1>Courses</h1>
        <p>Courses are the main planning unit for a selected student's records, descriptions, curriculum plans, and Michigan requirement mappings.</p>
    </div>
    @if (Session.IsParentAdmin)
    {
        <div class="page-header-student-selector">
            <label class="form-label" for="admin-course-student">Student</label>
            <select id="admin-course-student" class="form-select" @bind="selectedStudentId" @bind:after="ChangeSelectedStudent" disabled="@(students.Count == 0)">
                @if (students.Count == 0)
                {
                    <option value="">No students configured</option>
                }
                else
                {
                    @foreach (var student in students)
                    {
                        <option value="@student.Id.ToString()">@student.DisplayName</option>
                    }
                }
            </select>
        </div>
    }
</div>

<div class="content-workbench">
    <main class="workbench-main">
        @if (!Session.IsParentAdmin)
        {
            <div class="alert alert-warning">Sign in as parent/admin to create or edit courses.</div>
        }
        else
        {
            @if (!HasSelectedStudent)
            {
                <div class="alert alert-warning">Add a student in Setup before creating or importing courses.</div>
            }
            <section class="form-section">
                <div class="section-heading-row">
                    @if (courses.Count == 0 || showCreateCourse)
                    {
                        <h2>Create course</h2>
                    }
                    @if (courses.Count > 0)
                    {
                        <button class="@CreateCourseButtonCss()" @onclick="ToggleCreateCourse">
                            @(showCreateCourse ? "Hide" : "New Course")
                        </button>
                    }
                </div>
                @if (courses.Count == 0 || showCreateCourse)
                {
                    <label class="form-label" for="course-title">Title <span class="required-marker">*</span></label>
                    <input id="course-title" class="form-control" @bind="newCourse.Title" />
                    @ValidationFor("newCourse.Title")
                    <label class="form-label" for="course-description">Description</label>
                    <textarea id="course-description" class="form-control" rows="4" @bind="newCourse.Description"></textarea>
                    <label class="form-label" for="duration">Duration <span class="required-marker">*</span></label>
                    <select id="duration" class="form-select" @bind="newCourse.Duration">
                        <option value="@CourseDuration.OneSemester">One semester</option>
                        <option value="@CourseDuration.TwoSemesters">Two semesters</option>
                    </select>
                    @ValidationFor("newCourse.Duration")
                    <label class="form-label" for="planned-credit">Planned credit value <span class="required-marker">*</span></label>
                    <input id="planned-credit" class="form-control" type="number" step="0.25" min="0.25" max="3" @bind="newCourse.PlannedCreditValue" />
                    @ValidationFor("newCourse.PlannedCreditValue")
                    <button class="btn btn-primary mt-2" disabled="@(!HasSelectedStudent)" @onclick="CreateCourse">Create course</button>
                }
            </section>
        }

        <section class="status-panel">
            <div class="section-heading-row course-list-heading-row">
                <h2>Course list</h2>
                @if (Session.IsParentAdmin && courses.Count > 0)
                {
                    <div class="course-list-actions">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="ArchiveCourseList">
                            @(selectedCourseIds.Count > 0 ? "Archive Selected Courses" : "Archive Course List")
                        </button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="DeleteCourseList">
                            @(selectedCourseIds.Count > 0 ? "Delete Selected Courses" : "Delete Entire Course List")
                        </button>
                    </div>
                }
            </div>
            @if (courses.Count == 0)
            {
                <p>No courses have been created yet.</p>
            }
            else
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th class="select-cell">Select</th>
                            <th>Title</th>
                            <th>Description</th>
                            <th>Duration</th>
                            <th>Credits</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var course in courses)
                        {
                            <tr class="clickable-row" @onclick="() => OpenCourse(course.Id)">
                                <td class="select-cell" @onclick:stopPropagation="true">
                                    <input class="form-check-input" type="checkbox" checked="@selectedCourseIds.Contains(course.Id)" @onchange="eventArgs => ToggleSelectedCourse(course.Id, eventArgs)" aria-label="@($"Select {course.Title}")" />
                                </td>
                                <td>@course.Title</td>
                                <td>@DisplayDescription(course.Description)</td>
                                <td>@DurationText(course.Duration)</td>
                                <td class="credits-cell">@CreditText(course.PlannedCreditValue)</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="4" scope="row">Total credits</th>
                            <td class="credits-cell">@CreditText(CourseCreditTotal())</td>
                        </tr>
                    </tfoot>
                </table>
            }
        </section>

    </main>

    <aside class="workbench-support">
        <section class="support-card">
            <h2>Course packs</h2>
            @if (Session.IsParentAdmin)
            {
                <div class="mb-3">
                    <label class="form-label" for="course-pack-install">Install .coursepack</label>
                    <InputFile id="course-pack-install" class="form-control" accept=".coursepack,application/json" OnChange="SelectCoursePackFile" disabled="@isInstallingCoursePack" />
                    @if (!string.IsNullOrWhiteSpace(selectedCoursePackFileName))
                    {
                        <p class="form-text">Ready to install: @selectedCoursePackFileName</p>
                    }
                    <button class="btn btn-outline-primary btn-sm mt-2" disabled="@(selectedCoursePackFileBytes is null || isInstallingCoursePack)" @onclick="InstallSelectedCoursePack">
                        @if (isInstallingCoursePack)
                        {
                            <span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>
                            <span>Installing...</span>
                        }
                        else
                        {
                            <span>Install</span>
                        }
                    </button>
                    @if (!string.IsNullOrWhiteSpace(coursePackInstallStatus))
                    {
                        <div class="@coursePackInstallStatusCss" role="status" aria-live="polite">
                            @coursePackInstallStatus
                        </div>
                    }
                </div>
            }
            <label class="form-label" for="course-pack">Pack</label>
            <select id="course-pack" class="form-select" @bind="selectedPackId" @bind:after="SelectPack">
                @foreach (var pack in coursePacks)
                {
                    <option value="@pack.Id">@pack.Name</option>
                }
            </select>
            @if (selectedPack is not null)
            {
                <div class="course-pack-actions">
                    <p class="mb-0">@selectedPack.Description</p>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="DownloadSelectedPack">
                        Download .coursepack
                    </button>
                </div>
                <p>@selectedTemplateIds.Count selected course(s), @CreditText(SelectedPackCreditTotal()) planned credits</p>
                @if (Session.IsParentAdmin)
                {
                    <div class="course-pack-actions">
                        <div class="d-flex gap-2 flex-wrap">
                            <button class="btn btn-primary" disabled="@(!HasSelectedStudent)" @onclick="ImportFullPack">Import full pack</button>
                            <button class="btn btn-outline-primary" disabled="@(!HasSelectedStudent)" @onclick="ImportSelectedPack">Import selected</button>
                        </div>
                        <button class="btn btn-link btn-sm" @onclick="TogglePackDetails">
                            @(showPackDetails ? "Hide pack details" : "Show pack details")
                        </button>
                    </div>
                }
                @if (showPackDetails)
                {
                    <table class="table table-sm mt-3 course-pack-table">
                        <thead>
                            <tr>
                                <th>Select</th>
                                <th>Course</th>
                                <th>Description</th>
                                <th>Length</th>
                                <th>Credits</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in selectedPack.Courses)
                            {
                                <tr>
                                    <td>
                                        <input class="form-check-input" type="checkbox" checked="@selectedTemplateIds.Contains(item.TemplateId)" @onchange="eventArgs => ToggleSelectedTemplate(item.TemplateId, eventArgs)" />
                                    </td>
                                    <td class="course-pack-title">
                                        @if (item.Options.Count > 1)
                                        {
                                            <select class="form-select form-select-sm course-pack-course-select" value="@SelectedOptionId(item.TemplateId)" @onchange="eventArgs => ChangeSelectedOption(item.TemplateId, eventArgs)">
                                                @foreach (var option in item.Options)
                                                {
                                                    <option value="@option.OptionId">@option.Title</option>
                                                }
                                            </select>
                                        }
                                        else
                                        {
                                            @SelectedOption(item).Title
                                        }
                                    </td>
                                    <td class="course-pack-description">
                                        <div class="@DescriptionTextCss(item.TemplateId)">@DisplayDescription(SelectedOption(item).Description)</div>
                                        @if (CanToggleDescription(SelectedOption(item).Description))
                                        {
                                            <button type="button" class="btn btn-link btn-sm course-pack-description-toggle" @onclick="() => ToggleDescription(item.TemplateId)">
                                                @(expandedDescriptionTemplateIds.Contains(item.TemplateId) ? "Less" : "More")
                                            </button>
                                        }
                                    </td>
                                    <td class="course-pack-length">@DurationText(SelectedOption(item).Duration)</td>
                                    <td class="course-pack-credits">@CreditText(SelectedOption(item).PlannedCreditValue)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
        </section>

        <section class="status-panel">
            <h2>Michigan coverage summary</h2>
            <p>These records show selected coverage areas. This summary does not certify legal compliance.</p>
            @if (coverage.Count == 0)
            {
                <p>No requirement areas are available. Seed Michigan requirements from Setup.</p>
            }
            else
            {
                <table class="table">
                    <thead>
                        <tr>
                            <th>Area</th>
                            <th>Source</th>
                            <th>Coverage</th>
                            <th>Courses</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in coverage)
                        {
                            <tr class="@CoverageRowCss(item)">
                                <td>@item.Name</td>
                                <td>@item.Source</td>
                                <td>@(item.IsMapped ? item.CoverageLevel?.ToString() : "Not mapped")</td>
                                <td>@string.Join(", ", item.CourseTitles)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </section>
    </aside>
</div>

@if (messages.Count > 0)
{
    <section class="message-list" aria-live="polite">
        @foreach (var message in messages)
        {
            <div class="@message.CssClass">@message.Text</div>
        }
    </section>
}

@code {
    private IReadOnlyList<CourseListItem> courses = [];
    private IReadOnlyList<CoverageSummaryItem> coverage = [];
    private IReadOnlyList<CoursePackSummary> coursePacks = [];
    private IReadOnlyList<StudentSetupItem> students = [];
    private CoursePackDetail? selectedPack;
    private string selectedPackId = "";
    private string selectedStudentId = "";
    private bool showCreateCourse;
    private bool showPackDetails;
    private readonly HashSet<string> selectedTemplateIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly Dictionary<string, string> selectedOptionIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> expandedDescriptionTemplateIds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<Guid> selectedCourseIds = [];
    private readonly List<PageMessage> messages = [];
    private readonly Dictionary<string, string> fieldErrors = [];
    private CourseFormModel newCourse = new();
    private byte[]? selectedCoursePackFileBytes;
    private string selectedCoursePackFileName = "";
    private bool isInstallingCoursePack;
    private string coursePackInstallStatus = "";
    private string coursePackInstallStatusCss = "alert alert-info mt-2";
    private const long MaxCoursePackFileSize = 25 * 1024 * 1024;

    protected override async Task OnInitializedAsync()
    {
        await LoadStudents();
        coursePacks = await CourseService.ListCoursePacksAsync();
        selectedPackId = coursePacks.FirstOrDefault()?.Id ?? "";
        await SelectPack();
        await Refresh();
    }

    private async Task LoadStudents()
    {
        students = await SetupService.ListStudentsAsync();
        if (students.Count == 0)
        {
            selectedStudentId = "";
            return;
        }

        if (!Guid.TryParse(selectedStudentId, out var parsedStudentId) || students.All(student => student.Id != parsedStudentId))
        {
            selectedStudentId = students[0].Id.ToString();
        }
    }

    private async Task CreateCourse()
    {
        messages.Clear();
        fieldErrors.Clear();
        if (!ValidateNewCourse())
        {
            return;
        }

        var user = Session.CurrentUser;
        if (user is null)
        {
            messages.Add(new PageMessage("Sign in as parent/admin to create a course.", "alert alert-danger"));
            return;
        }

        if (!TryGetSelectedStudentId(out var studentId))
        {
            messages.Add(new PageMessage("Choose a student before creating a course.", "alert alert-danger"));
            return;
        }

        var result = await CourseService.CreateCourseAsync(
            user,
            new CreateCourseCommand(newCourse.Title, newCourse.Description, newCourse.SubjectAreas, newCourse.Duration, newCourse.PlannedCreditValue, studentId));

        if (!result.Succeeded)
        {
            messages.AddRange(result.Errors.Select(error => new PageMessage(error, "alert alert-danger")));
            return;
        }

        messages.Add(new PageMessage("Course created.", "alert alert-success"));
        newCourse = new CourseFormModel();
        showCreateCourse = false;
        await Refresh();
    }

    private void ToggleCreateCourse()
    {
        showCreateCourse = !showCreateCourse;
    }

    private string CreateCourseButtonCss()
    {
        return showCreateCourse
            ? "btn btn-outline-secondary btn-sm new-course-button"
            : "btn btn-primary new-course-button";
    }

    private void OpenCourse(Guid courseId)
    {
        NavigationManager.NavigateTo($"/courses/{courseId}");
    }

    private void TogglePackDetails()
    {
        showPackDetails = !showPackDetails;
    }

    private void ToggleSelectedCourse(Guid courseId, ChangeEventArgs eventArgs)
    {
        var isChecked = eventArgs.Value is bool value && value;
        if (isChecked)
        {
            selectedCourseIds.Add(courseId);
            return;
        }

        selectedCourseIds.Remove(courseId);
    }

    private Task ArchiveCourseList()
    {
        return RunCourseListAction(
            isDelete: false,
            selectedCourseIds.Count > 0
                ? "Archive the selected course(s)? They will be removed from the active course list but kept with their details."
                : "Archive the entire course list for this student? Courses will be removed from the active course list but kept with their details.");
    }

    private Task DeleteCourseList()
    {
        return RunCourseListAction(
            isDelete: true,
            selectedCourseIds.Count > 0
                ? "Delete the selected course(s)? This removes courses that do not have student work."
                : "Delete the entire active course list for this student? This removes courses that do not have student work.");
    }

    private async Task RunCourseListAction(bool isDelete, string confirmationMessage)
    {
        messages.Clear();
        fieldErrors.Clear();
        var user = Session.CurrentUser;
        if (user is null)
        {
            messages.Add(new PageMessage("Sign in as parent/admin to change the course list.", "alert alert-danger"));
            return;
        }

        if (!TryGetSelectedStudentId(out var studentId))
        {
            messages.Add(new PageMessage("Choose a student before changing the course list.", "alert alert-danger"));
            return;
        }

        var confirmed = await JS.InvokeAsync<bool>("confirm", confirmationMessage);
        if (!confirmed)
        {
            return;
        }

        var command = new CourseListActionCommand(
            studentId,
            selectedCourseIds.ToArray(),
            selectedCourseIds.Count == 0);
        var result = isDelete
            ? await CourseService.DeleteCoursesAsync(user, command)
            : await CourseService.ArchiveCoursesAsync(user, command);

        if (!result.Succeeded || result.Value is null)
        {
            messages.AddRange(result.Errors.Select(error => new PageMessage(error, "alert alert-danger")));
            return;
        }

        var actionName = isDelete ? "deleted" : "archived";
        messages.Add(new PageMessage($"{result.Value.SuccessCount} course(s) {actionName}.", "alert alert-success"));
        foreach (var failure in result.Value.Failures)
        {
            messages.Add(new PageMessage($"{failure.CourseTitle}: {failure.Message}", "alert alert-warning"));
        }

        selectedCourseIds.Clear();
        await Refresh();
    }

    private Task ImportFullPack()
    {
        var selections = selectedPack?.Courses
            .Select(course => new CoursePackSelectionCommand(course.TemplateId, SelectedOptionId(course.TemplateId)))
            .ToArray() ?? [];
        return ImportPack(selections, true);
    }

    private Task ImportSelectedPack()
    {
        var selections = selectedPack?.Courses
            .Where(course => selectedTemplateIds.Contains(course.TemplateId))
            .Select(course => new CoursePackSelectionCommand(course.TemplateId, SelectedOptionId(course.TemplateId)))
            .ToArray() ?? [];
        return ImportPack(selections, false);
    }

    private async Task ImportPack(IReadOnlyList<CoursePackSelectionCommand> selections, bool importFullPack)
    {
        messages.Clear();
        fieldErrors.Clear();
        var user = Session.CurrentUser;
        if (user is null)
        {
            messages.Add(new PageMessage("Sign in as parent/admin to import a course pack.", "alert alert-danger"));
            return;
        }

        if (!importFullPack && selections.Count == 0)
        {
            messages.Add(new PageMessage("Choose one or more courses, or import the full pack.", "alert alert-danger"));
            return;
        }

        if (!TryGetSelectedStudentId(out var studentId))
        {
            messages.Add(new PageMessage("Choose a student before importing courses.", "alert alert-danger"));
            return;
        }

        var result = await CourseService.ImportCoursePackAsync(user, new ImportCoursePackCommand(selectedPackId, [], selections, studentId));
        if (!result.Succeeded)
        {
            messages.AddRange(result.Errors.Select(error => new PageMessage(error, "alert alert-danger")));
            return;
        }

        messages.Add(new PageMessage($"Imported {result.Value} course(s).", "alert alert-success"));
        await Refresh();
    }

    private async Task DownloadSelectedPack()
    {
        messages.Clear();
        var result = await CourseService.DownloadCoursePackAsync(selectedPackId);
        if (!result.Succeeded || result.Value is null)
        {
            messages.AddRange(result.Errors.Select(error => new PageMessage(error, "alert alert-danger")));
            return;
        }

        await JS.InvokeVoidAsync(
            "homeschoolFiles.downloadBase64",
            result.Value.FileName,
            result.Value.ContentType,
            Convert.ToBase64String(result.Value.Content));
        messages.Add(new PageMessage($"Downloaded {result.Value.FileName}.", "alert alert-success"));
    }

    private async Task SelectCoursePackFile(InputFileChangeEventArgs eventArgs)
    {
        messages.Clear();
        fieldErrors.Clear();
        coursePackInstallStatus = "";
        coursePackInstallStatusCss = "alert alert-info mt-2";
        var file = eventArgs.File;
        if (!file.Name.EndsWith(".coursepack", StringComparison.OrdinalIgnoreCase))
        {
            SetCoursePackInstallStatus("Choose a .coursepack file to install.", false);
            selectedCoursePackFileBytes = null;
            selectedCoursePackFileName = "";
            return;
        }

        try
        {
            await using var stream = file.OpenReadStream(maxAllowedSize: MaxCoursePackFileSize);
            using var memory = new MemoryStream();
            await stream.CopyToAsync(memory);
            selectedCoursePackFileBytes = memory.ToArray();
            selectedCoursePackFileName = file.Name;
            SetCoursePackInstallStatus("Course pack file is ready. Click Install to add it to the pack list.", true);
        }
        catch (IOException)
        {
            selectedCoursePackFileBytes = null;
            selectedCoursePackFileName = "";
            SetCoursePackInstallStatus("The course pack file could not be read. Try choosing it again.", false);
        }
        catch (InvalidOperationException)
        {
            selectedCoursePackFileBytes = null;
            selectedCoursePackFileName = "";
            SetCoursePackInstallStatus("The course pack file is too large to install here. Use a file under 25 MB.", false);
        }
    }

    private async Task InstallSelectedCoursePack()
    {
        messages.Clear();
        fieldErrors.Clear();
        coursePackInstallStatus = "";
        var user = Session.CurrentUser;
        if (user is null)
        {
            SetCoursePackInstallStatus("Sign in as parent/admin to install a course pack file.", false);
            return;
        }

        if (selectedCoursePackFileBytes is null)
        {
            SetCoursePackInstallStatus("Choose a .coursepack file before installing.", false);
            return;
        }

        isInstallingCoursePack = true;
        SetCoursePackInstallStatus("Installing course pack. This may take a moment for larger packs.", true);
        StateHasChanged();

        try
        {
            var result = await CourseService.InstallCoursePackFileAsync(user, selectedCoursePackFileBytes);
            if (!result.Succeeded)
            {
                SetCoursePackInstallStatus(InstallFailureText(result.Errors), false);
                return;
            }

            coursePacks = await CourseService.ListCoursePacksAsync();
            selectedPackId = result.Value?.Id ?? selectedPackId;
            await SelectPack();
            selectedCoursePackFileBytes = null;
            selectedCoursePackFileName = "";
            SetCoursePackInstallStatus($"Installed {result.Value?.Name ?? "course pack"}. Use Import full pack or Import selected to add courses to the student course list.", true);
        }
        catch (Exception)
        {
            SetCoursePackInstallStatus("The course pack could not be installed. The file may be damaged or in a format this app does not support yet.", false);
        }
        finally
        {
            isInstallingCoursePack = false;
        }
    }

    private void SetCoursePackInstallStatus(string text, bool isSuccessOrProgress)
    {
        coursePackInstallStatus = text;
        coursePackInstallStatusCss = isSuccessOrProgress
            ? "alert alert-info mt-2"
            : "alert alert-danger mt-2";
    }

    private static string InstallFailureText(IReadOnlyList<string> errors)
    {
        if (errors.Count == 0)
        {
            return "The course pack could not be installed. The file may be damaged or in a format this app does not support yet.";
        }

        var first = errors[0];
        if (first.Contains("already built into the system", StringComparison.OrdinalIgnoreCase))
        {
            return "This course pack is already included in the app, so it does not need to be installed.";
        }

        if (first.Contains("version", StringComparison.OrdinalIgnoreCase))
        {
            return "This course pack was made for a different version of the app and cannot be installed yet.";
        }

        if (first.Contains("valid JSON", StringComparison.OrdinalIgnoreCase) ||
            first.Contains("recognized course pack", StringComparison.OrdinalIgnoreCase) ||
            first.Contains("could not be read", StringComparison.OrdinalIgnoreCase))
        {
            return "The selected file is not a readable course pack. Choose a downloaded .coursepack file and try again.";
        }

        if (first.Contains("zip", StringComparison.OrdinalIgnoreCase))
        {
            return "This course pack uses a zipped attachment format that is not supported yet.";
        }

        return $"The course pack could not be installed. {first}";
    }

    private async Task SelectPack()
    {
        selectedPack = string.IsNullOrWhiteSpace(selectedPackId)
            ? null
            : await CourseService.GetCoursePackDetailAsync(selectedPackId);
        selectedTemplateIds.Clear();
        selectedOptionIds.Clear();
        expandedDescriptionTemplateIds.Clear();
        if (selectedPack is not null)
        {
            foreach (var course in selectedPack.Courses)
            {
                selectedTemplateIds.Add(course.TemplateId);
                selectedOptionIds[course.TemplateId] = course.DefaultOptionId;
            }
        }
    }

    private void ToggleSelectedTemplate(string templateId, ChangeEventArgs eventArgs)
    {
        var isChecked = eventArgs.Value is bool value && value;
        if (isChecked)
        {
            selectedTemplateIds.Add(templateId);
            return;
        }

        selectedTemplateIds.Remove(templateId);
    }

    private void ChangeSelectedOption(string templateId, ChangeEventArgs eventArgs)
    {
        var optionId = eventArgs.Value?.ToString() ?? "";
        if (string.IsNullOrWhiteSpace(optionId))
        {
            selectedOptionIds.Remove(templateId);
            return;
        }

        selectedOptionIds[templateId] = optionId;
        expandedDescriptionTemplateIds.Remove(templateId);
    }

    private void ToggleDescription(string templateId)
    {
        if (!expandedDescriptionTemplateIds.Add(templateId))
        {
            expandedDescriptionTemplateIds.Remove(templateId);
        }
    }

    private async Task Refresh()
    {
        if (!TryGetSelectedStudentId(out var studentId))
        {
            courses = [];
            coverage = await CourseService.GetCoverageSummaryAsync();
            return;
        }

        courses = await CourseService.ListCoursesAsync(studentId);
        coverage = await CourseService.GetCoverageSummaryAsync(studentId);
        selectedCourseIds.RemoveWhere(courseId => courses.All(course => course.Id != courseId));
    }

    private async Task ChangeSelectedStudent()
    {
        messages.Clear();
        fieldErrors.Clear();
        newCourse = new CourseFormModel();
        showCreateCourse = false;
        await Refresh();
    }

    private bool TryGetSelectedStudentId(out Guid studentId)
    {
        if (!Guid.TryParse(selectedStudentId, out studentId))
        {
            return false;
        }

        var selectedId = studentId;
        return students.Any(student => student.Id == selectedId);
    }

    private bool HasSelectedStudent => TryGetSelectedStudentId(out _);

    private static string DurationText(CourseDuration duration)
    {
        return duration == CourseDuration.OneSemester ? "One semester" : "Two semesters";
    }

    private static string DisplayDescription(string description)
    {
        return string.IsNullOrWhiteSpace(description) ? "No description yet" : description;
    }

    private static string CreditText(decimal credits)
    {
        return credits.ToString("0.0##");
    }

    private decimal CourseCreditTotal()
    {
        return courses.Sum(course => course.PlannedCreditValue);
    }

    private string DescriptionTextCss(string templateId)
    {
        return expandedDescriptionTemplateIds.Contains(templateId)
            ? "course-pack-description-text expanded"
            : "course-pack-description-text";
    }

    private static bool CanToggleDescription(string description)
    {
        return !string.IsNullOrWhiteSpace(description) && description.Length > 90;
    }

    private static string CoverageRowCss(CoverageSummaryItem item)
    {
        return IsUnmetStatutoryRequirement(item) ? "unmet-statutory-requirement" : "";
    }

    private static bool IsUnmetStatutoryRequirement(CoverageSummaryItem item)
    {
        return !item.IsMapped && item.Source.Contains("Statutory", StringComparison.OrdinalIgnoreCase);
    }

    private string SelectedOptionId(string templateId)
    {
        if (selectedOptionIds.TryGetValue(templateId, out var optionId))
        {
            return optionId;
        }

        var course = selectedPack?.Courses.FirstOrDefault(item => item.TemplateId == templateId);
        return course?.DefaultOptionId ?? "";
    }

    private CoursePackOptionView SelectedOption(CoursePackCourseView course)
    {
        var selectedOptionId = SelectedOptionId(course.TemplateId);
        return course.Options.FirstOrDefault(option => string.Equals(option.OptionId, selectedOptionId, StringComparison.OrdinalIgnoreCase))
            ?? course.Options.First();
    }

    private decimal SelectedPackCreditTotal()
    {
        return selectedPack?.Courses
            .Where(course => selectedTemplateIds.Contains(course.TemplateId))
            .Sum(course => SelectedOption(course).PlannedCreditValue) ?? 0;
    }

    private MarkupString ValidationFor(string key)
    {
        return fieldErrors.TryGetValue(key, out var message)
            ? new MarkupString($"<div class=\"validation-message\">{System.Net.WebUtility.HtmlEncode(message)}</div>")
            : new MarkupString("");
    }

    private bool ValidateNewCourse()
    {
        if (string.IsNullOrWhiteSpace(newCourse.Title))
        {
            fieldErrors["newCourse.Title"] = "Title is required.";
        }

        if (!Enum.IsDefined(newCourse.Duration))
        {
            fieldErrors["newCourse.Duration"] = "Duration is required.";
        }

        if (newCourse.PlannedCreditValue <= 0 || newCourse.PlannedCreditValue > 3)
        {
            fieldErrors["newCourse.PlannedCreditValue"] = "Planned credit must be greater than 0 and no more than 3.";
        }

        if (fieldErrors.Count == 0)
        {
            return true;
        }

        messages.Add(new PageMessage("Please complete the required fields.", "alert alert-danger"));
        return false;
    }

    private sealed class CourseFormModel
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public CourseDuration Duration { get; set; } = CourseDuration.TwoSemesters;
        public decimal PlannedCreditValue { get; set; } = 1;

        public IReadOnlyList<string> SubjectAreas => [];
    }

    private sealed record PageMessage(string Text, string CssClass);
}

@rendermode InteractiveServer
@using HomeschoolManager.Web.Services
@inject SessionState Session
@implements IDisposable

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Homeschool Manager</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        @if (!Session.IsAuthenticated)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Login
                </NavLink>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="setup">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Setup
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="requirements">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Requirements
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="courses">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Courses
                </NavLink>
            </div>
        }
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        Session.Changed += OnSessionChanged;
    }

    private void OnSessionChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Session.Changed -= OnSessionChanged;
    }
}
